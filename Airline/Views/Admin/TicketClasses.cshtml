@model IEnumerable<Airline.Models.TicketClass>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Ticket Classes";

    var classes = Model?.ToList() ?? new List<Airline.Models.TicketClass>();
    var totalClasses = classes.Count;
    var usedClasses = classes.Count(x => x.Tickets.Any() || x.TicketPrices.Any());
    var priceLinkedClasses = classes.Count(x => x.TicketPrices.Any());
    var availableClasses = totalClasses - usedClasses;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-unified.css" asp-append-version="true" />
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Ticketing</div>
        <h1 class="page-title">Manage <span>Ticket Classes</span></h1>
        <p class="page-subtitle">Maintain cabin class definitions used for pricing, seats and bookings.</p>
    </div>

    <div class="page-actions">
        <button type="button" class="btn-ghost js-refresh-page">
            <i class="fa-solid fa-arrows-rotate"></i> Refresh
        </button>
        <button type="button" class="btn-primary js-open-create-modal">
            <i class="fa-solid fa-layer-group"></i> Add Class
        </button>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-box alert-success">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-box alert-error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}

<div class="kpi-grid">
    <div class="kpi-card" style="--kpi-accent:#17aab8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-ticket"></i></div>
        </div>
        <div class="kpi-value">@totalClasses</div>
        <div class="kpi-label">Total Classes</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#f0b429">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-sack-dollar"></i></div>
        </div>
        <div class="kpi-value">@priceLinkedClasses</div>
        <div class="kpi-label">Classes Linked To Prices</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#5de8a8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-check-double"></i></div>
        </div>
        <div class="kpi-value">@availableClasses</div>
        <div class="kpi-label">Safe To Remove</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#ff6b6b">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-lock"></i></div>
        </div>
        <div class="kpi-value">@usedClasses</div>
        <div class="kpi-label">Classes In Use</div>
    </div>
</div>

<div class="table-card">
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="ticketClassSearch" placeholder="Search class name..." />
            </div>

            <select id="ticketClassUsageFilter" class="toolbar-select">
                <option value="">All Statuses</option>
                <option value="ACTIVE">In Use</option>
                <option value="IDLE">Available</option>
            </select>
        </div>

        <div class="toolbar-right">
            <span class="result-text">
                Total: <strong id="ticketClassCount">@totalClasses</strong> class(es)
            </span>
        </div>
    </div>

    <div class="table-wrap">
        <table class="data-table" id="ticketClassesTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Class Name</th>
                    <th>Pricing Links</th>
                    <th>Ticket Usage</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (classes.Any())
                {
                    foreach (var item in classes)
                    {
                        var priceCount = item.TicketPrices.Count;
                        var ticketCount = item.Tickets.Count;
                        var isUsed = priceCount > 0 || ticketCount > 0;
                        var usage = isUsed ? "ACTIVE" : "IDLE";

                        <tr class="ticket-class-row"
                            data-search="@item.ClassName"
                            data-usage="@usage">
                            <td class="td-mono">#@item.ClassId</td>
                            <td class="td-bold">@item.ClassName</td>
                            <td>
                                <div class="metric-stack">
                                    <span class="metric-primary">@priceCount linked price(s)</span>
                                    <span class="metric-secondary">Pricing records attached to this class</span>
                                </div>
                            </td>
                            <td>
                                <div class="metric-stack">
                                    <span class="metric-primary">@ticketCount ticket(s)</span>
                                    <span class="metric-secondary">Issued or reserved using this class</span>
                                </div>
                            </td>
                            <td>
                                <span class="status-pill @(isUsed ? "pill-gold" : "pill-green")">
                                    @(isUsed ? "IN USE" : "AVAILABLE")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="row-actions">
                                    <button type="button"
                                            class="icon-btn edit-btn js-open-edit-modal"
                                            data-class-id="@item.ClassId"
                                            data-class-name="@item.ClassName"
                                            title="Edit ticket class">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>

                                    <button type="button"
                                            class="icon-btn delete-btn js-open-delete-modal"
                                            data-class-id="@item.ClassId"
                                            data-class-name="@item.ClassName"
                                            disabled="@isUsed"
                                            title="Delete ticket class">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="empty-state">
                            <i class="fa-solid fa-ticket"></i>
                            No ticket classes found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="createModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3>Create Ticket Class</h3>
                <p>Add a new class for booking and pricing.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form asp-controller="ManageTicketClass" asp-action="CreateTicketClass" method="post" class="form-shell">
            @Html.AntiForgeryToken()

            <div class="form-grid">
                <div class="form-group form-group-full">
                    <label for="createClassName">Class Name</label>
                    <input type="text" id="createClassName" name="className" maxlength="50" required placeholder="e.g. Premium Economy" />
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i> Save Class
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="editModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3>Edit Ticket Class</h3>
                <p>Update the selected class name.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form asp-controller="ManageTicketClass" asp-action="EditTicketClass" method="post" class="form-shell">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="editClassId" />

            <div class="form-grid">
                <div class="form-group form-group-full">
                    <label for="editClassName">Class Name</label>
                    <input type="text" id="editClassName" name="className" maxlength="50" required />
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i> Update Class
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3>Delete Ticket Class</h3>
                <p>This action cannot be undone.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form asp-controller="ManageTicketClass" asp-action="DeleteTicketClass" method="post" class="form-shell">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteClassId" />

            <div class="delete-content" style="padding:0 0 0.2rem;">
                <p>Are you sure you want to delete this ticket class?</p>
                <div class="delete-target" id="deleteTargetText"></div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="submit" class="btn-danger">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-ticket-classes.js" asp-append-version="true"></script>
}
