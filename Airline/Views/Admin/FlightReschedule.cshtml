@model IEnumerable<Airline.Models.FlightSchedule>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Flight Reschedule Management";
    var flights = ViewBag.Flights as IEnumerable<Airline.Models.Flight>;
    var search = ViewBag.Search as string ?? "";
    var statusFilter = ViewBag.StatusFilter as string ?? "";
    var filterDate = ViewBag.FilterDate as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-reschedule.css" />
}

<!-- Page Header -->
<div class="schedule-header">
    <div class="page-title-block">
        <div class="page-greeting"><i class="fa-solid fa-clock-rotate-left"></i> Operations Control</div>
        <h1 class="page-title">Flight Reschedule</h1>
        <p class="page-subtitle">Manage delays, time adjustments, and flight cancellations</p>
    </div>
</div>

<!-- Filter Bar -->
<form method="get" class="filter-bar" asp-controller="Admin" asp-action="FlightReschedule">
    <div class="filter-group">
        <label>Flight / Route Keyword</label>
        <input type="text" name="search" placeholder="e.g., VN123" value="@search" />
    </div>
    <div class="filter-group">
        <label>Status</label>
        <select name="status">
            <option value="ALL" selected="@(statusFilter == "ALL" || string.IsNullOrEmpty(statusFilter))">All Statuses</option>
            <option value="SCHEDULED" selected="@(statusFilter == "SCHEDULED")">Scheduled</option>
            <option value="DELAYED" selected="@(statusFilter == "DELAYED")">Delayed</option>
        </select>
    </div>
    <div class="filter-group">
        <label>Departure Date</label>
        <input type="date" name="filterDate" value="@filterDate" />
    </div>
    <button type="submit" class="filter-btn"><i class="fa-solid fa-filter"></i> Apply Filters</button>
</form>

<!-- Data Table -->
<div class="schedule-table-card">
    <table class="schedule-table">
        <thead>
            <tr>
                <th>Flight Info</th>
                <th>Current Departure</th>
                <th>Current Arrival</th>
                <th>Status</th>
                <th>Quick Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var s in Model)
                {
                    var depCity = s.Flight?.Route?.DepartureCityNavigation?.CityName ?? "—";
                    var arrCity = s.Flight?.Route?.ArrivalCityNavigation?.CityName ?? "—";
                    var flightNum = s.Flight?.FlightNumber ?? "—";

                    var isEditable = (s.Status == "SCHEDULED" || s.Status == "DELAYED");
                    var isDelayed = s.Status == "DELAYED";

                    var pillClass = "pill-scheduled";
                    var statusVi = "Scheduled";
                    if (s.Status == "DELAYED") { pillClass = "pill-delayed"; statusVi = "Delayed"; }
                    else if (s.Status == "CANCELLED") { pillClass = "pill-cancelled"; statusVi = "Cancelled"; }
                    else if (s.Status == "COMPLETED") { pillClass = "pill-completed"; statusVi = "Completed"; }

                    <tr>
                        <td>
                            <div class="route-cell">
                                <span class="route-cities">@depCity → @arrCity</span>
                                <span class="flight-num"><i class="fa-solid fa-plane"></i> @flightNum</span>
                            </div>
                        </td>
                        <td>
                            <div class="time-badge @(isDelayed ? "delay-badge" : "")">
                                <i class="fa-solid fa-plane-departure"></i>
                                @s.DepartureTime.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </td>
                        <td>
                            <div class="time-badge @(isDelayed ? "delay-badge" : "")">
                                <i class="fa-solid fa-plane-arrival"></i>
                                @s.ArrivalTime.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </td>
                        <td>
                            <span class="status-pill @pillClass">@statusVi</span>
                        </td>
                        <td>
                            <div class="action-btns">
                                @if (isEditable)
                                {
                                    <button class="act-btn act-reschedule" title="Adjust Times" onclick="openRescheduleModal(@s.ScheduleId)">
                                        <i class="fa-solid fa-clock-rotate-left"></i> Reschedule
                                    </button>
                                    <button class="act-btn act-cancel-flight" title="Cancel Flight" onclick="openCancelModal(@s.ScheduleId)">
                                        <i class="fa-solid fa-ban"></i> Cancel Flight
                                    </button>
                                }
                                else
                                {
                                    <button class="act-btn act-disabled" disabled>
                                        <i class="fa-solid fa-lock"></i> Locked
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5">
                        <div class="empty-state">
                            <i class="fa-solid fa-clipboard-check"></i>
                            <div>No flights require rescheduling based on your filters</div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ======================= MODALS ======================= -->

<!-- RESCHEDULE MODAL -->
<div class="modal-overlay" id="rescheduleModal">
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title" id="rTitle"><i class="fa-solid fa-clock-rotate-left" style="color:var(--accent-gold);margin-right:6px"></i> Reschedule Flight</span>
            <button class="modal-close" onclick="closeModal('rescheduleModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="rsId" value="0" />

            <div class="info-box" id="rsInfoBox">
                Loading flight info...
            </div>

            <div class="form-group" style="margin-top:0.5rem">
                <label class="form-label">New Departure Time</label>
                <input type="datetime-local" class="form-control" id="rsDepTime" />
            </div>

            <div class="form-group">
                <label class="form-label">New Arrival Time</label>
                <input type="datetime-local" class="form-control" id="rsArrTime" />
            </div>

            <div class="form-group">
                <label class="form-label">Update Status</label>
                <select class="form-control" id="rsStatus">
                    <option value="DELAYED">Mark as Delayed</option>
                    <option value="SCHEDULED">Revert to Scheduled</option>
                </select>
                <small style="color:rgba(255,255,255,0.4);font-size:0.75rem">Delaying a flight may send automated notifications to booked passengers.</small>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('rescheduleModal')">Discard Changes</button>
            <button class="btn-submit" onclick="submitReschedule()"><i class="fa-solid fa-check"></i> Confirm Reschedule</button>
        </div>
    </div>
</div>

<!-- CANCEL FLIGHT MODAL -->
<div class="modal-overlay" id="cancelModal">
    <div class="modal-box" style="width:min(450px,90vw)">
        <div class="modal-header">
            <span class="modal-title"><i class="fa-solid fa-ban" style="color:var(--accent-coral);margin-right:6px"></i> Cancel Flight</span>
            <button class="modal-close" onclick="closeModal('cancelModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body" style="text-align:center;padding:1.5rem 1.4rem">
            <p style="color:rgba(255,255,255,0.8);font-size:1.05rem;margin-bottom:0.5rem">
                You are about to cancel this flight.
            </p>
            <p style="color:rgba(255,255,255,0.5);font-size:0.9rem">
                This will change its status to <strong style="color:var(--accent-coral)">CANCELLED</strong>. Passengers may need to be refunded or rebooked. This action should be taken carefully.
            </p>
            <input type="hidden" id="cancelId" />
        </div>
        <div class="modal-footer" style="justify-content:center">
            <button class="btn-cancel" onclick="closeModal('cancelModal')">Do not cancel</button>
            <button class="btn-danger" onclick="submitCancelFlight()"><i class="fa-solid fa-check"></i> Yes, Cancel Flight</button>
        </div>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/admin-reschedule.js"></script>
}
