@model IEnumerable<Airline.Models.Promotion>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Promotions";

    var promotions = Model?.ToList() ?? new List<Airline.Models.Promotion>();
    var today = DateOnly.FromDateTime(DateTime.Now);
    var totalPromotions = promotions.Count;
    var activePromotions = promotions.Count(p => (!p.StartDate.HasValue || p.StartDate <= today) && (!p.EndDate.HasValue || p.EndDate >= today));
    var upcomingPromotions = promotions.Count(p => p.StartDate.HasValue && p.StartDate > today);
    var expiredPromotions = promotions.Count(p => p.EndDate.HasValue && p.EndDate < today);
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-unified.css" asp-append-version="true" />
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Commerce</div>
        <h1 class="page-title">Manage <span>Promotions</span></h1>
        <p class="page-subtitle">Create, update, and monitor discount codes used during flight booking.</p>
    </div>

    <div class="page-actions">
        <button type="button" class="btn-ghost js-refresh-page">
            <i class="fa-solid fa-arrows-rotate"></i> Refresh
        </button>
        <button type="button" class="btn-primary" onclick="openCreatePromotionModal()">
            <i class="fa-solid fa-tags"></i> Add Promotion
        </button>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card" style="--kpi-accent:#17aab8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-ticket-percent"></i></div>
        </div>
        <div class="kpi-value">@totalPromotions</div>
        <div class="kpi-label">Total Promotions</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#5de8a8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-bolt"></i></div>
        </div>
        <div class="kpi-value">@activePromotions</div>
        <div class="kpi-label">Active Now</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#f0b429">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-calendar-day"></i></div>
        </div>
        <div class="kpi-value">@upcomingPromotions</div>
        <div class="kpi-label">Upcoming</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#ff6b6b">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-clock-rotate-left"></i></div>
        </div>
        <div class="kpi-value">@expiredPromotions</div>
        <div class="kpi-label">Expired</div>
    </div>
</div>

<div class="table-card">
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="promotionSearch" placeholder="Search by code..." />
            </div>

            <select id="promotionStatusFilter" class="toolbar-select">
                <option value="">All Statuses</option>
                <option value="ACTIVE">Active</option>
                <option value="UPCOMING">Upcoming</option>
                <option value="EXPIRED">Expired</option>
            </select>
        </div>

        <div class="toolbar-right">
            <span class="result-text">
                Total: <strong id="promotionCount">@totalPromotions</strong> promotion(s)
            </span>
        </div>
    </div>

    <div class="table-wrap">
        <table class="data-table" id="promotionTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Code</th>
                    <th>Discount</th>
                    <th>Period</th>
                    <th>Usage</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (promotions.Any())
                {
                    foreach (var promotion in promotions)
                    {
                        var status = "ACTIVE";
                        if (promotion.StartDate.HasValue && promotion.StartDate.Value > today)
                        {
                            status = "UPCOMING";
                        }
                        else if (promotion.EndDate.HasValue && promotion.EndDate.Value < today)
                        {
                            status = "EXPIRED";
                        }

                        var statusClass = status switch
                        {
                            "ACTIVE" => "pill-green",
                            "UPCOMING" => "pill-gold",
                            _ => "pill-red"
                        };

                        <tr class="promotion-row"
                            data-search="@promotion.PromoCode"
                            data-status="@status">
                            <td class="td-mono">#@promotion.PromoId</td>
                            <td class="td-bold">@promotion.PromoCode</td>
                            <td class="amount-text">@((promotion.DiscountPercent ?? 0).ToString("N0"))%</td>
                            <td>
                                <div class="detail-stack">
                                    <span class="detail-primary">@(promotion.StartDate?.ToString("dd/MM/yyyy") ?? "-")</span>
                                    <span class="detail-secondary">to @(promotion.EndDate?.ToString("dd/MM/yyyy") ?? "-")</span>
                                </div>
                            </td>
                            <td>
                                <div class="metric-stack">
                                    <span class="metric-primary">@promotion.BookingPromotions.Count booking(s)</span>
                                    <span class="metric-secondary">Applied by passengers</span>
                                </div>
                            </td>
                            <td>
                                <span class="status-pill @statusClass">@status</span>
                            </td>
                            <td class="text-center">
                                <div class="row-actions">
                                    <button type="button"
                                            class="icon-btn edit-btn"
                                            title="Edit promotion"
                                            onclick="openEditPromotionModal(@promotion.PromoId)">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>

                                    <button type="button"
                                            class="icon-btn delete-btn"
                                            title="Delete promotion"
                                            data-promo-code="@promotion.PromoCode"
                                            onclick="openDeletePromotionModal(@promotion.PromoId, this.dataset.promoCode)"
                                            disabled="@(promotion.BookingPromotions.Any())">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="empty-state">
                            <i class="fa-solid fa-tags"></i>
                            No promotions found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="promotionModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3 id="promotionModalTitle">Add Promotion</h3>
                <p>Create or update a discount code for bookings.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="form-shell">
            <input type="hidden" id="promotionId" value="0" />

            <div class="form-grid">
                <div class="form-group form-group-full">
                    <label for="promotionCode">Promotion Code</label>
                    <input type="text" id="promotionCode" placeholder="Example: SUMMER15" maxlength="50" />
                </div>

                <div class="form-group">
                    <label for="discountPercent">Discount Percent</label>
                    <input type="number" id="discountPercent" min="1" max="100" placeholder="15" />
                </div>

                <div class="form-group">
                    <label for="promotionStartDate">Start Date</label>
                    <input type="date" id="promotionStartDate" />
                </div>

                <div class="form-group">
                    <label for="promotionEndDate">End Date</label>
                    <input type="date" id="promotionEndDate" />
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="button" class="btn-primary" onclick="submitPromotion()">
                    <i class="fa-solid fa-floppy-disk"></i> Save Promotion
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal-overlay" id="deletePromotionModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3>Delete Promotion</h3>
                <p>This action cannot be undone.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="delete-content">
            <p>Are you sure you want to delete this promotion?</p>
            <div class="delete-target" id="deletePromotionTargetText"></div>
            <input type="hidden" id="deletePromotionId" />
        </div>

        <div class="form-shell" style="padding-top:0.8rem;">
            <div class="modal-footer" style="margin-top:0;">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="button" class="btn-danger" onclick="submitDeletePromotion()">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<div id="toast" class="toast"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/admin-promotions.js" asp-append-version="true"></script>
}
