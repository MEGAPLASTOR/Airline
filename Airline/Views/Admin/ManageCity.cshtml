@model IEnumerable<Airline.Models.Cities>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Cities";

    var cities = Model?.ToList() ?? new List<Airline.Models.Cities>();
    var totalCities = cities.Count;
    var countryCount = cities
        .Select(x => x.Country?.Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();
    var activeCities = cities.Count(x => x.RouteDepartureCityNavigations.Count + x.RouteArrivalCityNavigations.Count > 0);
    var inactiveCities = totalCities - activeCities;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-unified.css" asp-append-version="true" />
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Master Data</div>
        <h1 class="page-title">Manage <span>Cities</span></h1>
        <p class="page-subtitle">Standardize departure and arrival cities used across the airline system.</p>
    </div>

    <div class="page-actions">
        <button type="button" class="btn-ghost js-refresh-page">
            <i class="fa-solid fa-arrows-rotate"></i> Refresh
        </button>
        <button type="button" class="btn-primary" onclick="openCreateModal()">
            <i class="fa-solid fa-city"></i> Add City
        </button>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card" style="--kpi-accent:#17aab8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-city"></i></div>
        </div>
        <div class="kpi-value">@totalCities</div>
        <div class="kpi-label">Total Cities</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#f0b429">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-earth-asia"></i></div>
        </div>
        <div class="kpi-value">@countryCount</div>
        <div class="kpi-label">Countries Covered</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#5de8a8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-route"></i></div>
        </div>
        <div class="kpi-value">@activeCities</div>
        <div class="kpi-label">Cities In Active Routes</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#ff6b6b">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-map-location-dot"></i></div>
        </div>
        <div class="kpi-value">@inactiveCities</div>
        <div class="kpi-label">Cities Not In Use</div>
    </div>
</div>

<div class="table-card">
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="citySearch" placeholder="Search by city or country..." />
            </div>

            <select id="cityUsageFilter" class="toolbar-select">
                <option value="">All Statuses</option>
                <option value="ACTIVE">In Use</option>
                <option value="IDLE">Not In Use</option>
            </select>
        </div>

        <div class="toolbar-right">
            <span class="result-text">
                Total: <strong id="cityCount">@totalCities</strong> city(s)
            </span>
        </div>
    </div>

    <div class="table-wrap">
        <table class="data-table" id="citiesTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>City</th>
                    <th>Country</th>
                    <th>Routes Linked</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (cities.Any())
                {
                    foreach (var city in cities)
                    {
                        var routesCount = city.RouteDepartureCityNavigations.Count + city.RouteArrivalCityNavigations.Count;
                        var usage = routesCount > 0 ? "ACTIVE" : "IDLE";

                        <tr class="city-row"
                            data-search="@($"{city.CityName} {city.Country}")"
                            data-usage="@usage">
                            <td class="td-mono">#@city.CityId</td>
                            <td class="td-bold">@city.CityName</td>
                            <td>@city.Country</td>
                            <td>
                                <div class="metric-stack">
                                    <span class="metric-primary">@routesCount route(s)</span>
                                    <span class="metric-secondary">
                                        @(routesCount > 0 ? "Connected to the flight network" : "No route currently attached")
                                    </span>
                                </div>
                            </td>
                            <td>
                                <span class="status-pill @(routesCount > 0 ? "pill-gold" : "pill-neutral")">
                                    @(routesCount > 0 ? "IN USE" : "IDLE")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="row-actions">
                                    <button type="button"
                                            class="icon-btn edit-btn"
                                            title="Edit city"
                                            onclick="openEditModal(@city.CityId)">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>

                                    <button type="button"
                                            class="icon-btn delete-btn"
                                            title="Delete city"
                                            onclick="openDeleteModal(@city.CityId, '@city.CityName')"
                                            disabled="@(routesCount > 0)">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="empty-state">
                            <i class="fa-solid fa-city"></i>
                            No cities found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="cityModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3 id="mTitle">Add City</h3>
                <p>Create or update a city used in airline routes.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="form-shell">
            <input type="hidden" id="cId" value="0" />

            <div class="form-grid">
                <div class="form-group form-group-full">
                    <label for="cName">City Name</label>
                    <input type="text" id="cName" placeholder="e.g. Ho Chi Minh City" />
                </div>

                <div class="form-group form-group-full">
                    <label for="cCountry">Country</label>
                    <input type="text" id="cCountry" placeholder="e.g. Vietnam" />
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="button" class="btn-primary" onclick="submitCity()">
                    <i class="fa-solid fa-floppy-disk"></i> Save City
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3>Delete City</h3>
                <p>This action cannot be undone.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="delete-content">
            <p>Are you sure you want to delete this city?</p>
            <div class="delete-target" id="deleteTargetText"></div>
            <input type="hidden" id="delId" />
        </div>

        <div class="form-shell" style="padding-top:0.8rem;">
            <div class="modal-footer" style="margin-top:0;">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="button" class="btn-danger" onclick="submitDelete()">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<div id="toast" class="toast"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/admin-cities.js" asp-append-version="true"></script>
}
