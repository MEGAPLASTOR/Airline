@model IEnumerable<Airline.Models.Cities>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Cities";
    var search = ViewBag.Search as string ?? "";
}

<!-- Page Header -->
<div class="schedule-header">
    <div class="page-title-block">
        <div class="page-greeting">Master Data</div>
        <h1 class="page-title">Manage Cities</h1>
        <p class="page-subtitle">Configure operational cities and destinations</p>
    </div>
    <button class="btn-create" onclick="openCreateModal()">
        <i class="fa-solid fa-plus"></i> Add New City
    </button>
</div>

<!-- Filter Bar -->
<form method="get" class="filter-bar" asp-controller="Admin" asp-action="ManageCity">
    <input type="text" name="search" placeholder="Search city or country..." value="@search" style="min-width:250px" />
    <button type="submit" class="filter-btn"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
</form>

<!-- Data Table -->
<div class="schedule-table-card">
    <table class="schedule-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>City Name</th>
                <th>Country</th>
                <th>Routes Used In</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var c in Model)
                {
                    var routesCount = c.RouteDepartureCityNavigations.Count + c.RouteArrivalCityNavigations.Count;
                    <tr>
                        <td class="td-mono">#@c.CityId</td>
                        <td style="font-weight:600;color:#fff">@c.CityName</td>
                        <td>@c.Country</td>
                        <td>
                            @if (routesCount > 0)
                            {
                                <span style="color:var(--accent-coral)"><i class="fa-solid fa-link" style="font-size:0.85em;margin-right:4px"></i> @routesCount routes</span>
                            }
                            else
                            {
                                <span style="color:rgba(255,255,255,0.4)">Not in use</span>
                            }
                        </td>
                        <td>
                            <div class="action-btns">
                                <button class="act-btn act-edit" title="Edit City" onclick="openEditModal(@c.CityId)">
                                    <i class="fa-solid fa-pen"></i> Edit
                                </button>
                                @if (routesCount == 0)
                                {
                                    <button class="act-btn act-cancel" title="Delete City" onclick="openDeleteModal(@c.CityId)">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </button>
                                }
                                else
                                {
                                    <button class="act-btn act-cancel" style="opacity:0.3;cursor:not-allowed" title="Cannot delete city in use">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5">
                        <div class="empty-state">
                            <i class="fa-solid fa-city"></i>
                            <div>No cities found</div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ======================= MODALS ======================= -->
<!-- CREATE / EDIT MODAL -->
<div class="modal-overlay" id="cityModal">
    <div class="modal-box" style="width: min(400px, 90vw);">
        <div class="modal-header">
            <span class="modal-title" id="mTitle"><i class="fa-solid fa-plus" style="color:var(--accent-gold);margin-right:6px"></i> Add City</span>
            <button class="modal-close" onclick="closeModal('cityModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="cId" value="0" />

            <div class="form-group">
                <label class="form-label">City Name</label>
                <input type="text" class="form-control" id="cName" placeholder="e.g., Ho Chi Minh City" />
            </div>

            <div class="form-group">
                <label class="form-label">Country</label>
                <input type="text" class="form-control" id="cCountry" placeholder="e.g., Vietnam" />
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('cityModal')">Cancel</button>
            <button class="btn-submit" onclick="submitCity()"><i class="fa-solid fa-check"></i> Save City</button>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal-box" style="width:min(400px,90vw)">
        <div class="modal-header">
            <span class="modal-title"><i class="fa-solid fa-triangle-exclamation" style="color:var(--accent-coral);margin-right:6px"></i> Confirm Deletion</span>
            <button class="modal-close" onclick="closeModal('deleteModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body" style="text-align:center;padding:1.5rem 1.4rem">
            <p style="color:rgba(255,255,255,0.7);font-size:0.95rem">
                Are you sure you want to <strong style="color:var(--accent-coral)">delete</strong> this city?<br />
                This action cannot be undone.
            </p>
            <input type="hidden" id="delId" />
        </div>
        <div class="modal-footer" style="justify-content:center">
            <button class="btn-cancel" onclick="closeModal('deleteModal')">No, keep it</button>
            <button class="btn-danger" onclick="submitDelete()"><i class="fa-solid fa-trash"></i> Delete</button>
        </div>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast"></div>

@Html.AntiForgeryToken()

<style>
    /* Styling similar to Flight Schedules for consistency */
    .schedule-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 1.5rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .page-title-block {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .page-greeting {
        color: var(--accent-gold);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        margin: 0;
    }

    .page-subtitle {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.95rem;
        margin: 0;
    }

    .btn-create {
        background: linear-gradient(135deg, var(--accent-gold), #e5a93d);
        color: #000;
        border: none;
        padding: 0.8rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s ease;
        box-shadow: 0 4px 15px rgba(212, 175, 55, 0.2);
    }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(212, 175, 55, 0.3);
        }

    .filter-bar {
        background: var(--surface-light);
        padding: 1rem;
        border-radius: 12px;
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        flex-wrap: wrap;
    }

        .filter-bar input {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 0.7rem 1rem;
            border-radius: 6px;
            flex: 1;
            font-size: 0.9rem;
        }

    .filter-btn {
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0 1.5rem;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 500;
        transition: all 0.2s;
    }

        .filter-btn:hover {
            background: rgba(255, 255, 255, 0.1);
        }

    .schedule-table-card {
        background: var(--surface-light);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        overflow-x: auto;
    }

    .schedule-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 800px;
    }

        .schedule-table th {
            text-align: left;
            padding: 1.2rem 1rem;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255, 255, 255, 0.4);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            font-weight: 600;
        }

        .schedule-table td {
            padding: 1.2rem 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            vertical-align: middle;
            font-size: 0.95rem;
            color: rgba(255, 255, 255, 0.8);
        }

        .schedule-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

    .td-mono {
        font-family: 'JetBrains Mono', Consolas, monospace;
        color: var(--accent-gold);
        font-size: 0.9rem;
    }

    .action-btns {
        display: flex;
        gap: 0.5rem;
    }

    .act-btn {
        border: none;
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        font-size: 0.85rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
    }

    .act-edit {
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
    }

        .act-edit:hover {
            background: rgba(255, 255, 255, 0.15);
        }

    .act-cancel {
        background: rgba(255, 82, 82, 0.1);
        color: var(--accent-coral);
    }

        .act-cancel:hover {
            background: rgba(255, 82, 82, 0.2);
        }

    .empty-state {
        padding: 4rem 1rem;
        text-align: center;
        color: rgba(255, 255, 255, 0.3);
    }

        .empty-state i {
            font-size: 3rem;
            margin-bottom: 1rem;
            color: rgba(255, 255, 255, 0.1);
        }

    /* Modal Styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s;
    }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

    .modal-box {
        background: var(--surface-dark);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
        transform: translateY(20px);
        transition: all 0.3s;
    }

    .modal-overlay.active .modal-box {
        transform: translateY(0);
    }

    .modal-header {
        padding: 1.2rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-title {
        font-weight: 600;
        font-size: 1.1rem;
        color: #fff;
    }

    .modal-close {
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.5);
        cursor: pointer;
        font-size: 1.2rem;
        transition: color 0.2s;
    }

        .modal-close:hover {
            color: #fff;
        }

    .modal-body {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.6);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.8rem 1rem;
        border-radius: 6px;
        color: #fff;
        font-size: 0.95rem;
        transition: border-color 0.2s;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--accent-gold);
        }

    .modal-footer {
        padding: 1.2rem 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
    }

    .btn-cancel {
        background: none;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #fff;
        padding: 0.6rem 1.2rem;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-cancel:hover {
            background: rgba(255, 255, 255, 0.05);
        }

    .btn-submit {
        background: var(--accent-gold);
        color: #000;
        border: none;
        padding: 0.6rem 1.2rem;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: filter 0.2s;
    }

        .btn-submit:hover {
            filter: brightness(1.1);
        }

    .btn-danger {
        background: var(--accent-coral);
        color: #fff;
        border: none;
        padding: 0.6rem 1.2rem;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-danger:hover {
            filter: brightness(1.1);
        }

    /* Toast */
    .toast {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: #333;
        color: #fff;
        padding: 1rem 1.5rem;
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        transform: translateY(100px);
        opacity: 0;
        transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        z-index: 2000;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 10px;
        border-left: 4px solid var(--accent-gold);
    }

        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }
</style>

@section Scripts {
    <script>
        function showToast(msg, isError = false) {
            const toast = document.getElementById('toast');
            toast.style.borderLeftColor = isError ? 'var(--accent-coral)' : 'var(--accent-gold)';
            const icon = isError ? '<i class="fa-solid fa-circle-exclamation" style="color:var(--accent-coral)"></i>'
                                 : '<i class="fa-solid fa-circle-check" style="color:var(--accent-gold)"></i>';
            toast.innerHTML = icon + ' ' + msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        function openCreateModal() {
            document.getElementById('mTitle').innerHTML = '<i class="fa-solid fa-plus" style="color:var(--accent-gold);margin-right:6px"></i> Add City';
            document.getElementById('cId').value = '0';
            document.getElementById('cName').value = '';
            document.getElementById('cCountry').value = '';
            document.getElementById('cityModal').classList.add('active');
        }

        async function openEditModal(id) {
            const res = await fetch('/Admin/GetCity/' + id);
            if (!res.ok) { showToast('Failed to load data', true); return; }
            const c = await res.json();
            document.getElementById('mTitle').innerHTML = '<i class="fa-solid fa-pen" style="color:var(--accent-gold);margin-right:6px"></i> Edit City';
            document.getElementById('cId').value = c.cityId;
            document.getElementById('cName').value = c.cityName;
            document.getElementById('cCountry').value = c.country;
            document.getElementById('cityModal').classList.add('active');
        }

        async function submitCity() {
            const id = document.getElementById('cId').value;
            const name = document.getElementById('cName').value.trim();
            const country = document.getElementById('cCountry').value.trim();

            if (!name || !country) {
                showToast('City name and country are required', true);
                return;
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const url = id == '0' ? '/Admin/CreateCity' : '/Admin/EditCity/' + id;

            const fd = new FormData();
            if (id != '0') fd.append('id', id);
            fd.append('cityName', name);
            fd.append('country', country);
            fd.append('__RequestVerificationToken', token);

            try {
                const res = await fetch(url, { method: 'POST', body: fd });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    showToast(data.message, true);
                }
            } catch (e) {
                showToast('A network error occurred', true);
            }
        }

        function openDeleteModal(id) {
            document.getElementById('delId').value = id;
            document.getElementById('deleteModal').classList.add('active');
        }

        async function submitDelete() {
            const id = document.getElementById('delId').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const fd = new FormData();
            fd.append('id', id);
            fd.append('__RequestVerificationToken', token);

            try {
                const res = await fetch('/Admin/DeleteCity/' + id, { method: 'POST', body: fd });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    showToast(data.message, true);
                }
            } catch (e) {
                showToast('A network error occurred', true);
            }
            closeModal('deleteModal');
        }
    </script>
}
