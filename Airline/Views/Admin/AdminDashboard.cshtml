@using System.Text.Json
@model Airline.Models.AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";

    var dashboard = Model ?? new Airline.Models.AdminDashboardViewModel();
    var bookingLabelsJson = JsonSerializer.Serialize(dashboard.BookingChartLabels);
    var bookingValuesJson = JsonSerializer.Serialize(dashboard.BookingChartValues);
    var revenueLabelsJson = JsonSerializer.Serialize(dashboard.RevenueChartLabels);
    var revenueValuesJson = JsonSerializer.Serialize(dashboard.RevenueChartValues);
    var classLabelsJson = JsonSerializer.Serialize(dashboard.TicketClasses.Select(x => x.Label));
    var classValuesJson = JsonSerializer.Serialize(dashboard.TicketClasses.Select(x => x.Count));
    var classPercentagesJson = JsonSerializer.Serialize(dashboard.TicketClasses.Select(x => x.Percentage));
    var routeLabelsJson = JsonSerializer.Serialize(dashboard.TopRoutes.Select(x => x.Label));
    var routeValuesJson = JsonSerializer.Serialize(dashboard.TopRoutes.Select(x => x.PassengerCount));
    var spark1Json = JsonSerializer.Serialize(dashboard.TotalUsers.Sparkline);
    var spark2Json = JsonSerializer.Serialize(dashboard.RevenueThisMonth.Sparkline);
    var spark3Json = JsonSerializer.Serialize(dashboard.ActiveBookings.Sparkline);
    var spark4Json = JsonSerializer.Serialize(dashboard.FlightsToday.Sparkline);
}

@section Styles {
    <style>
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.15rem;
            margin-bottom: 1.5rem;
        }

        .kpi-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-lg);
            padding: 1.2rem 1.35rem 1rem;
            position: relative;
            overflow: hidden;
            transition: border-color var(--tr), transform var(--tr);
            cursor: default;
        }

            .kpi-card:hover {
                border-color: rgba(23,170,184,0.3);
                transform: translateY(-2px);
            }

            .kpi-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--kpi-accent, var(--ocean-aqua));
                border-radius: var(--radius-lg) var(--radius-lg) 0 0;
            }

        .kpi-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 0.75rem;
        }

        .kpi-icon-wrap {
            width: 40px;
            height: 40px;
            border-radius: var(--radius-md);
            background: rgba(255,255,255,0.06);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            color: var(--kpi-accent, var(--ocean-aqua));
        }

        .kpi-trend {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            font-size: 0.72rem;
            font-weight: 600;
            padding: 0.18rem 0.5rem;
            border-radius: 20px;
        }

            .kpi-trend.up {
                background: rgba(93,232,168,0.12);
                color: var(--accent-green);
            }

            .kpi-trend.down {
                background: rgba(255,107,107,0.12);
                color: var(--accent-coral);
            }

            .kpi-trend.flat {
                background: rgba(255,255,255,0.08);
                color: rgba(255,255,255,0.72);
            }

        .kpi-value {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 700;
            color: #fff;
            line-height: 1;
            margin-bottom: 0.25rem;
        }

        .kpi-label {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.42);
        }

        .kpi-sparkline {
            margin-top: 0.75rem;
            height: 36px;
        }

            .kpi-sparkline canvas {
                width: 100% !important;
                height: 36px !important;
            }

        .charts-row,
        .charts-row-3,
        .bottom-row {
            display: grid;
            gap: 1.15rem;
            margin-bottom: 1.15rem;
        }

        .charts-row {
            grid-template-columns: 1.6fr 1fr;
        }

        .charts-row-3 {
            grid-template-columns: 1fr 1fr 1fr;
        }

        .bottom-row {
            grid-template-columns: 1.45fr 0.9fr;
        }

        .chart-card,
        .table-card,
        .health-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            backdrop-filter: blur(12px);
        }

        .chart-card,
        .health-card {
            padding: 1.15rem 1.2rem;
        }

        .table-card {
            padding: 1rem 1rem 0.4rem;
        }

        .chart-wrap {
            position: relative;
            height: 300px;
        }

        .chart-wrap-sm {
            position: relative;
            height: 240px;
        }

        .chart-empty {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255,255,255,0.45);
            font-size: 0.84rem;
            text-align: center;
            padding: 1rem;
        }

        .card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .card-title {
            font-size: 0.95rem;
            font-weight: 700;
            color: #fff;
        }

        .card-subtitle {
            font-size: 0.76rem;
            color: rgba(255,255,255,0.42);
            margin-top: 0.2rem;
        }

        .card-tag {
            padding: 0.32rem 0.6rem;
            border-radius: 999px;
            background: rgba(23,170,184,0.12);
            border: 1px solid rgba(23,170,184,0.2);
            color: var(--ocean-aqua);
            font-size: 0.72rem;
            font-weight: 600;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

            .data-table th {
                text-align: left;
                font-size: 0.74rem;
                color: rgba(255,255,255,0.42);
                font-weight: 600;
                padding: 0.9rem 0.85rem;
                border-bottom: 1px solid rgba(255,255,255,0.07);
            }

            .data-table td {
                padding: 0.95rem 0.85rem;
                border-bottom: 1px solid rgba(255,255,255,0.05);
                font-size: 0.84rem;
                color: rgba(255,255,255,0.8);
            }

        .td-mono {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
            color: var(--ocean-foam);
        }

        .td-bold {
            font-weight: 600;
            color: #fff;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            padding: 0.34rem 0.62rem;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .pill-green {
            background: rgba(93,232,168,0.12);
            color: var(--accent-green);
        }

        .pill-gold {
            background: rgba(240,180,41,0.12);
            color: var(--accent-gold);
        }

        .pill-red {
            background: rgba(255,107,107,0.12);
            color: var(--accent-coral);
        }

        .empty-table {
            text-align: center;
            color: rgba(255,255,255,0.45);
            padding: 1.5rem 0;
        }

        .donut-legend {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.7rem;
            margin-top: 0.9rem;
        }

        .legend-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: var(--radius-md);
            padding: 0.55rem 0.7rem;
        }

        .legend-left {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            font-size: 0.76rem;
            color: rgba(255,255,255,0.68);
        }

        .legend-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

        .legend-val {
            font-size: 0.76rem;
            color: #fff;
            font-weight: 600;
        }

        .health-item {
            margin-bottom: 1rem;
        }

            .health-item:last-child {
                margin-bottom: 0;
            }

        .health-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 0.45rem;
        }

        .health-name {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.65);
        }

        .health-val {
            font-size: 0.8rem;
            font-weight: 600;
            color: #fff;
        }

        .health-bar {
            height: 6px;
            background: rgba(255,255,255,0.07);
            border-radius: 3px;
            overflow: hidden;
        }

        .health-fill {
            height: 100%;
            border-radius: 3px;
            background: linear-gradient(90deg, var(--ocean-aqua), var(--ocean-teal));
            transition: width 1s ease;
        }

            .health-fill.warn {
                background: linear-gradient(90deg, var(--accent-gold), #e0901a);
            }

            .health-fill.crit {
                background: linear-gradient(90deg, var(--accent-coral), #d94f4f);
            }

        .quick-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.6rem;
            margin-top: 1rem;
        }

        .qa-btn {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.6rem 0.75rem;
            border-radius: var(--radius-md);
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.07);
            color: rgba(255,255,255,0.6);
            font-size: 0.78rem;
            transition: background var(--tr), color var(--tr), border-color var(--tr);
        }

            .qa-btn i {
                color: var(--ocean-aqua);
                font-size: 0.8rem;
            }

            .qa-btn:hover {
                background: rgba(23,170,184,0.1);
                border-color: rgba(23,170,184,0.25);
                color: #fff;
            }

        @@media (max-width: 1280px) {
            .kpi-grid {
                grid-template-columns: repeat(2,1fr);
            }
        }

        @@media (max-width: 1024px) {
            .charts-row, .charts-row-3, .bottom-row {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 640px) {
            .kpi-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Admin Dashboard</div>
        <h1 class="page-title">Welcome back, <span>Admin</span></h1>
        <p class="page-subtitle" id="dashDate"></p>
    </div>
    <div class="page-actions">
        <button class="btn-ghost"><i class="fa-solid fa-arrows-rotate"></i> Refresh</button>
        <button class="btn-primary"><i class="fa-solid fa-file-export"></i> Export Report</button>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card" style="--kpi-accent:#17aab8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-users"></i></div>
            <span class="kpi-trend up"><i class="fa-solid fa-arrow-trend-up"></i> +8.3%</span>
        </div>
        <div class="kpi-value">124,500</div>
        <div class="kpi-label">Total Users</div>
        <div class="kpi-sparkline"><canvas id="spark1"></canvas></div>
    </div>
    <div class="kpi-card" style="--kpi-accent:#f0b429">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-sack-dollar"></i></div>
            <span class="kpi-trend up"><i class="fa-solid fa-arrow-trend-up"></i> +12.5%</span>
        </div>
        <div class="kpi-value">$1.25M</div>
        <div class="kpi-label">Revenue (This Month)</div>
        <div class="kpi-sparkline"><canvas id="spark2"></canvas></div>
    </div>
    <div class="kpi-card" style="--kpi-accent:#5de8a8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-ticket"></i></div>
            <span class="kpi-trend up"><i class="fa-solid fa-arrow-trend-up"></i> +5.1%</span>
        </div>
        <div class="kpi-value">8,750</div>
        <div class="kpi-label">Active Bookings</div>
        <div class="kpi-sparkline"><canvas id="spark3"></canvas></div>
    </div>
    <div class="kpi-card" style="--kpi-accent:#ff6b6b">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-plane-departure"></i></div>
            <span class="kpi-trend down"><i class="fa-solid fa-arrow-trend-down"></i> -2.0%</span>
        </div>
        <div class="kpi-value">342</div>
        <div class="kpi-label">Flights Today</div>
        <div class="kpi-sparkline"><canvas id="spark4"></canvas></div>
    </div>
</div>

<div class="charts-row">
    <div class="chart-card">
        <div class="card-header">
            <div>
                <div class="card-title">Booking Growth</div>
                <div class="card-subtitle">Monthly bookings for current year</div>
            </div>
            <span class="card-tag">2025</span>
        </div>
        <div class="chart-wrap"><canvas id="bookingChart"></canvas></div>
    </div>
    <div class="chart-card">
        <div class="card-header">
            <div>
                <div class="card-title">Ticket Classes</div>
                <div class="card-subtitle">Distribution by class</div>
            </div>
        </div>
        <div class="chart-wrap-sm"><canvas id="classChart"></canvas></div>
        <div class="donut-legend" id="classLegend"></div>
    </div>
</div>

<div class="charts-row">
    <div class="chart-card">
        <div class="card-header">
            <div>
                <div class="card-title">Revenue Overview</div>
                <div class="card-subtitle">Monthly revenue in USD</div>
            </div>
            <span class="card-tag">This Year</span>
        </div>
        <div class="chart-wrap"><canvas id="revenueChart"></canvas></div>
    </div>
    <div class="chart-card">
        <div class="card-header">
            <div>
                <div class="card-title">Top Routes</div>
                <div class="card-subtitle">By passenger volume</div>
            </div>
        </div>
        <div class="chart-wrap"><canvas id="routeChart"></canvas></div>
    </div>
</div>

<div class="bottom-row">
    <div class="table-card">
        <div class="card-header">
            <div>
                <div class="card-title">Recent Ticket Activity</div>
                <div class="card-subtitle">Latest bookings requiring attention</div>
            </div>
            <button class="btn-ghost" style="font-size:0.75rem;padding:0.32rem 0.85rem">View All</button>
        </div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Ticket ID</th>
                    <th>Passenger</th>
                    <th>Route</th>
                    <th>Class</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="td-mono">#SKY-00421</td>
                    <td class="td-bold">Nguyen Van A</td>
                    <td>HAN → SGN</td>
                    <td>Business</td>
                    <td><span class="status-pill pill-green">Confirmed</span></td>
                </tr>
                <tr>
                    <td class="td-mono">#SKY-00422</td>
                    <td class="td-bold">Tran Thi B</td>
                    <td>SGN → DAD</td>
                    <td>Economy</td>
                    <td><span class="status-pill pill-gold">Pending</span></td>
                </tr>
                <tr>
                    <td class="td-mono">#SKY-00423</td>
                    <td class="td-bold">Le Van C</td>
                    <td>HAN → PQC</td>
                    <td>Premium</td>
                    <td><span class="status-pill pill-red">Cancelled</span></td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="health-card">
        <div class="card-header">
            <div>
                <div class="card-title">System Health</div>
                <div class="card-subtitle">Current platform status</div>
            </div>
            <span class="card-tag">Live</span>
        </div>

        <div class="health-item">
            <div class="health-top">
                <span class="health-name">Server Load</span>
                <span class="health-val">72%</span>
            </div>
            <div class="health-bar"><div class="health-fill" style="width:72%"></div></div>
        </div>

        <div class="health-item">
            <div class="health-top">
                <span class="health-name">Database</span>
                <span class="health-val">61%</span>
            </div>
            <div class="health-bar"><div class="health-fill warn" style="width:61%"></div></div>
        </div>

        <div class="health-item">
            <div class="health-top">
                <span class="health-name">Payment Gateway</span>
                <span class="health-val">95%</span>
            </div>
            <div class="health-bar"><div class="health-fill" style="width:95%"></div></div>
        </div>

        <div class="health-item">
            <div class="health-top">
                <span class="health-name">Booking Queue</span>
                <span class="health-val">38%</span>
            </div>
            <div class="health-bar"><div class="health-fill crit" style="width:38%"></div></div>
        </div>

        <div class="quick-actions">
            <button class="qa-btn"><i class="fa-solid fa-user-plus"></i> Add Staff</button>
            <button class="qa-btn"><i class="fa-solid fa-bell"></i> Alerts</button>
            <button class="qa-btn"><i class="fa-solid fa-plane"></i> Flights</button>
            <button class="qa-btn"><i class="fa-solid fa-chart-line"></i> Reports</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.getElementById("dashDate").textContent = new Date().toLocaleString("vi-VN", {
            weekday: "long",
            year: "numeric",
            month: "long",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit"
        });

        function sparkline(id, data, color) {
            new Chart(document.getElementById(id), {
                type: 'line',
                data: {
                    labels: data.map((_, i) => i + 1),
                    datasets: [{
                        data: data,
                        borderColor: color,
                        borderWidth: 2,
                        fill: false,
                        tension: 0.45,
                        pointRadius: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { enabled: false } },
                    scales: { x: { display: false }, y: { display: false } }
                }
            });
        }

        sparkline('spark1', [16, 22, 19, 28, 25, 31, 36], '#17aab8');
        sparkline('spark2', [12, 17, 15, 21, 26, 29, 35], '#f0b429');
        sparkline('spark3', [10, 12, 11, 14, 18, 17, 20], '#5de8a8');
        sparkline('spark4', [24, 22, 23, 19, 18, 17, 16], '#ff6b6b');

        new Chart(document.getElementById('bookingChart'), {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                datasets: [{
                    label: 'Bookings',
                    data: [4200, 4800, 5300, 5900, 6500, 7200, 7600, 7300, 8100, 8600, 9100, 9750],
                    borderColor: '#17aab8',
                    backgroundColor: 'rgba(23,170,184,0.15)',
                    fill: true,
                    tension: 0.35,
                    pointRadius: 3,
                    pointBackgroundColor: '#17aab8'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { ticks: { color: 'rgba(255,255,255,0.55)' }, grid: { color: 'rgba(255,255,255,0.05)' } },
                    y: { ticks: { color: 'rgba(255,255,255,0.55)' }, grid: { color: 'rgba(255,255,255,0.05)' } }
                }
            }
        });

        const classData = {
            labels: ['Economy', 'Business', 'Premium', 'First'],
            values: [58, 18, 16, 8],
            colors: ['#17aab8', '#f0b429', '#5de8a8', '#ff6b6b']
        };

        new Chart(document.getElementById('classChart'), {
            type: 'doughnut',
            data: {
                labels: classData.labels,
                datasets: [{
                    data: classData.values,
                    backgroundColor: classData.colors,
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '68%',
                plugins: { legend: { display: false } }
            }
        });

        const classLegend = document.getElementById('classLegend');
        classLegend.innerHTML = classData.labels.map((label, i) => `
            <div class="legend-item">
                <div class="legend-left">
                    <span class="legend-dot" style="background:${classData.colors[i]}"></span>
                    <span>${label}</span>
                </div>
                <span class="legend-val">${classData.values[i]}%</span>
            </div>
        `).join('');

        new Chart(document.getElementById('revenueChart'), {
            type: 'bar',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                datasets: [{
                    label: 'Revenue',
                    data: [82000, 91000, 97000, 108000, 116000, 124000, 131000, 128000, 139000, 146000, 157000, 169000],
                    backgroundColor: 'rgba(240,180,41,0.75)',
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { ticks: { color: 'rgba(255,255,255,0.55)' }, grid: { display: false } },
                    y: { ticks: { color: 'rgba(255,255,255,0.55)' }, grid: { color: 'rgba(255,255,255,0.05)' } }
                }
            }
        });

        new Chart(document.getElementById('routeChart'), {
            type: 'bar',
            data: {
                labels: ['HAN-SGN', 'SGN-DAD', 'HAN-PQC', 'DAD-CXR', 'SGN-HUI'],
                datasets: [{
                    label: 'Passengers',
                    data: [9800, 8600, 7100, 5400, 4900],
                    backgroundColor: ['#17aab8', '#2cc6d3', '#48d4de', '#70e0e7', '#9beaf0'],
                    borderRadius: 8
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { ticks: { color: 'rgba(255,255,255,0.55)' }, grid: { color: 'rgba(255,255,255,0.05)' } },
                    y: { ticks: { color: 'rgba(255,255,255,0.7)' }, grid: { display: false } }
                }
            }
        });
    </script>
}
