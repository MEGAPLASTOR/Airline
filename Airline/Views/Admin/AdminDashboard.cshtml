@using System.Text.Json
@model Airline.Models.AdminDashboardViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";

    var dashboard = Model ?? new Airline.Models.AdminDashboardViewModel();
    var bookingLabelsJson = JsonSerializer.Serialize(dashboard.BookingChartLabels);
    var bookingValuesJson = JsonSerializer.Serialize(dashboard.BookingChartValues);
    var revenueLabelsJson = JsonSerializer.Serialize(dashboard.RevenueChartLabels);
    var revenueValuesJson = JsonSerializer.Serialize(dashboard.RevenueChartValues);
    var classLabelsJson = JsonSerializer.Serialize(dashboard.TicketClasses.Select(x => x.Label));
    var classValuesJson = JsonSerializer.Serialize(dashboard.TicketClasses.Select(x => x.Count));
    var classPercentagesJson = JsonSerializer.Serialize(dashboard.TicketClasses.Select(x => x.Percentage));
    var routeLabelsJson = JsonSerializer.Serialize(dashboard.TopRoutes.Select(x => x.Label));
    var routeValuesJson = JsonSerializer.Serialize(dashboard.TopRoutes.Select(x => x.PassengerCount));
    var spark1Json = JsonSerializer.Serialize(dashboard.TotalUsers.Sparkline);
    var spark2Json = JsonSerializer.Serialize(dashboard.RevenueThisMonth.Sparkline);
    var spark3Json = JsonSerializer.Serialize(dashboard.ActiveBookings.Sparkline);
    var spark4Json = JsonSerializer.Serialize(dashboard.FlightsToday.Sparkline);
}

@section Styles {
    <style>
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.15rem;
            margin-bottom: 1.5rem;
        }

        .kpi-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-lg);
            padding: 1.2rem 1.35rem 1rem;
            position: relative;
            overflow: hidden;
            transition: border-color var(--tr), transform var(--tr);
            cursor: default;
        }

            .kpi-card:hover {
                border-color: rgba(23,170,184,0.3);
                transform: translateY(-2px);
            }

            .kpi-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: var(--kpi-accent, var(--ocean-aqua));
                border-radius: var(--radius-lg) var(--radius-lg) 0 0;
            }

        .kpi-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 0.75rem;
        }

        .kpi-icon-wrap {
            width: 40px;
            height: 40px;
            border-radius: var(--radius-md);
            background: rgba(255,255,255,0.06);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            color: var(--kpi-accent, var(--ocean-aqua));
        }

        .kpi-trend {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            font-size: 0.72rem;
            font-weight: 600;
            padding: 0.18rem 0.5rem;
            border-radius: 20px;
        }

            .kpi-trend.up {
                background: rgba(93,232,168,0.12);
                color: var(--accent-green);
            }

            .kpi-trend.down {
                background: rgba(255,107,107,0.12);
                color: var(--accent-coral);
            }

            .kpi-trend.flat {
                background: rgba(255,255,255,0.08);
                color: rgba(255,255,255,0.72);
            }

        .kpi-value {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 700;
            color: #fff;
            line-height: 1;
            margin-bottom: 0.25rem;
        }

        .kpi-label {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.42);
        }

        .kpi-sparkline {
            margin-top: 0.75rem;
            height: 36px;
        }

            .kpi-sparkline canvas {
                width: 100% !important;
                height: 36px !important;
            }

        .charts-row,
        .charts-row-3,
        .bottom-row {
            display: grid;
            gap: 1.15rem;
            margin-bottom: 1.15rem;
        }

        .charts-row {
            grid-template-columns: 1.6fr 1fr;
        }

        .charts-row-3 {
            grid-template-columns: 1fr 1fr 1fr;
        }

        .bottom-row {
            grid-template-columns: 1.45fr 0.9fr;
        }

        .chart-card,
        .table-card,
        .health-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            backdrop-filter: blur(12px);
        }

        .chart-card,
        .health-card {
            padding: 1.15rem 1.2rem;
        }

        .table-card {
            padding: 1rem 1rem 0.4rem;
        }

        .chart-wrap {
            position: relative;
            height: 300px;
        }

        .chart-wrap-sm {
            position: relative;
            height: 240px;
        }

        .chart-empty {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255,255,255,0.45);
            font-size: 0.84rem;
            text-align: center;
            padding: 1rem;
        }

        .card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .card-title {
            font-size: 0.95rem;
            font-weight: 700;
            color: #fff;
        }

        .card-subtitle {
            font-size: 0.76rem;
            color: rgba(255,255,255,0.42);
            margin-top: 0.2rem;
        }

        .card-tag {
            padding: 0.32rem 0.6rem;
            border-radius: 999px;
            background: rgba(23,170,184,0.12);
            border: 1px solid rgba(23,170,184,0.2);
            color: var(--ocean-aqua);
            font-size: 0.72rem;
            font-weight: 600;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

            .data-table th {
                text-align: left;
                font-size: 0.74rem;
                color: rgba(255,255,255,0.42);
                font-weight: 600;
                padding: 0.9rem 0.85rem;
                border-bottom: 1px solid rgba(255,255,255,0.07);
            }

            .data-table td {
                padding: 0.95rem 0.85rem;
                border-bottom: 1px solid rgba(255,255,255,0.05);
                font-size: 0.84rem;
                color: rgba(255,255,255,0.8);
            }

        .td-mono {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
            color: var(--ocean-foam);
        }

        .td-bold {
            font-weight: 600;
            color: #fff;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            padding: 0.34rem 0.62rem;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .pill-green {
            background: rgba(93,232,168,0.12);
            color: var(--accent-green);
        }

        .pill-gold {
            background: rgba(240,180,41,0.12);
            color: var(--accent-gold);
        }

        .pill-red {
            background: rgba(255,107,107,0.12);
            color: var(--accent-coral);
        }

        .empty-table {
            text-align: center;
            color: rgba(255,255,255,0.45);
            padding: 1.5rem 0;
        }

        .donut-legend {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.7rem;
            margin-top: 0.9rem;
        }

        .legend-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: var(--radius-md);
            padding: 0.55rem 0.7rem;
        }

        .legend-left {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            font-size: 0.76rem;
            color: rgba(255,255,255,0.68);
        }

        .legend-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

        .legend-val {
            font-size: 0.76rem;
            color: #fff;
            font-weight: 600;
        }

        .health-item {
            margin-bottom: 1rem;
        }

            .health-item:last-child {
                margin-bottom: 0;
            }

        .health-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 0.45rem;
        }

        .health-name {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.65);
        }

        .health-val {
            font-size: 0.8rem;
            font-weight: 600;
            color: #fff;
        }

        .health-bar {
            height: 6px;
            background: rgba(255,255,255,0.07);
            border-radius: 3px;
            overflow: hidden;
        }

        .health-fill {
            height: 100%;
            border-radius: 3px;
            background: linear-gradient(90deg, var(--ocean-aqua), var(--ocean-teal));
            transition: width 1s ease;
        }

            .health-fill.warn {
                background: linear-gradient(90deg, var(--accent-gold), #e0901a);
            }

            .health-fill.crit {
                background: linear-gradient(90deg, var(--accent-coral), #d94f4f);
            }

        .quick-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.6rem;
            margin-top: 1rem;
        }

        .qa-btn {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.6rem 0.75rem;
            border-radius: var(--radius-md);
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.07);
            color: rgba(255,255,255,0.6);
            font-size: 0.78rem;
            transition: background var(--tr), color var(--tr), border-color var(--tr);
        }

            .qa-btn i {
                color: var(--ocean-aqua);
                font-size: 0.8rem;
            }

            .qa-btn:hover {
                background: rgba(23,170,184,0.1);
                border-color: rgba(23,170,184,0.25);
                color: #fff;
            }

        @@media (max-width: 1280px) {
            .kpi-grid {
                grid-template-columns: repeat(2,1fr);
            }
        }

        @@media (max-width: 1024px) {
            .charts-row, .charts-row-3, .bottom-row {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 640px) {
            .kpi-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Admin Dashboard</div>
        <h1 class="page-title">Welcome back, <span>@dashboard.AdminFirstName</span></h1>
        <p class="page-subtitle" id="dashDate"></p>
    </div>
    <div class="page-actions">
        <button class="btn-ghost" type="button" onclick="window.location.reload()">
            <i class="fa-solid fa-arrows-rotate"></i> Refresh
        </button>
        <button class="btn-primary" type="button" onclick="window.print()">
            <i class="fa-solid fa-file-export"></i> Export Report
        </button>
    </div>
</div>

<div class="kpi-grid">
    @{
        var kpis = new[]
        {
            (Accent: "#17aab8", Icon: "fa-users", Data: dashboard.TotalUsers),
            (Accent: "#f0b429", Icon: "fa-sack-dollar", Data: dashboard.RevenueThisMonth),
            (Accent: "#5de8a8", Icon: "fa-ticket", Data: dashboard.ActiveBookings),
            (Accent: "#ff6b6b", Icon: "fa-plane-departure", Data: dashboard.FlightsToday)
        };
    }
    @for (var i = 0; i < kpis.Length; i++)
    {
        var kpi = kpis[i];
        var trendIcon = kpi.Data.TrendDirection == "down"
            ? "fa-arrow-trend-down"
            : kpi.Data.TrendDirection == "flat"
                ? "fa-minus"
                : "fa-arrow-trend-up";

        <div class="kpi-card" style="--kpi-accent:@kpi.Accent">
            <div class="kpi-top">
                <div class="kpi-icon-wrap"><i class="fa-solid @kpi.Icon"></i></div>
                <span class="kpi-trend @kpi.Data.TrendDirection">
                    <i class="fa-solid @trendIcon"></i> @kpi.Data.TrendText
                </span>
            </div>
            <div class="kpi-value">@kpi.Data.Value</div>
            <div class="kpi-label">@kpi.Data.Label</div>
            <div class="kpi-sparkline"><canvas id="spark@(i + 1)"></canvas></div>
        </div>
    }
</div>

<div class="charts-row">
    <div class="chart-card">
        <div class="card-header">
            <div>
                <div class="card-title">Booking Growth</div>
                <div class="card-subtitle">Monthly bookings for the current year</div>
            </div>
            <span class="card-tag">@dashboard.CurrentYear</span>
        </div>
        <div class="chart-wrap"><canvas id="bookingChart"></canvas></div>
    </div>
    <div class="chart-card">
        <div class="card-header">
            <div>
                <div class="card-title">Ticket Classes</div>
                <div class="card-subtitle">Distribution by sold ticket class</div>
            </div>
        </div>
        <div class="chart-wrap-sm"><canvas id="classChart"></canvas></div>
        <div class="donut-legend" id="classLegend"></div>
    </div>
</div>

<div class="charts-row">
    <div class="chart-card">
        <div class="card-header">
            <div>
                <div class="card-title">Revenue Overview</div>
                <div class="card-subtitle">Monthly revenue in VND</div>
            </div>
            <span class="card-tag">@dashboard.CurrentYear</span>
        </div>
        <div class="chart-wrap"><canvas id="revenueChart"></canvas></div>
    </div>
    <div class="chart-card">
        <div class="card-header">
            <div>
                <div class="card-title">Top Routes</div>
                <div class="card-subtitle">By passenger volume</div>
            </div>
        </div>
        <div class="chart-wrap"><canvas id="routeChart"></canvas></div>
    </div>
</div>

