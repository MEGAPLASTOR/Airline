@model Airline.Models.AdminDashboardViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <style>
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.15rem;
            margin-bottom: 1.5rem;
        }

        .kpi-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-lg);
            padding: 1.2rem 1.35rem 1rem;
        }

        .kpi-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 0.75rem;
        }

        .kpi-icon-wrap {
            width: 40px;
            height: 40px;
            border-radius: var(--radius-md);
            background: rgba(255,255,255,0.06);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }

        .kpi-value {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 700;
            color: #fff;
            line-height: 1;
            margin-bottom: 0.25rem;
        }

        .kpi-label {
            font-size: 0.78rem;
            color: rgba(255,255,255,0.42);
        }

        .charts-row, .bottom-row {
            display: grid;
            gap: 1.15rem;
            margin-bottom: 1.15rem;
        }

        .charts-row { grid-template-columns: 1fr 1fr; }
        .bottom-row { grid-template-columns: 1.4fr 1fr; }

        .chart-card, .table-card, .health-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            padding: 1.15rem 1.2rem;
        }

        .chart-wrap { position: relative; height: 320px; }

        .card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .card-title {
            font-size: 0.95rem;
            font-weight: 700;
            color: #fff;
        }

        .card-subtitle {
            font-size: 0.76rem;
            color: rgba(255,255,255,0.42);
            margin-top: 0.2rem;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th, .data-table td {
            text-align: left;
            padding: 0.9rem 0.85rem;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            font-size: 0.84rem;
        }

        .data-table th {
            color: rgba(255,255,255,0.42);
            font-weight: 600;
        }

        .td-bold { color: #fff; font-weight: 600; }

        .status-pill {
            display: inline-flex;
            align-items: center;
            padding: 0.34rem 0.62rem;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .pill-green { background: rgba(93,232,168,0.12); color: #5de8a8; }
        .pill-gold { background: rgba(240,180,41,0.12); color: #f0b429; }
        .pill-red { background: rgba(255,107,107,0.12); color: #ff6b6b; }
        .pill-gray { background: rgba(255,255,255,0.12); color: #ddd; }

        .health-item { margin-bottom: 1rem; }
        .health-top {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.45rem;
        }
        .health-name { font-size: 0.78rem; color: rgba(255,255,255,0.65); }
        .health-val { font-size: 0.8rem; font-weight: 600; color: #fff; }

        @@media (max-width: 1024px) {
            .kpi-grid, .charts-row, .bottom-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Admin Dashboard</div>
        <h1 class="page-title">Welcome back, <span>@Model.FirstName</span></h1>
        <p class="page-subtitle" id="dashDate"></p>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-users"></i></div>
        </div>
        <div class="kpi-value">@Model.TotalUsers</div>
        <div class="kpi-label">Total Users</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-plane"></i></div>
        </div>
        <div class="kpi-value">@Model.TotalFlights</div>
        <div class="kpi-label">Total Flights</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-ticket"></i></div>
        </div>
        <div class="kpi-value">@Model.ActiveBookings</div>
        <div class="kpi-label">Active Bookings</div>
    </div>

    <div class="kpi-card">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-sack-dollar"></i></div>
        </div>
        <div class="kpi-value">@Model.RevenueThisMonth.ToString("N0")</div>
        <div class="kpi-label">Revenue This Month</div>
    </div>
</div>

<div class="charts-row">
    <div class="chart-card">
        <div class="card-header">
            <div>
                <div class="card-title">Ticket Class Distribution</div>
                <div class="card-subtitle">Real data from Tickets + TicketClasses</div>
            </div>
        </div>
        <div class="chart-wrap">
            <canvas id="classChart"></canvas>
        </div>
    </div>

    <div class="chart-card">
        <div class="card-header">
            <div>
                <div class="card-title">Top Routes</div>
                <div class="card-subtitle">Real data by sold tickets</div>
            </div>
        </div>
        <div class="chart-wrap">
            <canvas id="routeChart"></canvas>
        </div>
    </div>
</div>

<div class="bottom-row">
    <div class="table-card">
        <div class="card-header">
            <div>
                <div class="card-title">Recent Ticket Activity</div>
                <div class="card-subtitle">Latest tickets from database</div>
            </div>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Ticket ID</th>
                    <th>Passenger</th>
                    <th>Route</th>
                    <th>Class</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.RecentTickets.Any())
                {
                    @foreach (var item in Model.RecentTickets)
                    {
                        var statusClass = item.Status?.ToUpper() switch
                        {
                                        "CONFIRMED" => "pill-green",
                                        "BOOKED" => "pill-green",
                                        "PENDING" => "pill-gold",
                                        "CANCELLED" => "pill-red",
                            _ => "pill-gray"
                        };

                        <tr>
                            <td>#SKY-@item.TicketId</td>
                            <td class="td-bold">@item.PassengerName</td>
                            <td>@item.RouteName</td>
                            <td>@item.ClassName</td>
                            <td><span class="status-pill @statusClass">@item.Status</span></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">No ticket data found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="health-card">
        <div class="card-header">
            <div>
                <div class="card-title">Today Summary</div>
                <div class="card-subtitle">Live counters from schedules</div>
            </div>
        </div>

        <div class="health-item">
            <div class="health-top">
                <span class="health-name">Flights Today</span>
                <span class="health-val">@Model.ScheduledFlightsToday</span>
            </div>
        </div>

        <div class="health-item">
            <div class="health-top">
                <span class="health-name">Available Seats Today</span>
                <span class="health-val">@Model.AvailableSeatsToday</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.getElementById("dashDate").textContent = new Date().toLocaleString("vi-VN", {
            weekday: "long",
            year: "numeric",
            month: "long",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit"
        });

        const classLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.TicketClassDistribution.Select(x => x.ClassName)
            ));
    const classValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.TicketClassDistribution.Select(x => x.Count)
        ));

    new Chart(document.getElementById('classChart'), {
        type: 'doughnut',
        data: {
            labels: classLabels,
            datasets: [{
                data: classValues,
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });

        const routeLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.TopRoutes.Select(x => x.RouteName)
        ));
    const routeValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.TopRoutes.Select(x => x.PassengerCount)
        ));

    new Chart(document.getElementById('routeChart'), {
        type: 'bar',
        data: {
            labels: routeLabels,
            datasets: [{
                label: 'Passengers',
                data: routeValues,
                borderRadius: 8
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false
        }
    });
</script>
}