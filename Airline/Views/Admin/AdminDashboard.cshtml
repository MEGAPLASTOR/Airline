    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.getElementById("dashDate").textContent = new Date().toLocaleString("en-US", {
            weekday: "long",
            year: "numeric",
            month: "long",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit"
        });

        const bookingLabels = @Html.Raw(bookingLabelsJson);
        const bookingValues = @Html.Raw(bookingValuesJson);
        const revenueLabels = @Html.Raw(revenueLabelsJson);
        const revenueValues = @Html.Raw(revenueValuesJson);
        const classLabels = @Html.Raw(classLabelsJson);
        const classValues = @Html.Raw(classValuesJson);
        const classPercentages = @Html.Raw(classPercentagesJson);
        const routeLabels = @Html.Raw(routeLabelsJson);
        const routeValues = @Html.Raw(routeValuesJson);
        const donutPalette = ['#17aab8', '#f0b429', '#5de8a8', '#ff6b6b', '#2cc6d3', '#9beaf0'];
        const routePalette = ['#17aab8', '#2cc6d3', '#48d4de', '#70e0e7', '#9beaf0'];

        function formatCompactNumber(value) {
            const abs = Math.abs(value);
            if (abs >= 1_000_000_000) return (value / 1_000_000_000).toFixed(1).replace(/\.0$/, '') + 'B';
            if (abs >= 1_000_000) return (value / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M';
            if (abs >= 1_000) return (value / 1_000).toFixed(1).replace(/\.0$/, '') + 'K';
            return new Intl.NumberFormat('en-US').format(value);
        }

        function formatCurrency(value) {
            return `${formatCompactNumber(value)} VND`;
        }

        function renderEmptyState(canvasId, message) {
            const canvas = document.getElementById(canvasId);
            if (!canvas || !canvas.parentElement) return;
            canvas.parentElement.innerHTML = `<div class="chart-empty">${message}</div>`;
        }

        function sparkline(id, data, color) {
            const canvas = document.getElementById(id);
            if (!canvas || !Array.isArray(data) || data.length === 0) return;

            new Chart(canvas, {
                type: 'line',
                data: {
                    labels: data.map((_, index) => index + 1),
                    datasets: [{
                        data: data,
                        borderColor: color,
                        borderWidth: 2,
                        fill: false,
                        tension: 0.45,
                        pointRadius: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { enabled: false } },
                    scales: { x: { display: false }, y: { display: false } }
                }
            });
        }

        sparkline('spark1', @Html.Raw(spark1Json), '#17aab8');
        sparkline('spark2', @Html.Raw(spark2Json), '#f0b429');
        sparkline('spark3', @Html.Raw(spark3Json), '#5de8a8');
        sparkline('spark4', @Html.Raw(spark4Json), '#ff6b6b');

        if (bookingLabels.length && bookingValues.length) {
            new Chart(document.getElementById('bookingChart'), {
                type: 'line',
                data: {
                    labels: bookingLabels,
                    datasets: [{
                        label: 'Bookings',
                        data: bookingValues,
                        borderColor: '#17aab8',
                        backgroundColor: 'rgba(23,170,184,0.15)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: 3,
                        pointBackgroundColor: '#17aab8'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { ticks: { color: 'rgba(255,255,255,0.55)' }, grid: { color: 'rgba(255,255,255,0.05)' } },
                        y: { ticks: { color: 'rgba(255,255,255,0.55)' }, grid: { color: 'rgba(255,255,255,0.05)' } }
                    }
                }
            });
        } else {
            renderEmptyState('bookingChart', 'No booking data available for the selected year.');
        }

        if (classLabels.length && classValues.some(value => value > 0)) {
            new Chart(document.getElementById('classChart'), {
                type: 'doughnut',
                data: {
                    labels: classLabels,
                    datasets: [{
                        data: classValues,
                        backgroundColor: classLabels.map((_, index) => donutPalette[index % donutPalette.length]),
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '68%',
                    plugins: { legend: { display: false } }
                }
            });

            const classLegend = document.getElementById('classLegend');
            classLegend.innerHTML = classLabels.map((label, index) => `
                <div class="legend-item">
                    <div class="legend-left">
                        <span class="legend-dot" style="background:${donutPalette[index % donutPalette.length]}"></span>
                        <span>${label}</span>
                    </div>
                    <span class="legend-val">${classPercentages[index]}%</span>
                </div>
            `).join('');
        } else {
            renderEmptyState('classChart', 'No ticket class data available.');
            const classLegend = document.getElementById('classLegend');
            if (classLegend) {
                classLegend.innerHTML = '<div class="chart-empty">No ticket class distribution found.</div>';
            }
        }

        if (revenueLabels.length && revenueValues.length) {
            new Chart(document.getElementById('revenueChart'), {
                type: 'bar',
                data: {
                    labels: revenueLabels,
                    datasets: [{
                        label: 'Revenue',
                        data: revenueValues,
                        backgroundColor: 'rgba(240,180,41,0.75)',
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return formatCurrency(context.raw ?? 0);
                                }
                            }
                        }
                    },
                    scales: {
                        x: { ticks: { color: 'rgba(255,255,255,0.55)' }, grid: { display: false } },
                        y: {
                            ticks: {
                                color: 'rgba(255,255,255,0.55)',
                                callback: function (value) {
                                    return formatCurrency(value);
                                }
                            },
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        }
                    }
                }
            });
        } else {
            renderEmptyState('revenueChart', 'No revenue data available for the selected year.');
        }

        if (routeLabels.length && routeValues.length) {
            new Chart(document.getElementById('routeChart'), {
                type: 'bar',
                data: {
                    labels: routeLabels,
                    datasets: [{
                        label: 'Passengers',
                        data: routeValues,
                        backgroundColor: routeLabels.map((_, index) => routePalette[index % routePalette.length]),
                        borderRadius: 8
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: {
                            ticks: { color: 'rgba(255,255,255,0.55)' },
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        },
                        y: {
                            ticks: { color: 'rgba(255,255,255,0.7)' },
                            grid: { display: false }
                        }
                    }
                }
            });
        } else {
            renderEmptyState('routeChart', 'No route activity data available.');
        }
    </script>
}
