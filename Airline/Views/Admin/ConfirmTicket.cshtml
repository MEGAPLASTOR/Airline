@model IEnumerable<Airline.Models.Booking>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Confirm Tickets";

    var bookings = Model?.ToList() ?? new List<Airline.Models.Booking>();
    var totalBookings = bookings.Count;
    var totalPassengers = bookings.Sum(x => x.Passengers.Count);
    var totalRevenue = bookings.Sum(x => ViewData[$"Total_{x.BookingId}"] as decimal? ?? 0m);
    var upcomingFlights = bookings.Count(x => x.Schedule?.DepartureTime >= DateTime.Now);
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-unified.css" asp-append-version="true" />
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Ticketing Operations</div>
        <h1 class="page-title">Confirm <span>Guest Tickets</span></h1>
        <p class="page-subtitle">Review pending guest bookings and finalize manual payment confirmation.</p>
    </div>

    <div class="page-actions">
        <button type="button" class="btn-ghost js-refresh-page">
            <i class="fa-solid fa-arrows-rotate"></i> Refresh
        </button>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-box alert-success">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-box alert-error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}

<div class="kpi-grid">
    <div class="kpi-card" style="--kpi-accent:#17aab8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-ticket"></i></div>
        </div>
        <div class="kpi-value">@totalBookings</div>
        <div class="kpi-label">Pending Bookings</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#f0b429">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-users"></i></div>
        </div>
        <div class="kpi-value">@totalPassengers</div>
        <div class="kpi-label">Passengers Waiting</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#5de8a8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-money-check-dollar"></i></div>
        </div>
        <div class="kpi-value">@totalRevenue.ToString("N0")</div>
        <div class="kpi-label">Pending Revenue (VND)</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#ff6b6b">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-plane-departure"></i></div>
        </div>
        <div class="kpi-value">@upcomingFlights</div>
        <div class="kpi-label">Upcoming Departures</div>
    </div>
</div>

<div class="table-card">
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="bookingSearch" placeholder="Search booking, customer, flight..." />
            </div>
        </div>

        <div class="toolbar-right">
            <span class="result-text">
                Total: <strong id="bookingCount">@totalBookings</strong> booking(s)
            </span>
        </div>
    </div>

    <div class="table-wrap">
        <table class="data-table" id="confirmTicketTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Customer</th>
                    <th>Flight</th>
                    <th>Passengers</th>
                    <th>Total Price</th>
                    <th>Status</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (bookings.Any())
                {
                    foreach (var booking in bookings)
                    {
                        var totalAmount = ViewData[$"Total_{booking.BookingId}"] as decimal? ?? 0m;
                        var customerName = $"{booking.User?.FirstName} {booking.User?.LastName}".Trim();
                        var flightNumber = booking.Schedule?.Flight?.FlightNumber ?? "-";
                        var dep = booking.Schedule?.Flight?.Route?.DepartureCityNavigation?.CityName ?? "-";
                        var arr = booking.Schedule?.Flight?.Route?.ArrivalCityNavigation?.CityName ?? "-";
                        var passengerSummary = string.Join(" ", booking.Passengers.Select(x => x.FullName));

                        <tr class="booking-row"
                            data-search="@($"BK-{booking.BookingId} {customerName} {booking.User?.Username} {flightNumber} {dep} {arr} {passengerSummary}")">
                            <td class="td-mono">#BK-@booking.BookingId</td>
                            <td>
                                <div class="detail-stack">
                                    <span class="detail-primary">@customerName</span>
                                    <span class="detail-secondary">@@@booking.User?.Username</span>
                                </div>
                            </td>
                            <td>
                                <div class="detail-stack">
                                    <span class="detail-primary">@flightNumber</span>
                                    <span class="detail-secondary">@dep &rarr; @arr</span>
                                    <span class="detail-secondary">@(booking.Schedule?.DepartureTime.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                                </div>
                            </td>
                            <td>
                                <div class="passenger-list">
                                    @foreach (var passenger in booking.Passengers)
                                    {
                                        <span class="passenger-item">@passenger.FullName (@passenger.PassengerType)</span>
                                    }
                                </div>
                            </td>
                            <td class="amount-text">@totalAmount.ToString("N0") VND</td>
                            <td>
                                <span class="status-pill pill-gold">
                                    <i class="fa-solid fa-clock"></i> @booking.Status
                                </span>
                            </td>
                            <td class="text-center">
                                <button type="button"
                                        class="btn-success js-open-confirm-modal"
                                        data-booking-id="@booking.BookingId"
                                        data-customer-name="@customerName"
                                        data-flight="@flightNumber"
                                        data-total="@(totalAmount.ToString("N0") + " VND")">
                                    <i class="fa-solid fa-check"></i> Confirm
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="empty-state">
                            <i class="fa-solid fa-ticket-simple"></i>
                            No pending bookings found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="confirmModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3>Confirm Payment</h3>
                <p>Manual payment confirmation will mark the booking as paid.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form asp-controller="AdminBooking" asp-action="ProcessConfirm" method="post" class="form-shell">
            @Html.AntiForgeryToken()
            <input type="hidden" name="bookingId" id="confirmBookingId" />

            <div class="delete-content" style="padding:0 0 0.2rem;">
                <p>Confirm payment for this booking?</p>
                <div class="delete-target" id="confirmTargetText"></div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="submit" class="btn-success">
                    <i class="fa-solid fa-check"></i> Confirm Payment
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-confirm-ticket.js" asp-append-version="true"></script>
}

