@model dynamic
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Flight Seats";
    
    // Model can be IEnumerable<FlightSchedule> or a single FlightSchedule
    var isDetail = Model is Airline.Models.FlightSchedule;
    var schedules = !isDetail ? Model as IEnumerable<Airline.Models.FlightSchedule> : null;
    var schedule = isDetail ? Model as Airline.Models.FlightSchedule : null;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-flightseats.css" />
    <style>
        .seat-map-container {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: var(--radius-lg);
            padding: 2rem;
            margin-top: 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        .cabin-block {
            width: 100%;
            margin-bottom: 2rem;
            border-bottom: 1px dashed rgba(255,255,255,0.1);
            padding-bottom: 1.5rem;
        }

        .cabin-title {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: rgba(255,255,255,0.3);
            margin-bottom: 1rem;
            display: block;
            text-align: center;
        }

        .seat-grid {
            display: flex;
            flex-direction: column;
            gap: 8px; /* Compact row gap */
            align-items: center;
        }
        
        .seat-row {
            display: flex;
            gap: 12px;
            justify-content: center;
        }

        .seat {
            width: 48px;
            height: 48px;
            border-radius: 8px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .seat-num { font-size: 0.75rem; font-weight: 700; color: #fff; }
        .seat-type-icon { font-size: 0.6rem; opacity: 0.5; }

        .seat:hover { transform: scale(1.1); background: rgba(255,255,255,0.15); }

        .seat.BOOKED { background: var(--accent-coral); border-color: #ff4d4d; }
        .seat.BLOCKED { background: #555; border-color: #777; color: #ccc; }
        .seat.AVAILABLE { background: var(--accent-green); border-color: #4cd995; }
        .seat.AVAILABLE .seat-num { color: #0c3a25; }

        .map-legend {
            display: flex; gap: 1.5rem; margin-bottom: 2rem;
            padding: 1rem; background: rgba(255,255,255,0.03); border-radius: 12px;
        }
        .legend-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; }
        .legend-color { width: 16px; height: 16px; border-radius: 4px; }
        .interior-scroll-area {
            max-height: 600px;
            overflow-y: auto;
            width: 100%;
            padding-right: 15px;
            scrollbar-width: thin;
        }
    </style>
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Operations</div>
        <h1 class="page-title">Manage <span>Flight Seats</span></h1>
        @if (isDetail)
        {
            <p class="page-subtitle">Flight: @schedule.Flight.FlightNumber | Route: @schedule.Flight.Route?.DepartureCityNavigation?.CityName to @schedule.Flight.Route?.ArrivalCityNavigation?.CityName</p>
        }
        else
        {
            <p class="page-subtitle">Select a flight schedule to manage seat availability</p>
        }
    </div>
    @if (isDetail)
    {
        <a asp-action="FlightSeats" class="btn-ghost">
            <i class="fa-solid fa-arrow-left"></i> Back to List
        </a>
    }
</div>

@if (!isDetail)
{
    <div class="schedule-table-card">
        <table class="schedule-table">
            <thead>
                <tr>
                    <th>Flight</th>
                    <th>Route</th>
                    <th>Departure</th>
                    <th>Capacity</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in schedules)
                {
                    <tr>
                        <td><strong>@s.Flight?.FlightNumber</strong></td>
                        <td>@s.Flight?.Route?.DepartureCityNavigation?.CityName &rarr; @s.Flight?.Route?.ArrivalCityNavigation?.CityName</td>
                        <td>@s.DepartureTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(s.AvailableSeats ?? 0) / @(s.TotalSeats ?? 0)</td>
                        <td>
                            <a asp-action="FlightSeats" asp-route-id="@s.ScheduleId" class="act-btn act-edit">
                                <i class="fa-solid fa-chair"></i> Manage Seats
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="seat-map-container">
        <div class="map-legend">
            <div class="legend-item">
                <div class="legend-color" style="background:var(--accent-green)"></div>
                <span>Available</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background:var(--accent-coral)"></div>
                <span>Booked</span>
            </div>
            <div class="legend-item">
                <div class="legend-color" style="background:#555"></div>
                <span>Blocked (Admin)</span>
            </div>
        </div>

        <div class="interior-scroll-area">
            <div class="airplane-interior" style="width: 100%; max-width: 600px; margin: 0 auto;">
                @foreach (var classGroup in schedule.Seats.GroupBy(s => s.ClassId).OrderByDescending(g => g.Key))
                {
                    <div class="cabin-block">
                        <span class="cabin-title">@classGroup.First().Class.ClassName Cabin</span>
                        <div class="seat-grid">
                            @foreach (var rowGroup in classGroup.GroupBy(s => s.SeatNumber.Substring(1)).OrderBy(r => r.Key))
                            {
                                <div class="seat-row">
                                    @foreach (var seat in rowGroup.OrderBy(s => s.SeatNumber[0]))
                                    {
                                        <div class="seat @seat.SeatStatus" 
                                             onclick="handleSeatClick(@schedule.ScheduleId, '@seat.SeatNumber', '@seat.SeatStatus')"
                                             title="Seat @seat.SeatNumber">
                                            <span class="seat-num">@seat.SeatNumber</span>
                                            <i class="fa-solid fa-couch seat-type-icon"></i>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Seat Details Modal -->
<div class="modal-overlay" id="seatModal">
    <div class="modal-box" style="width: 400px">
        <div class="modal-header">
            <span class="modal-title">Seat <span id="modalSeatNum"></span> Details</span>
            <button class="modal-close" onclick="closeModal('seatModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body" id="modalSeatBody">
            <!-- Content loaded via JS -->
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('seatModal')">Close</button>
            <button class="btn-primary" id="btnToggleStatus" onclick="toggleStatus()">Toggle Block</button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        let currentScheduleId = 0;
        let currentSeatNum = '';

        async function handleSeatClick(scheduleId, seatNum, status) {
            currentScheduleId = scheduleId;
            currentSeatNum = seatNum;

            document.getElementById('modalSeatNum').textContent = seatNum;
            const body = document.getElementById('modalSeatBody');
            const btnToggle = document.getElementById('btnToggleStatus');

            body.innerHTML = '<p style="text-align:center">Loading seat details...</p>';
            document.getElementById('seatModal').classList.add('active');

            const res = await fetch(`/Admin/GetSeatDetails?scheduleId=${scheduleId}&seatNumber=${seatNum}`);
            if (res.ok) {
                const data = await res.json();
                
                if (data.status === 'BOOKED') {
                    btnToggle.style.display = 'none';
                    body.innerHTML = `
                        <div style="display:grid; gap:10px">
                            <div style="display:flex; justify-content:space-between"><span>Class:</span> <strong>${data.className}</strong></div>
                            <div style="display:flex; justify-content:space-between"><span>Passenger:</span> <strong>${data.passengerName}</strong></div>
                            <div style="display:flex; justify-content:space-between"><span>Booked By:</span> <span>${data.username}</span></div>
                            <div style="display:flex; justify-content:space-between"><span>Booking Date:</span> <span>${data.bookingDate}</span></div>
                            <div style="display:flex; justify-content:space-between"><span>Status:</span> <span class="status-pill pill-completed">${data.status}</span></div>
                        </div>
                    `;
                } else {
                    btnToggle.style.display = 'block';
                    btnToggle.textContent = data.status === 'BLOCKED' ? 'Unblock Seat' : 'Block Seat';
                    body.innerHTML = `
                        <div style="display:grid; gap:10px">
                             <div style="display:flex; justify-content:space-between"><span>Class:</span> <strong>${data.className}</strong></div>
                             <div style="display:flex; justify-content:space-between"><span>Status:</span> <span class="status-pill">${data.status}</span></div>
                        </div>
                        <p style="margin-top:1rem; font-size:0.85rem; color:rgba(255,255,255,0.5)">You can block this seat to prevent customers from booking it.</p>
                    `;
                }
            } else {
                body.innerHTML = '<p style="color:var(--accent-coral)">Failed to load details.</p>';
            }
        }

        async function toggleStatus() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const fd = new FormData();
            fd.append('scheduleId', currentScheduleId);
            fd.append('seatNumber', currentSeatNum);
            fd.append('__RequestVerificationToken', token);

            const res = await fetch('/Admin/ToggleSeatStatus', {
                method: 'POST',
                body: fd
            });
            const data = await res.json();
            if (data.success) {
                location.reload();
            } else {
                alert(data.message || 'Failed to update status');
            }
        }
    </script>
}
