@model Airline.Controllers.TicketPriceController.TicketPricePageVm
@{
    ViewData["Title"] = "Ticket Prices";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var items = Model.Items?.ToList() ?? new List<Airline.Controllers.TicketPriceController.TicketPriceRowVm>();
    var schedules = Model.Schedules?.ToList() ?? new List<Airline.Controllers.TicketPriceController.ScheduleOptionVm>();
    var classes = Model.Classes?.ToList() ?? new List<Airline.Controllers.TicketPriceController.ClassOptionVm>();
    var totalPrices = items.Count;
    var pricedSchedules = items.Select(x => x.ScheduleId).Distinct().Count();
    var pricedClasses = items.Select(x => x.ClassId).Distinct().Count();
    var averagePrice = items.Any() ? items.Average(x => x.Price) : 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-unified.css" asp-append-version="true" />
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Ticketing</div>
        <h1 class="page-title">Manage <span>Ticket Prices</span></h1>
        <p class="page-subtitle">Set and maintain ticket prices by flight schedule and class.</p>
    </div>

    <div class="page-actions">
        <button type="button" class="btn-ghost js-refresh-page">
            <i class="fa-solid fa-arrows-rotate"></i> Refresh
        </button>
        <button type="button" class="btn-primary" id="openModalBtn">
            <i class="fa-solid fa-tags"></i> Add Price
        </button>
    </div>
</div>

@if (TempData["tp_ok"] != null)
{
    <div class="alert-box alert-success">
        <i class="fa-solid fa-circle-check"></i>
        <span>@TempData["tp_ok"]</span>
    </div>
}

@if (TempData["tp_err"] != null)
{
    <div class="alert-box alert-error">
        <i class="fa-solid fa-circle-exclamation"></i>
        <span>@TempData["tp_err"]</span>
    </div>
}

<div class="kpi-grid">
    <div class="kpi-card" style="--kpi-accent:#17aab8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-tags"></i></div>
        </div>
        <div class="kpi-value">@totalPrices</div>
        <div class="kpi-label">Price Records</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#f0b429">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-calendar-days"></i></div>
        </div>
        <div class="kpi-value">@pricedSchedules</div>
        <div class="kpi-label">Schedules Priced</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#5de8a8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-layer-group"></i></div>
        </div>
        <div class="kpi-value">@pricedClasses</div>
        <div class="kpi-label">Classes Covered</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#ff6b6b">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-sack-dollar"></i></div>
        </div>
        <div class="kpi-value">@averagePrice.ToString("N0")</div>
        <div class="kpi-label">Average Price (VND)</div>
    </div>
</div>

<div class="table-card">
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="priceSearch" placeholder="Search flight, date or class..." />
            </div>

            <select id="priceClassFilter" class="toolbar-select">
                <option value="">All Classes</option>
                @foreach (var item in classes)
                {
                    <option value="@item.ClassId">@item.ClassName</option>
                }
            </select>
        </div>

        <div class="toolbar-right">
            <span class="result-text">
                Total: <strong id="priceCount">@totalPrices</strong> price record(s)
            </span>
        </div>
    </div>

    <div class="table-wrap">
        <table class="data-table" id="ticketPriceTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Flight & Schedule</th>
                    <th>Class</th>
                    <th>Price</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (items.Any())
                {
                    foreach (var item in items)
                    {
                        <tr class="price-row"
                            data-search="@($"{item.FlightNumber} {item.ClassName} {item.DepartureTime:dd/MM/yyyy HH:mm}")"
                            data-class-id="@item.ClassId">
                            <td class="td-mono">#@item.PriceId</td>
                            <td>
                                <div class="detail-stack">
                                    <span class="detail-primary">@item.FlightNumber</span>
                                    <span class="detail-secondary">
                                        @(item.DepartureTime?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                                        @if (item.ArrivalTime != null)
                                        {
                                            <text> - @item.ArrivalTime.Value.ToString("dd/MM/yyyy HH:mm")</text>
                                        }
                                    </span>
                                </div>
                            </td>
                            <td>
                                <span class="status-pill pill-blue">@item.ClassName</span>
                            </td>
                            <td class="amount-text">@item.Price.ToString("N0") VNĐ</td>
                            <td class="text-center">
                                <div class="row-actions">
                                    <button type="button"
                                            class="icon-btn edit-btn editBtn"
                                            data-id="@item.PriceId"
                                            data-schedule="@item.ScheduleId"
                                            data-class="@item.ClassId"
                                            data-price="@item.Price"
                                            title="Edit price">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>

                                    <button type="button"
                                            class="icon-btn delete-btn js-open-delete-modal"
                                            data-id="@item.PriceId"
                                            data-flight="@item.FlightNumber"
                                            data-class-name="@item.ClassName"
                                            title="Delete price">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="empty-state">
                            <i class="fa-solid fa-tags"></i>
                            No ticket prices found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="modal">
    <div class="modal-card modal-md">
        <div class="modal-header">
            <div>
                <h3 id="priceModalTitle">Set Ticket Price</h3>
                <p>Fill in the schedule, class and price details below.</p>
            </div>
            <button id="closeModal" type="button" class="modal-close">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form method="post" asp-action="Upsert" class="form-shell">
            @Html.AntiForgeryToken()
            <input type="hidden" name="PriceId" id="PriceId" />

            <div class="form-grid">
                <div class="form-group">
                    <label for="ScheduleId">Schedule</label>
                    <select name="ScheduleId" id="ScheduleId">
                        @foreach (var schedule in schedules)
                        {
                            <option value="@schedule.ScheduleId">@schedule.Label</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label for="ClassId">Class</label>
                    <select name="ClassId" id="ClassId">
                        @foreach (var item in classes)
                        {
                            <option value="@item.ClassId">@item.ClassName</option>
                        }
                    </select>
                </div>

                <div class="form-group form-group-full">
                    <label for="Price">Price</label>
                    <input type="number" name="Price" id="Price" min="0" step="1000" placeholder="Enter ticket price..." />
                    <div class="helper-text" id="preview">0 VNĐ</div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost" id="cancelModalBtn">Cancel</button>
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i> Save Price
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3>Delete Ticket Price</h3>
                <p>This action cannot be undone.</p>
            </div>
            <button type="button" class="modal-close js-close-delete-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <form method="post" asp-action="Delete" class="form-shell">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deletePriceId" />

            <div class="delete-content" style="padding:0 0 0.2rem;">
                <p>Are you sure you want to delete this ticket price?</p>
                <div class="delete-target" id="deleteTargetText"></div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost js-close-delete-modal">Cancel</button>
                <button type="submit" class="btn-danger">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-ticketprice.js" asp-append-version="true"></script>
}
