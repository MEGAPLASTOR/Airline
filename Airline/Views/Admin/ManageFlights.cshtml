@model IEnumerable<Airline.Models.Flight>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Flights";
    var routes = ViewBag.Routes as IEnumerable<Airline.Models.Route>;
    var search = ViewBag.Search as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-flights.css" />
}

<!-- Page Header -->
<div class="schedule-header">
    <div class="page-title-block">
        <div class="page-greeting">Master Data</div>
        <h1 class="page-title">Manage Flights</h1>
        <p class="page-subtitle">Configure flight numbers and assign routes</p>
    </div>
    <button class="btn-create" onclick="openCreateModal()">
        <i class="fa-solid fa-plus"></i> Add New Flight
    </button>
</div>

<!-- Filter Bar -->
<form method="get" class="filter-bar" asp-controller="Admin" asp-action="ManageFlights">
    <input type="text" name="search" placeholder="Search flight number, city..." value="@search" style="min-width:280px" />
    <button type="submit" class="filter-btn"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
</form>

<!-- Data Table -->
<div class="schedule-table-card">
    <table class="schedule-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Flight Number</th>
                <th>Route (Departure → Arrival)</th>
                <th>Schedules Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var f in Model)
                {
                    var dep = f.Route?.DepartureCityNavigation?.CityName ?? "—";
                    var arr = f.Route?.ArrivalCityNavigation?.CityName ?? "—";
                    var routeStr = $"{dep} → {arr}";
                    var scheduleCount = f.FlightSchedules.Count;

                    <tr>
                        <td class="td-mono">#@f.FlightId</td>
                        <td style="font-weight:600;color:var(--accent-gold);font-size:1.05rem">@f.FlightNumber</td>
                        <td>@routeStr</td>
                        <td>
                            @if (scheduleCount > 0)
                            {
                                <span style="color:#fff">@scheduleCount schedules</span>
                            }
                            else
                            {
                                <span style="color:rgba(255,255,255,0.4)">No schedules</span>
                            }
                        </td>
                        <td>
                            <div class="action-btns">
                                <button class="act-btn act-edit" title="Edit Flight" onclick="openEditModal(@f.FlightId)">
                                    <i class="fa-solid fa-pen"></i> Edit
                                </button>
                                @if (scheduleCount == 0)
                                {
                                    <button class="act-btn act-cancel" title="Delete Flight" onclick="openDeleteModal(@f.FlightId)">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </button>
                                }
                                else
                                {
                                    <button class="act-btn act-cancel" style="opacity:0.3;cursor:not-allowed" title="Cannot delete flight with active schedules">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5">
                        <div class="empty-state">
                            <i class="fa-solid fa-plane-departure"></i>
                            <div>No flights found</div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ======================= MODALS ======================= -->
<!-- CREATE / EDIT MODAL -->
<div class="modal-overlay" id="flightModal">
    <div class="modal-box" style="width: min(450px, 90vw);">
        <div class="modal-header">
            <span class="modal-title" id="mTitle"><i class="fa-solid fa-plus" style="color:var(--accent-gold);margin-right:6px"></i> Add Flight</span>
            <button class="modal-close" onclick="closeModal('flightModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="fId" value="0" />

            <div class="form-group">
                <label class="form-label">Flight Number</label>
                <input type="text" class="form-control" id="fNumber" placeholder="e.g., VN123" style="text-transform:uppercase;font-weight:600;color:var(--accent-gold)" />
            </div>

            <div class="form-group">
                <label class="form-label">Route</label>
                <select class="form-control" id="fRoute">
                    <option value="">-- Select Route --</option>
                    @if (routes != null)
                    {
                        foreach (var r in routes)
                        {
                            var d = r.DepartureCityNavigation?.CityName ?? "—";
                            var a = r.ArrivalCityNavigation?.CityName ?? "—";
                            <option value="@r.RouteId">@d → @a</option>
                        }
                    }
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('flightModal')">Cancel</button>
            <button class="btn-submit" onclick="submitFlight()"><i class="fa-solid fa-check"></i> Save Flight</button>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal-box" style="width:min(400px,90vw)">
        <div class="modal-header">
            <span class="modal-title"><i class="fa-solid fa-triangle-exclamation" style="color:var(--accent-coral);margin-right:6px"></i> Confirm Deletion</span>
            <button class="modal-close" onclick="closeModal('deleteModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body" style="text-align:center;padding:1.5rem 1.4rem">
            <p style="color:rgba(255,255,255,0.7);font-size:0.95rem">
                Are you sure you want to <strong style="color:var(--accent-coral)">delete</strong> this flight?<br />
                This action cannot be undone.
            </p>
            <input type="hidden" id="delId" />
        </div>
        <div class="modal-footer" style="justify-content:center">
            <button class="btn-cancel" onclick="closeModal('deleteModal')">No, keep it</button>
            <button class="btn-danger" onclick="submitDelete()"><i class="fa-solid fa-trash"></i> Delete</button>
        </div>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/admin-flights.js"></script>
}
