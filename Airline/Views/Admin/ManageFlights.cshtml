@model IEnumerable<Airline.Models.Flight>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Flights";

    var flights = Model?.ToList() ?? new List<Airline.Models.Flight>();
    var routes = ViewBag.Routes as IEnumerable<Airline.Models.Route> ?? Enumerable.Empty<Airline.Models.Route>();
    var totalFlights = flights.Count;
    var linkedRoutes = flights.Select(x => x.RouteId).Distinct().Count();
    var scheduledFlights = flights.Count(x => x.FlightSchedules.Any());
    var unscheduledFlights = totalFlights - scheduledFlights;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-unified.css" asp-append-version="true" />
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Master Data</div>
        <h1 class="page-title">Manage <span>Flights</span></h1>
        <p class="page-subtitle">Control flight numbers and map each flight to its assigned route.</p>
    </div>

    <div class="page-actions">
        <button type="button" class="btn-ghost js-refresh-page">
            <i class="fa-solid fa-arrows-rotate"></i> Refresh
        </button>
        <button type="button" class="btn-primary" onclick="openCreateModal()">
            <i class="fa-solid fa-plane"></i> Add Flight
        </button>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card" style="--kpi-accent:#17aab8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-plane"></i></div>
        </div>
        <div class="kpi-value">@totalFlights</div>
        <div class="kpi-label">Total Flights</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#f0b429">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-route"></i></div>
        </div>
        <div class="kpi-value">@linkedRoutes</div>
        <div class="kpi-label">Routes Assigned</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#5de8a8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-calendar-check"></i></div>
        </div>
        <div class="kpi-value">@scheduledFlights</div>
        <div class="kpi-label">Flights With Schedules</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#ff6b6b">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-calendar-xmark"></i></div>
        </div>
        <div class="kpi-value">@unscheduledFlights</div>
        <div class="kpi-label">Flights Without Schedules</div>
    </div>
</div>

<div class="table-card">
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="flightSearch" placeholder="Search flight number or route..." />
            </div>

            <select id="flightScheduleFilter" class="toolbar-select">
                <option value="">All Flights</option>
                <option value="SCHEDULED">With Schedules</option>
                <option value="UNSCHEDULED">Without Schedules</option>
            </select>
        </div>

        <div class="toolbar-right">
            <span class="result-text">
                Total: <strong id="flightCount">@totalFlights</strong> flight(s)
            </span>
        </div>
    </div>

    <div class="table-wrap">
        <table class="data-table" id="flightsTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Flight Number</th>
                    <th>Route</th>
                    <th>Schedules</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (flights.Any())
                {
                    foreach (var flight in flights)
                    {
                        var dep = flight.Route?.DepartureCityNavigation?.CityName ?? "-";
                        var arr = flight.Route?.ArrivalCityNavigation?.CityName ?? "-";
                        var scheduleCount = flight.FlightSchedules.Count;
                        var scheduleState = scheduleCount > 0 ? "SCHEDULED" : "UNSCHEDULED";

                        <tr class="flight-row"
                            data-search="@($"{flight.FlightNumber} {dep} {arr}")"
                            data-status="@scheduleState">
                            <td class="td-mono">#@flight.FlightId</td>
                            <td>
                                <div class="metric-stack">
                                    <span class="metric-primary">@flight.FlightNumber</span>
                                    <span class="metric-secondary">Route ID: #@flight.RouteId</span>
                                </div>
                            </td>
                            <td>
                                <div class="route-stack">
                                    <span class="route-primary">@dep &rarr; @arr</span>
                                    <span class="route-secondary">Assigned route for this flight</span>
                                </div>
                            </td>
                            <td>
                                <div class="metric-stack">
                                    <span class="metric-primary">@scheduleCount schedule(s)</span>
                                    <span class="metric-secondary">
                                        @(scheduleCount > 0 ? "Ready for booking operations" : "Needs schedule setup")
                                    </span>
                                </div>
                            </td>
                            <td>
                                <span class="status-pill @(scheduleCount > 0 ? "pill-green" : "pill-neutral")">
                                    @(scheduleCount > 0 ? "ACTIVE" : "PENDING")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="row-actions">
                                    <button type="button"
                                            class="icon-btn edit-btn"
                                            title="Edit flight"
                                            onclick="openEditModal(@flight.FlightId)">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>

                                    <button type="button"
                                            class="icon-btn delete-btn"
                                            title="Delete flight"
                                            onclick="openDeleteModal(@flight.FlightId, '@flight.FlightNumber')"
                                            disabled="@(scheduleCount > 0)">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="empty-state">
                            <i class="fa-solid fa-plane-departure"></i>
                            No flights found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="flightModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3 id="mTitle">Add Flight</h3>
                <p>Create a flight number and assign it to an existing route.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="form-shell">
            <input type="hidden" id="fId" value="0" />

            <div class="form-grid">
                <div class="form-group form-group-full">
                    <label for="fNumber">Flight Number</label>
                    <input type="text" id="fNumber" placeholder="e.g. VN123" style="text-transform:uppercase;" />
                </div>

                <div class="form-group form-group-full">
                    <label for="fRoute">Route</label>
                    <select id="fRoute">
                        <option value="">Select route</option>
                        @foreach (var route in routes)
                        {
                            var dep = route.DepartureCityNavigation?.CityName ?? "-";
                            var arr = route.ArrivalCityNavigation?.CityName ?? "-";
                            <option value="@route.RouteId">@dep &rarr; @arr</option>
                        }
                    </select>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="button" class="btn-primary" onclick="submitFlight()">
                    <i class="fa-solid fa-floppy-disk"></i> Save Flight
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3>Delete Flight</h3>
                <p>This action cannot be undone.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="delete-content">
            <p>Are you sure you want to delete this flight?</p>
            <div class="delete-target" id="deleteTargetText"></div>
            <input type="hidden" id="delId" />
        </div>

        <div class="form-shell" style="padding-top:0.8rem;">
            <div class="modal-footer" style="margin-top:0;">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="button" class="btn-danger" onclick="submitDelete()">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<div id="toast" class="toast"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/admin-flights.js" asp-append-version="true"></script>
}
