@model IEnumerable<Airline.Models.Route>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Routes";
    var cities = ViewBag.Cities as IEnumerable<Airline.Models.Cities>;
    var search = ViewBag.Search as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-routes.css" />
}

<!-- Page Header -->
<div class="schedule-header">
    <div class="page-title-block">
        <div class="page-greeting">Master Data</div>
        <h1 class="page-title">Manage Routes</h1>
        <p class="page-subtitle">Configure flight paths between cities</p>
    </div>
    <button class="btn-create" onclick="openCreateModal()">
        <i class="fa-solid fa-plus"></i> Add New Route
    </button>
</div>

<!-- Filter Bar -->
<form method="get" class="filter-bar" asp-controller="Admin" asp-action="ManageRoutes">
    <input type="text" name="search" placeholder="Search departure or arrival city..." value="@search" style="min-width:280px" />
    <button type="submit" class="filter-btn"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
</form>

<!-- Data Table -->
<div class="schedule-table-card">
    <table class="schedule-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Departure City</th>
                <th></th>
                <th>Arrival City</th>
                <th>Flights Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var r in Model)
                {
                    var dep = r.DepartureCityNavigation?.CityName ?? "—";
                    var arr = r.ArrivalCityNavigation?.CityName ?? "—";
                    var flightCount = r.Flights.Count;
                    <tr>
                        <td class="td-mono">#@r.RouteId</td>
                        <td style="font-weight:600;color:#fff">@dep</td>
                        <td style="color:var(--accent-gold);font-size:0.8rem"><i class="fa-solid fa-plane"></i></td>
                        <td style="font-weight:600;color:#fff">@arr</td>
                        <td>
                            @if (flightCount > 0)
                            {
                                <span style="color:var(--accent-gold)">@flightCount flights</span>
                            }
                            else
                            {
                                <span style="color:rgba(255,255,255,0.4)">Not in use</span>
                            }
                        </td>
                        <td>
                            <div class="action-btns">
                                <button class="act-btn act-edit" title="Edit Route" onclick="openEditModal(@r.RouteId)">
                                    <i class="fa-solid fa-pen"></i> Edit
                                </button>
                                @if (flightCount == 0)
                                {
                                    <button class="act-btn act-cancel" title="Delete Route" onclick="openDeleteModal(@r.RouteId)">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </button>
                                }
                                else
                                {
                                    <button class="act-btn act-cancel" style="opacity:0.3;cursor:not-allowed" title="Cannot delete route with active flights">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state">
                            <i class="fa-solid fa-route"></i>
                            <div>No routes found</div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ======================= MODALS ======================= -->
<!-- CREATE / EDIT MODAL -->
<div class="modal-overlay" id="routeModal">
    <div class="modal-box" style="width: min(450px, 90vw);">
        <div class="modal-header">
            <span class="modal-title" id="mTitle"><i class="fa-solid fa-plus" style="color:var(--accent-gold);margin-right:6px"></i> Add Route</span>
            <button class="modal-close" onclick="closeModal('routeModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="rId" value="0" />

            <div class="form-group">
                <label class="form-label">Departure City</label>
                <select class="form-control" id="rDep">
                    <option value="">-- Select Departure --</option>
                    @if (cities != null)
                    {
                        foreach (var c in cities)
                        {
                            <option value="@c.CityId">@c.CityName (@c.Country)</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group" style="text-align:center;color:var(--accent-gold);margin:-5px 0">
                <i class="fa-solid fa-arrow-down"></i>
            </div>
            <div class="form-group">
                <label class="form-label">Arrival City</label>
                <select class="form-control" id="rArr">
                    <option value="">-- Select Arrival --</option>
                    @if (cities != null)
                    {
                        foreach (var c in cities)
                        {
                            <option value="@c.CityId">@c.CityName (@c.Country)</option>
                        }
                    }
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('routeModal')">Cancel</button>
            <button class="btn-submit" onclick="submitRoute()"><i class="fa-solid fa-check"></i> Save Route</button>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal-box" style="width:min(400px,90vw)">
        <div class="modal-header">
            <span class="modal-title"><i class="fa-solid fa-triangle-exclamation" style="color:var(--accent-coral);margin-right:6px"></i> Confirm Deletion</span>
            <button class="modal-close" onclick="closeModal('deleteModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body" style="text-align:center;padding:1.5rem 1.4rem">
            <p style="color:rgba(255,255,255,0.7);font-size:0.95rem">
                Are you sure you want to <strong style="color:var(--accent-coral)">delete</strong> this route?<br />
                This action cannot be undone.
            </p>
            <input type="hidden" id="delId" />
        </div>
        <div class="modal-footer" style="justify-content:center">
            <button class="btn-cancel" onclick="closeModal('deleteModal')">No, keep it</button>
            <button class="btn-danger" onclick="submitDelete()"><i class="fa-solid fa-trash"></i> Delete</button>
        </div>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/admin-routes.js"></script>
}
