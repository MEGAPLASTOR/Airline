@model IEnumerable<Airline.Models.Route>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Routes";

    var routesList = Model?.ToList() ?? new List<Airline.Models.Route>();
    var cities = ViewBag.Cities as IEnumerable<Airline.Models.Cities> ?? Enumerable.Empty<Airline.Models.Cities>();
    var totalRoutes = routesList.Count;
    var activeRoutes = routesList.Count(x => x.Flights.Any());
    var unusedRoutes = totalRoutes - activeRoutes;
    var connectedCities = routesList
        .SelectMany(x => new[] { x.DepartureCity, x.ArrivalCity })
        .Distinct()
        .Count();
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-unified.css" asp-append-version="true" />
}

<div class="page-header">
    <div class="page-title-block">
        <div class="page-greeting">Network Planning</div>
        <h1 class="page-title">Manage <span>Routes</span></h1>
        <p class="page-subtitle">Maintain the flight paths that connect your departure and arrival cities.</p>
    </div>

    <div class="page-actions">
        <button type="button" class="btn-ghost js-refresh-page">
            <i class="fa-solid fa-arrows-rotate"></i> Refresh
        </button>
        <button type="button" class="btn-primary" onclick="openCreateModal()">
            <i class="fa-solid fa-route"></i> Add Route
        </button>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card" style="--kpi-accent:#17aab8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-route"></i></div>
        </div>
        <div class="kpi-value">@totalRoutes</div>
        <div class="kpi-label">Total Routes</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#f0b429">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-plane-up"></i></div>
        </div>
        <div class="kpi-value">@activeRoutes</div>
        <div class="kpi-label">Routes In Use</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#5de8a8">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-location-dot"></i></div>
        </div>
        <div class="kpi-value">@connectedCities</div>
        <div class="kpi-label">Cities Connected</div>
    </div>

    <div class="kpi-card" style="--kpi-accent:#ff6b6b">
        <div class="kpi-top">
            <div class="kpi-icon-wrap"><i class="fa-solid fa-circle-pause"></i></div>
        </div>
        <div class="kpi-value">@unusedRoutes</div>
        <div class="kpi-label">Unused Routes</div>
    </div>
</div>

<div class="table-card">
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="routeSearch" placeholder="Search departure or arrival city..." />
            </div>

            <select id="routeUsageFilter" class="toolbar-select">
                <option value="">All Statuses</option>
                <option value="ACTIVE">In Use</option>
                <option value="IDLE">Not In Use</option>
            </select>
        </div>

        <div class="toolbar-right">
            <span class="result-text">
                Total: <strong id="routeCount">@totalRoutes</strong> route(s)
            </span>
        </div>
    </div>

    <div class="table-wrap">
        <table class="data-table" id="routesTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Departure</th>
                    <th>Arrival</th>
                    <th>Flights Linked</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (routesList.Any())
                {
                    foreach (var route in routesList)
                    {
                        var dep = route.DepartureCityNavigation?.CityName ?? "-";
                        var arr = route.ArrivalCityNavigation?.CityName ?? "-";
                        var flightCount = route.Flights.Count;
                        var usage = flightCount > 0 ? "ACTIVE" : "IDLE";

                        <tr class="route-row"
                            data-search="@($"{dep} {arr}")"
                            data-usage="@usage">
                            <td class="td-mono">#@route.RouteId</td>
                            <td>
                                <div class="metric-stack">
                                    <span class="metric-primary">@dep</span>
                                    <span class="metric-secondary">Origin city</span>
                                </div>
                            </td>
                            <td>
                                <div class="metric-stack">
                                    <span class="metric-primary">@arr</span>
                                    <span class="metric-secondary">Destination city</span>
                                </div>
                            </td>
                            <td>
                                <div class="metric-stack">
                                    <span class="metric-primary">@flightCount flight(s)</span>
                                    <span class="metric-secondary">
                                        @(flightCount > 0 ? "Assigned to active flights" : "No flight currently linked")
                                    </span>
                                </div>
                            </td>
                            <td>
                                <span class="status-pill @(flightCount > 0 ? "pill-gold" : "pill-neutral")">
                                    @(flightCount > 0 ? "IN USE" : "IDLE")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="row-actions">
                                    <button type="button"
                                            class="icon-btn edit-btn"
                                            title="Edit route"
                                            onclick="openEditModal(@route.RouteId)">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>

                                    <button type="button"
                                            class="icon-btn delete-btn"
                                            title="Delete route"
                                            onclick="openDeleteModal(@route.RouteId, '@dep', '@arr')"
                                            disabled="@(flightCount > 0)">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="empty-state">
                            <i class="fa-solid fa-route"></i>
                            No routes found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal-overlay" id="routeModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3 id="mTitle">Add Route</h3>
                <p>Create or update a route between two cities.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="form-shell">
            <input type="hidden" id="rId" value="0" />

            <div class="form-grid">
                <div class="form-group form-group-full">
                    <label for="rDep">Departure City</label>
                    <select id="rDep">
                        <option value="">Select departure</option>
                        @foreach (var city in cities)
                        {
                            <option value="@city.CityId">@city.CityName (@city.Country)</option>
                        }
                    </select>
                </div>

                <div class="form-group form-group-full">
                    <label for="rArr">Arrival City</label>
                    <select id="rArr">
                        <option value="">Select arrival</option>
                        @foreach (var city in cities)
                        {
                            <option value="@city.CityId">@city.CityName (@city.Country)</option>
                        }
                    </select>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="button" class="btn-primary" onclick="submitRoute()">
                    <i class="fa-solid fa-floppy-disk"></i> Save Route
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal-card modal-sm">
        <div class="modal-header">
            <div>
                <h3>Delete Route</h3>
                <p>This action cannot be undone.</p>
            </div>
            <button type="button" class="modal-close js-close-modal">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="delete-content">
            <p>Are you sure you want to delete this route?</p>
            <div class="delete-target" id="deleteTargetText"></div>
            <input type="hidden" id="delId" />
        </div>

        <div class="form-shell" style="padding-top:0.8rem;">
            <div class="modal-footer" style="margin-top:0;">
                <button type="button" class="btn-ghost js-close-modal">Cancel</button>
                <button type="button" class="btn-danger" onclick="submitDelete()">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<div id="toast" class="toast"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/admin-routes.js" asp-append-version="true"></script>
}
