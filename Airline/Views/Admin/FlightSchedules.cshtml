@model IEnumerable<Airline.Models.FlightSchedule>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Flight Schedules";
    var flights = ViewBag.Flights as IEnumerable<Airline.Models.Flight>;
    var search = ViewBag.Search as string ?? "";
    var statusFilter = ViewBag.StatusFilter as string ?? "";
    var dateFrom = ViewBag.DateFrom as string ?? "";
    var dateTo = ViewBag.DateTo as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-pages.css" />
}

<!-- Page Header -->
<div class="schedule-header">
    <div class="page-title-block">
        <div class="page-greeting">Manage Flights</div>
        <h1 class="page-title">Flight Schedules</h1>
        <p class="page-subtitle">Manage departure times, arrivals, and capacities</p>
    </div>
    <button class="btn-create" onclick="openCreateModal()">
        <i class="fa-solid fa-plus"></i> Add New Schedule
    </button>
</div>

<!-- Filter Bar -->
<form method="get" class="filter-bar" asp-controller="Admin" asp-action="FlightSchedules">
    <div class="filter-group">
        <label>Search Flight / Route</label>
        <input type="text" name="search" placeholder="Enter keywords..." value="@search" style="width:200px" />
    </div>
    <div class="filter-group">
        <label>Status</label>
        <select name="status">
            <option value="ALL" selected="@(statusFilter == "ALL" || string.IsNullOrEmpty(statusFilter))">All Statuses</option>
            <option value="SCHEDULED" selected="@(statusFilter == "SCHEDULED")">Scheduled</option>
            <option value="DELAYED" selected="@(statusFilter == "DELAYED")">Delayed</option>
            <option value="CANCELLED" selected="@(statusFilter == "CANCELLED")">Cancelled</option>
            <option value="COMPLETED" selected="@(statusFilter == "COMPLETED")">Completed</option>
        </select>
    </div>
    <div class="filter-group">
        <label>From Date</label>
        <input type="date" name="dateFrom" value="@dateFrom" />
    </div>
    <div class="filter-group">
        <label>To Date</label>
        <input type="date" name="dateTo" value="@dateTo" />
    </div>
    <button type="submit" class="filter-btn"><i class="fa-solid fa-filter"></i> Filter</button>
</form>

<!-- Data Table -->
<div class="schedule-table-card">
    <table class="schedule-table">
        <thead>
            <tr>
                <th>Flight & Route</th>
                <th>Departure</th>
                <th>Arrival</th>
                <th>Seats (Avail/Total)</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var s in Model)
                {
                    var depCity = s.Flight?.Route?.DepartureCityNavigation?.CityName ?? "—";
                    var arrCity = s.Flight?.Route?.ArrivalCityNavigation?.CityName ?? "—";
                    var flightNum = s.Flight?.FlightNumber ?? "—";

                    var pillClass = "pill-scheduled";
                    var statusVi = "Scheduled";
                    switch(s.Status)
                    {
                        case "DELAYED": pillClass = "pill-delayed"; statusVi = "Delayed"; break;
                        case "CANCELLED": pillClass = "pill-cancelled"; statusVi = "Cancelled"; break;
                        case "COMPLETED": pillClass = "pill-completed"; statusVi = "Completed"; break;
                    }

                    var booked = (s.TotalSeats ?? 0) - (s.AvailableSeats ?? 0);
                    var percent = (s.TotalSeats ?? 0) > 0 ? (booked * 100.0 / (s.TotalSeats ?? 1)) : 0;

                    <tr>
                        <td>
                            <div class="route-cell">
                                <span class="route-cities">@depCity → @arrCity</span>
                                <span class="flight-num"><i class="fa-solid fa-ticket"></i> @flightNum</span>
                            </div>
                        </td>
                        <td>
                            <div class="time-badge">
                                <i class="fa-solid fa-plane-departure"></i>
                                @s.DepartureTime.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </td>
                        <td>
                            <div class="time-badge">
                                <i class="fa-solid fa-plane-arrival"></i>
                                @s.ArrivalTime.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </td>
                        <td>
                            <div style="font-size:0.9rem">
                                <strong style="color:#fff">@s.AvailableSeats</strong> / @s.TotalSeats
                            </div>
                            <div class="seats-bar">
                                <div class="seats-fill" style="width: @percent%"></div>
                            </div>
                        </td>
                        <td>
                            <span class="status-pill @pillClass">@statusVi</span>
                        </td>
                        <td>
                            <div class="action-btns">
                                <button class="act-btn act-edit" title="Edit Schedule" onclick="openEditModal(@s.ScheduleId)">
                                    <i class="fa-solid fa-pen"></i> Edit
                                </button>
                                <button class="act-btn act-cancel" title="Delete Schedule" onclick="openDeleteModal(@s.ScheduleId)">
                                    <i class="fa-solid fa-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state">
                            <i class="fa-solid fa-calendar-xmark"></i>
                            <div>No flight schedules found</div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ======================= MODALS ======================= -->

<!-- CREATE / EDIT MODAL -->
<div class="modal-overlay" id="scheduleModal">
    <div class="modal-box">
        <div class="modal-header">
            <span class="modal-title" id="mTitle"><i class="fa-solid fa-plus" style="color:var(--accent-gold);margin-right:6px"></i> Add Schedule</span>
            <button class="modal-close" onclick="closeModal('scheduleModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="sId" value="0" />
            
            <div class="form-group">
                <label class="form-label">Flight</label>
                <select class="form-control" id="sFlight">
                    <option value="">-- Select Flight --</option>
                    @if (flights != null)
                    {
                        foreach (var f in flights)
                        {
                            var dep = f.Route?.DepartureCityNavigation?.CityName ?? "";
                            var arr = f.Route?.ArrivalCityNavigation?.CityName ?? "";
                            <option value="@f.FlightId">@f.FlightNumber (@dep → @arr)</option>
                        }
                    }
                </select>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Departure Time</label>
                    <input type="datetime-local" class="form-control" id="sDepTime" />
                </div>
                <div class="form-group">
                    <label class="form-label">Arrival Time</label>
                    <input type="datetime-local" class="form-control" id="sArrTime" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Total Seats</label>
                    <input type="number" class="form-control" id="sTotal" min="1" value="150" />
                </div>
                <div class="form-group">
                    <label class="form-label">Available Seats</label>
                    <input type="number" class="form-control" id="sAvail" min="0" value="150" />
                    <small style="color:rgba(255,255,255,0.4);font-size:0.75rem" id="sAvailHint">Same as total on creation</small>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Status</label>
                <select class="form-control" id="sStatus">
                    <option value="SCHEDULED">Scheduled</option>
                    <option value="DELAYED">Delayed</option>
                    <option value="CANCELLED">Cancelled</option>
                    <option value="COMPLETED">Completed</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal('scheduleModal')">Cancel</button>
            <button class="btn-submit" onclick="submitSchedule()"><i class="fa-solid fa-check"></i> Save Schedule</button>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal-box" style="width:min(400px,90vw)">
        <div class="modal-header">
            <span class="modal-title"><i class="fa-solid fa-triangle-exclamation" style="color:var(--accent-coral);margin-right:6px"></i> Confirm Deletion</span>
            <button class="modal-close" onclick="closeModal('deleteModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body" style="text-align:center;padding:1.5rem 1.4rem">
            <p style="color:rgba(255,255,255,0.7);font-size:0.95rem">
                Are you sure you want to <strong style="color:var(--accent-coral)">delete</strong> this schedule?<br />
                This action cannot be undone.
            </p>
            <input type="hidden" id="delId" />
        </div>
        <div class="modal-footer" style="justify-content:center">
            <button class="btn-cancel" onclick="closeModal('deleteModal')">No, keep it</button>
            <button class="btn-danger" onclick="submitDelete()"><i class="fa-solid fa-trash"></i> Delete</button>
        </div>
    </div>
</div>

<!-- Toast -->
<div id="toast" class="toast"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/admin-common.js"></script>
    <script src="~/js/admin-schedules.js"></script>
}
