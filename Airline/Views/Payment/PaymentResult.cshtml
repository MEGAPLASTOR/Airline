@{
    ViewData["Title"] = "Payment Result";
    var success = ViewBag.Success as bool? ?? false;
    var message = ViewBag.Message as string ?? "Thông tin thanh toán không xác định.";
}

<style>
    .result-container {
        padding: 4rem 2rem;
        max-width: 650px;
        margin: 0 auto;
        text-align: center;
    }
    .result-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-lg);
        padding: 3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    }
    .result-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }
    .icon-success {
        background: rgba(23, 184, 120, 0.15);
        color: #5de8a8;
        border: 2px solid rgba(23, 184, 120, 0.3);
    }
    .icon-error {
        background: rgba(255, 107, 107, 0.15);
        color: #ff8f8f;
        border: 2px solid rgba(255, 107, 107, 0.3);
    }
    .result-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
    }
    .result-msg {
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.6;
    }
    .btn-return {
        margin-top: 1rem;
        background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
        color: #fff;
        padding: 0.85rem 2rem;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: transform 0.2s;
        display: inline-block;
    }
    .btn-return:hover {
        transform: translateY(-2px);
        opacity: 0.9;
    }
</style>

<div class="result-container">
    <div class="result-card">
        <div class="result-icon @(success ? "icon-success" : "icon-error")">
            <i class="fa-solid @(success ? "fa-circle-check" : "fa-circle-xmark")"></i>
        </div>
        
        <h1 class="result-title">@(success ? "Payment Successful" : "Payment Failed")</h1>
        
        <p class="result-msg">@message</p>

        @if (success)
        {
            <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">Vé của bạn đã được xác nhận và cập nhật trạng thái PAID. Bạn có thể xem lại trong mục My Tickets.</p>
        }
        else
        {
            <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">Đã có lỗi xảy ra trong quá trình thanh toán. Vui lòng thử lại sau hoặc liên hệ bộ phận chăm sóc khách hàng.</p>
        }

        <a asp-controller="Ticket" asp-action="ViewConfirmation" class="btn-return">
            Go to My Tickets
        </a>
    </div>
</div>
