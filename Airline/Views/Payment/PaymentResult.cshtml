@{
    ViewData["Title"] = "Payment Result";
    Layout = "_Layout";
    var success = ViewBag.Success as bool? ?? false;
    var message = ViewBag.Message as string ?? "Thong tin thanh toan khong xac dinh.";
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("ViewConfirmation", "Ticket");
    var returnText = ViewBag.ReturnText as string ?? "Go to My Tickets";
}

<div class="result-container">
    <div class="result-card">
        <div class="result-icon @(success ? "icon-success" : "icon-error")">
            <i class="fa-solid @(success ? "fa-circle-check" : "fa-circle-xmark")"></i>
        </div>
        
        <h1 class="result-title">@(success ? "Payment Successful" : "Payment Failed")</h1>
        
        <p class="result-msg">@message</p>

        @if (success)
        {
            <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">Giao dich da duoc ghi nhan thanh cong. Ban co the quay lai man hinh lien quan de kiem tra trang thai moi nhat.</p>
        }
        else
        {
            <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">Da co loi xay ra trong qua trinh thanh toan. Vui long thu lai sau hoac lien he bo phan cham soc khach hang.</p>
        }

        <a href="@returnUrl" class="btn-return">
            @returnText
        </a>
    </div>
</div>
