@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="status-page">
    <div class="status-card">
        <div class="status-icon icon-error">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>

        <h1 class="status-title">Something Went Wrong</h1>
        <p class="status-message">The request could not be completed. The issue may be temporary, but if it continues the support team should review the related booking, account, or admin action.</p>

        @if (Model.ShowRequestId)
        {
            <div class="status-actions" style="margin-top:1.1rem;">
                <span class="request-chip">
                    <i class="fa-solid fa-hashtag"></i>
                    Request ID
                </span>
                <span class="request-code">@Model.RequestId</span>
            </div>
        }

        <p class="status-meta">For local debugging, enable the <strong>Development</strong> environment only when you need detailed exception data. Do not expose that environment in production because it can reveal sensitive application details.</p>

        <div class="status-actions">
            <a href="/" class="btn-primary">
                <i class="fa-solid fa-house"></i>
                Return Home
            </a>
            <a href="/Contact" class="btn-ghost">
                <i class="fa-solid fa-headset"></i>
                Contact Support
            </a>
        </div>
    </div>
</div>
