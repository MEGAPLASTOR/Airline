@* ✅ KHÔNG dùng Identity — đọc role từ Cookie Claims *@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SkyAdmin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --ocean-deep:   #071829;
            --ocean-dark:   #0b2235;
            --ocean-aqua:   #17aab8;
            --ocean-teal:   #0d7f8f;
            --accent-green: #5de8a8;
            --accent-gold:  #f0b429;
            --accent-coral: #ff6b6b;
            --accent-blue:  #4f9cf9;
            --card-bg:      rgba(255,255,255,0.035);
            --card-border:  rgba(255,255,255,0.07);
            --sidebar-w:    240px;
            --topbar-h:     58px;
            --radius-md:    10px;
            --radius-lg:    14px;
            --tr:           0.18s ease;
        }
        html, body { height: 100%; background: var(--ocean-deep); color: rgba(255,255,255,0.82); font-family: 'DM Sans', sans-serif; font-size: 14px; line-height: 1.55; }
        a { color: inherit; text-decoration: none; }
        button { cursor: pointer; font-family: inherit; }

        .app-shell { display: flex; height: 100vh; overflow: hidden; }

        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar-w); flex-shrink: 0;
            background: var(--ocean-dark);
            border-right: 1px solid rgba(255,255,255,0.055);
            display: flex; flex-direction: column;
            overflow-y: auto; overflow-x: hidden;
            scrollbar-width: none; z-index: 100;
        }
        .sidebar::-webkit-scrollbar { display: none; }
        .sidebar-logo {
            display: flex; align-items: center; gap: 0.65rem;
            padding: 1.2rem 1.35rem 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.055);
        }
        .logo-icon {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
            border-radius: var(--radius-md);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.9rem; color: #fff;
        }
        .logo-text { font-size: 1rem; font-weight: 600; color: #fff; }
        .logo-text span { color: var(--ocean-aqua); }

        .nav-section { padding: 1rem 0 0.5rem; }
        .nav-section-label {
            font-size: 0.66rem; font-weight: 600; text-transform: uppercase;
            letter-spacing: 0.9px; color: rgba(255,255,255,0.22);
            padding: 0 1.35rem 0.5rem;
        }
        .nav-item {
            display: flex; align-items: center; gap: 0.65rem;
            padding: 0.54rem 1.35rem; margin: 0 0.55rem;
            border-radius: var(--radius-md);
            color: rgba(255,255,255,0.45); font-size: 0.84rem; font-weight: 500;
            transition: background var(--tr), color var(--tr);
            position: relative; white-space: nowrap;
        }
        .nav-item i { width: 16px; text-align: center; font-size: 0.8rem; flex-shrink: 0; }
        .nav-item:hover { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.82); }
        .nav-item.active { background: rgba(23,170,184,0.12); color: var(--ocean-aqua); }
        .nav-item.active i { color: var(--ocean-aqua); }
        .nav-item.active::before {
            content: ''; position: absolute; left: -0.55rem; top: 25%; bottom: 25%;
            width: 3px; background: var(--ocean-aqua); border-radius: 0 3px 3px 0;
        }
        .nav-badge {
            margin-left: auto; font-size: 0.65rem; font-weight: 700;
            padding: 0.1rem 0.45rem; border-radius: 20px;
            background: var(--ocean-aqua); color: var(--ocean-deep); line-height: 1.4;
        }
        .nav-badge.warn { background: var(--accent-gold); }
        .nav-divider { height: 1px; background: rgba(255,255,255,0.055); margin: 0.5rem 1rem; }

        .sidebar-footer { margin-top: auto; padding: 1rem; border-top: 1px solid rgba(255,255,255,0.055); }
        .user-chip {
            display: flex; align-items: center; gap: 0.65rem;
            padding: 0.55rem 0.65rem; border-radius: var(--radius-md);
            background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
        }
        .user-avatar {
            width: 30px; height: 30px; border-radius: 50%;
            background: linear-gradient(135deg, var(--ocean-aqua), var(--accent-blue));
            display: flex; align-items: center; justify-content: center;
            font-size: 0.72rem; font-weight: 700; color: #fff; flex-shrink: 0;
        }
        .user-info { flex: 1; min-width: 0; }
        .user-name { font-size: 0.8rem; font-weight: 600; color: rgba(255,255,255,0.82); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .user-role { font-size: 0.7rem; color: rgba(255,255,255,0.35); }

        /* ── MAIN ── */
        .main-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .topbar {
            height: var(--topbar-h); background: rgba(7,24,41,0.85);
            backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.055);
            display: flex; align-items: center; padding: 0 1.5rem; gap: 0.75rem; flex-shrink: 0;
        }
        .topbar-search { flex: 1; max-width: 320px; position: relative; }
        .topbar-search i { position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.25); font-size: 0.78rem; }
        .topbar-search input {
            width: 100%; padding: 0.42rem 0.75rem 0.42rem 2.1rem;
            background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.07);
            border-radius: var(--radius-md); color: rgba(255,255,255,0.75);
            font-size: 0.82rem; font-family: inherit; outline: none; transition: border-color var(--tr);
        }
        .topbar-search input:focus { border-color: rgba(23,170,184,0.4); }
        .topbar-search input::placeholder { color: rgba(255,255,255,0.2); }
        .topbar-spacer { flex: 1; }
        .topbar-icon {
            width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;
            border-radius: var(--radius-md); background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.45);
            font-size: 0.8rem; transition: background var(--tr), color var(--tr); position: relative;
        }
        .topbar-icon:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.8); }
        .topbar-dot { position: absolute; top: 6px; right: 7px; width: 6px; height: 6px; border-radius: 50%; background: var(--accent-coral); border: 1.5px solid var(--ocean-dark); }

        .page-content { flex: 1; overflow-y: auto; padding: 1.5rem 1.75rem; scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.08) transparent; }

        /* ── PAGE HEADER ── */
        .page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem; }
        .page-greeting { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--ocean-aqua); margin-bottom: 0.2rem; }
        .page-title { font-size: 1.45rem; font-weight: 700; color: #fff; font-family: 'Playfair Display', serif; letter-spacing: -0.3px; }
        .page-title span { color: var(--ocean-aqua); }
        .page-subtitle { font-size: 0.78rem; color: rgba(255,255,255,0.35); margin-top: 0.2rem; }
        .page-actions { display: flex; align-items: center; gap: 0.6rem; }

        /* ── SHARED COMPONENTS ── */
        .btn-primary {
            display: inline-flex; align-items: center; gap: 0.45rem; padding: 0.45rem 1rem;
            background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
            color: #fff; font-size: 0.8rem; font-weight: 600; border: none; border-radius: var(--radius-md);
            transition: opacity var(--tr), transform var(--tr);
        }
        .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
        .btn-ghost {
            display: inline-flex; align-items: center; gap: 0.45rem; padding: 0.45rem 1rem;
            background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.09);
            color: rgba(255,255,255,0.55); font-size: 0.8rem; font-weight: 500; border-radius: var(--radius-md);
            transition: background var(--tr), color var(--tr);
        }
        .btn-ghost:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85); }

        .card-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1rem; gap: 0.75rem; }
        .card-title { font-size: 0.9rem; font-weight: 600; color: rgba(255,255,255,0.88); }
        .card-subtitle { font-size: 0.75rem; color: rgba(255,255,255,0.32); margin-top: 0.15rem; }

        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; color: rgba(255,255,255,0.28); padding: 0.55rem 0.85rem; border-bottom: 1px solid rgba(255,255,255,0.06); text-align: left; white-space: nowrap; }
        .data-table td { padding: 0.7rem 0.85rem; border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 0.82rem; color: rgba(255,255,255,0.62); }
        .data-table tbody tr:hover td { background: rgba(255,255,255,0.025); }
        .data-table tbody tr:last-child td { border-bottom: none; }
        .td-mono { font-family: 'Courier New', monospace; font-size: 0.78rem; color: var(--ocean-aqua); }
        .td-bold { font-weight: 600; color: rgba(255,255,255,0.82); }

        .status-pill { display: inline-block; padding: 0.18rem 0.6rem; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
        .pill-green  { background: rgba(93,232,168,0.12);  color: var(--accent-green); }
        .pill-yellow { background: rgba(240,180,41,0.12);   color: var(--accent-gold);  }
        .pill-red    { background: rgba(255,107,107,0.12);  color: var(--accent-coral); }
        .pill-blue   { background: rgba(79,156,249,0.12);   color: var(--accent-blue);  }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

@{
    // ✅ Đọc từ Cookie Claims — khớp với SignIn() trong Accountcontroller.cs
    var userRole    = User?.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var isAdmin     = userRole == "ADMIN";
    var displayName = User?.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Guest";
    var firstName   = User?.FindFirst("FirstName")?.Value ?? displayName;
    var initials    = displayName.Length > 0 ? displayName.Substring(0, 1).ToUpper() : "?";
    var roleLabel   = isAdmin ? "Administrator" : "Member";

    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<div class="app-shell">

    <!-- ═══════ SIDEBAR ═══════ -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon"><i class="fa-solid fa-plane"></i></div>
            <span class="logo-text">Sky<span>Admin</span></span>
        </div>

        @if (isAdmin)
        {
            <!-- ✅ CHỈ ADMIN thấy — role "ADMIN" từ cookie -->
            <nav class="nav-section">
                <div class="nav-section-label">Admin</div>
                <a class="nav-item @(ctrl == "Admin" ? "active" : "")" href="/Admin/Dashboard">
                    <i class="fa-solid fa-gauge-high"></i> Admin Dashboard
                </a>

                <div class="nav-divider"></div>
                <div class="nav-section-label" style="padding-top:0.5rem">Quản lý</div>

                <a class="nav-item" href="/Admin/Users">
                    <i class="fa-solid fa-users"></i> Người dùng
                </a>
                <a class="nav-item" href="/Admin/Flights">
                    <i class="fa-solid fa-plane-departure"></i> Chuyến bay
                </a>
                <a class="nav-item" href="/Admin/Tickets">
                    <i class="fa-solid fa-ticket"></i> Vé đặt
                    <span class="nav-badge warn">12</span>
                </a>
                <a class="nav-item" href="/Admin/Routes">
                    <i class="fa-solid fa-route"></i> Tuyến bay
                </a>
                <a class="nav-item" href="/Admin/Promotions">
                    <i class="fa-solid fa-tags"></i> Khuyến mãi
                </a>

                <div class="nav-divider"></div>
                <div class="nav-section-label" style="padding-top:0.5rem">Hệ thống</div>

                <a class="nav-item" href="/Admin/Reports">
                    <i class="fa-solid fa-chart-line"></i> Báo cáo
                </a>
                <a class="nav-item" href="/Admin/Settings">
                    <i class="fa-solid fa-gear"></i> Cài đặt
                </a>
            </nav>
        }
        else
        {
            <!-- ✅ USER thường — KHÔNG có Admin Dashboard -->
            <nav class="nav-section">
                <div class="nav-section-label">Menu</div>
                <a class="nav-item @(ctrl == "Home" ? "active" : "")" href="/">
                    <i class="fa-solid fa-house"></i> Trang chủ
                </a>
                <a class="nav-item @(ctrl == "Booking" ? "active" : "")" href="/Booking">
                    <i class="fa-solid fa-plane-departure"></i> Đặt vé
                </a>
                <a class="nav-item @(ctrl == "MyTickets" ? "active" : "")" href="/MyTickets">
                    <i class="fa-solid fa-ticket"></i> Vé của tôi
                </a>
                <a class="nav-item @(ctrl == "Account" ? "active" : "")" href="/Account/EditAccount">
                    <i class="fa-solid fa-user-pen"></i> Tài khoản
                </a>
            </nav>
        }

        <div class="sidebar-footer">
            <div class="user-chip">
                <div class="user-avatar">@initials</div>
                <div class="user-info">
                    <div class="user-name">@displayName</div>
                    <div class="user-role">@roleLabel</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- ═══════ MAIN ═══════ -->
    <div class="main-area">
        <header class="topbar">
            <div class="topbar-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Tìm kiếm..." />
            </div>
            <div class="topbar-spacer"></div>
            <div class="topbar-icon" title="Thông báo">
                <i class="fa-solid fa-bell"></i>
                <span class="topbar-dot"></span>
            </div>
            <!-- ✅ Logout dùng GET /Auth/Logout khớp với Accountcontroller.cs -->
            <a href="/Auth/Logout" class="topbar-icon" title="Đăng xuất">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
            </a>
        </header>

        <main class="page-content">
            @RenderBody()
        </main>
    </div>
</div>

@RenderSection("Scripts", required: false)
</body>
</html>
