@{
    var firstName = User?.FindFirst("FirstName")?.Value ?? "Admin";
    var lastName = User?.FindFirst("LastName")?.Value ?? "User";
    var initials = $"{firstName.FirstOrDefault()}{lastName.FirstOrDefault()}".ToUpper();
    var displayName = $"{firstName} {lastName}".Trim();

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    bool IsActive(string controller, params string[] actions)
    {
        if (!string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (actions == null || actions.Length == 0)
        {
            return true;
        }

        return actions.Any(action =>
            string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));
    }

    bool IsAny(params (string Controller, string Action)[] routes)
    {
        return routes.Any(route =>
            string.Equals(currentController, route.Controller, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(currentAction, route.Action, StringComparison.OrdinalIgnoreCase));
    }

    var isDashboard = IsAny(
        ("AdminDashboard", "Dashboard"),
        ("AdminDashboard", "AdminDashboard"),
        ("Account", "AdminDashboard")
    );

    var isTicketingGroup = IsAny(
        ("Admin", "TicketStatuses"),
        ("Admin", "ConfirmTicket"),
        ("ManageTicketClass", "TicketClasses"),
        ("TicketPrice", "TicketPrice")
    );

    var isManageAccounts = IsActive("AdminAccount", "ManageAccounts");

    var isFlightsGroup = IsAny(
        ("AdminFlight", "ManageFlights"),
        ("Admin", "FlightManagement"),
        ("AdminSchedule", "FlightSchedules"),
        ("AdminSchedule", "FlightReschedule"),
        ("AdminSchedule", "FlightSeats"),
        ("Admin", "FlightNotifications")
    );

    var isRoutesGroup = IsAny(
        ("AdminRoute", "ManageRoutes"),
        ("AdminCity", "ManageCity")
    );

    var isCommerceGroup = IsAny(
        ("Admin", "ManagePromotions"),
        ("Admin", "ManageBaggage")
    );
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkyWave Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --ocean-deep: #081a2f;
            --ocean-mid: #0e2c4f;
            --ocean-teal: #0d7f8f;
            --ocean-aqua: #17aab8;
            --ocean-foam: #c8f5fa;
            --accent-gold: #f0b429;
            --accent-coral: #ff6b6b;
            --accent-green: #5de8a8;
            --sidebar-w: 282px;
            --header-h: 74px;
            --radius-sm: 10px;
            --radius-md: 14px;
            --radius-lg: 20px;
            --tr: 0.24s cubic-bezier(0.4,0,0.2,1);
            --card-bg: rgba(255,255,255,0.04);
            --card-border: rgba(255,255,255,0.08);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: radial-gradient(circle at top right, rgba(23,170,184,0.12), transparent 25%), radial-gradient(circle at left bottom, rgba(13,127,143,0.18), transparent 25%), linear-gradient(160deg, #061525, #0a223c 42%, #081b31 100%) !important;
            min-height: 100vh;
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        button, input {
            font: inherit;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            width: var(--sidebar-w);
            background: linear-gradient(180deg, rgba(8,26,47,0.96), rgba(10,34,60,0.94));
            border-right: 1px solid rgba(255,255,255,0.06);
            backdrop-filter: blur(18px);
            z-index: 600;
            display: flex;
            flex-direction: column;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            padding: 1.2rem 1.25rem 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .brand-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--ocean-aqua), #0fd2e4);
            box-shadow: 0 12px 26px rgba(23,170,184,0.24);
            color: white;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .brand-name {
            display: block;
            font-family: 'Playfair Display', serif;
            font-size: 1.12rem;
            color: #fff;
            letter-spacing: 0.02em;
        }

        .brand-sub {
            display: block;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.16em;
            color: rgba(255,255,255,0.42);
            margin-top: 0.08rem;
        }

        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            padding: 1rem 0.8rem 1rem 0.85rem;
        }

        .nav-label {
            padding: 0.9rem 0.8rem 0.45rem;
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.33);
        }

        .nav-link,
        .nav-group-trigger,
        .nav-group-items a {
            display: flex;
            align-items: center;
            gap: 0.78rem;
            border-radius: 14px;
            color: rgba(255,255,255,0.72);
            transition: background var(--tr), color var(--tr), transform var(--tr);
        }

        .nav-link,
        .nav-group-trigger {
            padding: 0.78rem 0.9rem;
            font-size: 0.86rem;
            font-weight: 500;
        }

            .nav-link:hover,
            .nav-group-trigger:hover,
            .nav-group-items a:hover {
                background: rgba(255,255,255,0.05);
                color: #fff;
            }

            .nav-link.active {
                background: linear-gradient(135deg, rgba(23,170,184,0.18), rgba(23,170,184,0.07));
                color: #fff;
                border: 1px solid rgba(23,170,184,0.22);
            }

        .nav-icon {
            width: 34px;
            height: 34px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.05);
            color: var(--ocean-aqua);
            flex-shrink: 0;
            font-size: 0.85rem;
        }

        .nav-group {
            margin-bottom: 0.25rem;
        }

        .nav-group-trigger {
            justify-content: space-between;
            cursor: pointer;
        }

            .nav-group-trigger .arrow {
                margin-left: auto;
                font-size: 0.72rem;
                transition: transform var(--tr);
            }

        .nav-group.open .arrow {
            transform: rotate(180deg);
        }

        .nav-group-items {
            display: none;
            padding: 0.25rem 0 0.4rem 2.95rem;
        }

        .nav-group.open .nav-group-items {
            display: flex;
            flex-direction: column;
            gap: 0.28rem;
        }

        .nav-group-items a {
            padding: 0.6rem 0.75rem;
            font-size: 0.8rem;
        }

            .nav-group-items a.active-sub-link {
                background: rgba(23,170,184,0.12);
                color: #fff;
                border: 1px solid rgba(23,170,184,0.16);
            }

        .sidebar-footer {
            padding: 1rem;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        .admin-card {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            padding: 0.85rem;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: var(--radius-lg);
        }

        .admin-avatar,
        .user-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: linear-gradient(135deg, #ffffff, var(--ocean-foam));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.72rem;
            font-weight: 700;
            color: var(--ocean-deep);
        }

        .admin-name {
            font-size: 0.84rem;
            font-weight: 700;
            color: #fff;
        }

        .admin-role {
            font-size: 0.72rem;
            color: rgba(255,255,255,0.45);
        }

        .sidebar-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.45);
            backdrop-filter: blur(4px);
            z-index: 580;
            display: none;
        }

        .topbar {
            position: fixed;
            top: 0;
            right: 0;
            left: var(--sidebar-w);
            height: var(--header-h);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem;
            z-index: 500;
            background: rgba(6,21,37,0.72);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .topbar-left,
        .topbar-right {
            display: flex;
            align-items: center;
            gap: 0.9rem;
        }

        .menu-toggle {
            display: none;
            width: 42px;
            height: 42px;
            border: none;
            background: rgba(255,255,255,0.06);
            color: #fff;
            border-radius: 12px;
            cursor: pointer;
        }

        .topbar-search {
            width: min(380px, 42vw);
            position: relative;
        }

            .topbar-search input {
                width: 100%;
                background: rgba(255,255,255,0.06);
                border: 1px solid rgba(255,255,255,0.09);
                color: #fff;
                padding: 0.78rem 1rem 0.78rem 2.65rem;
                border-radius: 999px;
                outline: none;
            }

            .topbar-search i {
                position: absolute;
                left: 1rem;
                top: 50%;
                transform: translateY(-50%);
                color: rgba(255,255,255,0.4);
                font-size: 0.85rem;
            }

        .topbar-datetime {
            padding: 0.65rem 0.9rem;
            border-radius: 999px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.07);
            font-size: 0.78rem;
            color: rgba(255,255,255,0.6);
            white-space: nowrap;
        }

        .topbar-user {
            position: relative;
        }

        .user-btn {
            display: flex;
            align-items: center;
            gap: 0.7rem;
            border: 1px solid rgba(255,255,255,0.09);
            background: rgba(255,255,255,0.05);
            color: #fff;
            border-radius: 999px;
            padding: 0.35rem 0.42rem 0.35rem 0.5rem;
            cursor: pointer;
        }

        .user-name {
            font-size: 0.82rem;
            font-weight: 500;
            color: rgba(255,255,255,0.82);
        }

        .user-chevron {
            font-size: 0.58rem;
            color: rgba(255,255,255,0.35);
        }

        .user-dropdown {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background: #0b2240;
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: var(--radius-md);
            min-width: 190px;
            box-shadow: 0 12px 32px rgba(0,0,0,0.5);
            overflow: hidden;
            display: none;
            z-index: 500;
        }

            .user-dropdown.open {
                display: block;
            }

            .user-dropdown a,
            .user-dropdown button {
                display: flex;
                align-items: center;
                gap: 0.6rem;
                padding: 0.65rem 1rem;
                font-size: 0.82rem;
                color: rgba(255,255,255,0.7);
                width: 100%;
                background: none;
                border: none;
                text-align: left;
                transition: background var(--tr), color var(--tr);
                cursor: pointer;
            }

                .user-dropdown a:hover,
                .user-dropdown button:hover {
                    background: rgba(255,255,255,0.07);
                    color: #fff;
                }

        .user-dropdown-divider {
            height: 1px;
            background: rgba(255,255,255,0.07);
            margin: 0.25rem 0;
        }

        .user-dropdown .logout-btn {
            color: rgba(255,107,107,0.8);
        }

            .user-dropdown .logout-btn:hover {
                color: #ff6b6b;
                background: rgba(255,107,107,0.08);
            }

        .main-wrapper {
            margin-left: var(--sidebar-w);
            margin-top: var(--header-h);
            width: calc(100% - var(--sidebar-w));
            min-height: calc(100vh - var(--header-h));
            display: flex;
            flex-direction: column;
        }

        .main-content {
            flex: 1;
            padding: 2rem 2.25rem;
        }

        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 1.85rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .page-greeting {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--ocean-aqua);
            margin-bottom: 0.2rem;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.85rem;
            font-weight: 700;
            color: #fff;
            line-height: 1.2;
        }

            .page-title span {
                color: var(--ocean-aqua);
            }

        .page-subtitle {
            font-size: 0.83rem;
            color: rgba(255,255,255,0.38);
            margin-top: 0.25rem;
        }

        .page-actions {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            flex-wrap: wrap;
        }

        .btn-primary,
        .btn-ghost {
            border: none;
            border-radius: 12px;
            padding: 0.72rem 1rem;
            font-size: 0.82rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: transform var(--tr), box-shadow var(--tr), background var(--tr);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--ocean-aqua), #0fd2e4);
            color: white;
            box-shadow: 0 12px 24px rgba(23,170,184,0.18);
        }

        .btn-ghost {
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.8);
            border: 1px solid rgba(255,255,255,0.08);
        }

        @@media (max-width: 1024px) {
            .menu-toggle {
                display: block;
            }

            .topbar {
                left: 0;
                padding-left: 1.25rem;
            }

            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
            }

                .sidebar.open {
                    transform: translateX(0);
                }

            .sidebar-overlay.open {
                display: block;
            }

            .main-wrapper {
                margin-left: 0;
                width: 100%;
            }
        }

        @@media (max-width: 640px) {
            .topbar-search,
            .topbar-datetime {
                display: none;
            }

            .main-content {
                padding: 1.25rem;
            }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <aside class="sidebar" id="sidebar">
        <a class="sidebar-brand" asp-controller="Admin" asp-action="Dashboard">
            <div class="brand-icon"><i class="fa-solid fa-shield-halved"></i></div>
            <div class="brand-text">
                <span class="brand-name">The Airline</span>
                <span class="brand-sub">Admin Panel</span>
            </div>
        </a>

        <nav class="sidebar-nav">
            <a class="nav-link @(isDashboard ? "active" : "")" asp-controller="AdminDashboard" asp-action="Dashboard">
                <span class="nav-icon"><i class="fa-solid fa-gauge-high"></i></span>
                Dashboard
            </a>

            <div class="nav-label">Ticketing</div>
            <div class="nav-group @(isTicketingGroup ? "open" : "")">
                <div class="nav-group-trigger" onclick="toggleGroup(this)">
                    <span class="nav-icon"><i class="fa-solid fa-ticket"></i></span>
                    Tickets
                    <i class="fa-solid fa-chevron-down arrow"></i>
                </div>
                <div class="nav-group-items">
                    <a class="@(IsActive("Admin", "TicketStatuses") ? "active-sub-link" : "")"
                       asp-controller="Admin" asp-action="TicketStatuses">Manage Ticket Statuses</a>

                    <a class="@(IsActive("Admin", "ConfirmTicket") ? "active-sub-link" : "")"
                       asp-controller="Admin" asp-action="ConfirmTicket">Confirm Ticket</a>

                    <a class="@(IsActive("TicketPrice", "TicketPrice") ? "active-sub-link" : "")"
                       asp-controller="TicketPrice" asp-action="TicketPrice">Manage Ticket Prices</a>

                    <a class="@(IsActive("ManageTicketClass", "TicketClasses") ? "active-sub-link" : "")"
                       asp-controller="ManageTicketClass" asp-action="TicketClasses">Manage Ticket Classes</a>
                </div>
            </div>

            <a class="nav-link @(isManageAccounts ? "active" : "")"
               asp-controller="AdminAccount" asp-action="ManageAccounts">
                <span class="nav-icon"><i class="fa-solid fa-users-gear"></i></span>
                Manage User Account
            </a>

            <div class="nav-label">Flight Operations</div>
            <div class="nav-group @(isFlightsGroup ? "open" : "")">
                <div class="nav-group-trigger" onclick="toggleGroup(this)">
                    <span class="nav-icon"><i class="fa-solid fa-plane"></i></span>
                    Flights
                    <i class="fa-solid fa-chevron-down arrow"></i>
                </div>
                <div class="nav-group-items">
                    <a class="@(IsActive("AdminFlight", "ManageFlights") ? "active-sub-link" : "")"
                       asp-controller="AdminFlight" asp-action="ManageFlights">Manage Flights</a>

                    <a class="@(IsActive("Admin", "FlightManagement") ? "active-sub-link" : "")"
                       asp-controller="Admin" asp-action="FlightManagement">Set Flight Management</a>

                    <a class="@(IsActive("AdminSchedule", "FlightSchedules") ? "active-sub-link" : "")"
                       asp-controller="AdminSchedule" asp-action="FlightSchedules">Manage Flight Schedules</a>

                    <a class="@(IsActive("AdminSchedule", "FlightReschedule") ? "active-sub-link" : "")"
                       asp-controller="AdminSchedule" asp-action="FlightReschedule">Manage Flight Reschedule</a>

                    <a class="@(IsActive("AdminSchedule", "FlightSeats") ? "active-sub-link" : "")"
                       asp-controller="AdminSchedule" asp-action="FlightSeats">Manage Flight Seats</a>

                    <a class="@(IsActive("Admin", "FlightNotifications") ? "active-sub-link" : "")"
                       asp-controller="Admin" asp-action="FlightNotifications">Manage Flight Notifications</a>
                </div>
            </div>

            <div class="nav-group @(isRoutesGroup ? "open" : "")">
                <div class="nav-group-trigger" onclick="toggleGroup(this)">
                    <span class="nav-icon"><i class="fa-solid fa-route"></i></span>
                    Routes & Cities
                    <i class="fa-solid fa-chevron-down arrow"></i>
                </div>
                <div class="nav-group-items">
                    <a class="@(IsActive("AdminRoute", "ManageRoutes") ? "active-sub-link" : "")"
                       asp-controller="AdminRoute" asp-action="ManageRoutes">Manage Routes</a>

                    <a class="@(IsActive("AdminCity", "ManageCity") ? "active-sub-link" : "")"
                       asp-controller="AdminCity" asp-action="ManageCity">Manage City</a>
                </div>
            </div>

            <div class="nav-label">Commerce</div>
            <div class="nav-group @(isCommerceGroup ? "open" : "")">
                <div class="nav-group-trigger" onclick="toggleGroup(this)">
                    <span class="nav-icon"><i class="fa-solid fa-tags"></i></span>
                    Promotions & Baggage
                    <i class="fa-solid fa-chevron-down arrow"></i>
                </div>
                <div class="nav-group-items">
                    <a class="@(IsActive("Admin", "ManagePromotions") ? "active-sub-link" : "")"
                       asp-controller="Admin" asp-action="ManagePromotions">Manage Promotions</a>

                    <a class="@(IsActive("Admin", "ManageBaggage") ? "active-sub-link" : "")"
                       asp-controller="Admin" asp-action="ManageBaggage">Manage Baggage</a>
                </div>
            </div>
        </nav>

        <div class="sidebar-footer">
            <div class="admin-card">
                <div class="admin-avatar">@initials</div>
                <div class="admin-info">
                    <div class="admin-name">@displayName</div>
                    <div class="admin-role">Super Administrator</div>
                </div>
            </div>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <header class="topbar">
        <div class="topbar-left">
            <button type="button" class="menu-toggle" onclick="openSidebar()">
                <i class="fa-solid fa-bars"></i>
            </button>

            <div class="topbar-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Search anything in admin..." />
            </div>
        </div>

        <div class="topbar-right">
            <div class="topbar-datetime" id="topbarDateTime"></div>

            <div class="topbar-user">
                <button type="button" class="user-btn" onclick="toggleUserDropdown()">
                    <div class="user-avatar">@initials</div>
                    <span class="user-name">@displayName</span>
                    <i class="fa-solid fa-chevron-down user-chevron"></i>
                </button>

                <div class="user-dropdown" id="userDropdown">
                    <a asp-controller="Account" asp-action="EditAccount">
                        <i class="fa-regular fa-user"></i> Edit Account
                    </a>
                    <a asp-controller="Account" asp-action="ChangePassword">
                        <i class="fa-solid fa-key"></i> Change Password
                    </a>
                    <div class="user-dropdown-divider"></div>
                    <a class="logout-btn" asp-controller="Account" asp-action="Logout">
                        <i class="fa-solid fa-right-from-bracket"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="main-wrapper">
        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script>
        function openSidebar() {
            document.getElementById('sidebar')?.classList.add('open');
            document.getElementById('sidebarOverlay')?.classList.add('open');
        }

        function closeSidebar() {
            document.getElementById('sidebar')?.classList.remove('open');
            document.getElementById('sidebarOverlay')?.classList.remove('open');
        }

        function toggleGroup(element) {
            element.parentElement.classList.toggle('open');
        }

        function toggleUserDropdown() {
            document.getElementById('userDropdown')?.classList.toggle('open');
        }

        document.addEventListener('click', function (e) {
            const userArea = document.querySelector('.topbar-user');
            if (userArea && !userArea.contains(e.target)) {
                document.getElementById('userDropdown')?.classList.remove('open');
            }
        });

        function updateClock() {
            const element = document.getElementById('topbarDateTime');
            if (!element) return;

            element.textContent = new Date().toLocaleString('vi-VN', {
                weekday: 'short',
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        updateClock();
        setInterval(updateClock, 60000);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>