@{
    bool isLoggedIn = User?.Identity?.IsAuthenticated == true;
    var firstName = User?.FindFirst("FirstName")?.Value ?? "Admin";
    var lastName  = User?.FindFirst("LastName")?.Value  ?? "";
    var initials  = (firstName.Length > 0 ? firstName[0].ToString() : "A")
                  + (lastName.Length  > 0 ? lastName[0].ToString()  : "");
    var displayName = string.IsNullOrWhiteSpace(firstName + lastName)
                    ? "Admin" : $"{firstName} {lastName}".Trim();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkyWave Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    @await RenderSectionAsync("Styles", required: false)

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --ocean-deep:   #0a2342;
            --ocean-mid:    #0e3a6e;
            --ocean-teal:   #0d7f8f;
            --ocean-aqua:   #17aab8;
            --ocean-foam:   #a8e6ef;
            --ocean-pearl:  #f0f8fa;
            --accent-gold:  #f0b429;
            --accent-coral: #ff6b6b;
            --accent-green: #5de8a8;
            --text-dark:    #0d1f2d;
            --sidebar-w:    260px;
            --header-h:     64px;
            --radius-sm:    8px;
            --radius-md:    12px;
            --radius-lg:    18px;
            --tr:           0.2s ease;
            --card-bg:      rgba(255,255,255,0.03);
            --card-border:  rgba(255,255,255,0.08);
        }

        html, body { min-height: 100%; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: #071829;
            color: rgba(255,255,255,0.82);
            min-height: 100vh;
            display: flex; flex-direction: column;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }
        a { text-decoration: none; }
        ul { list-style: none; }
        button { cursor: pointer; font-family: inherit; }

        /* ══════════════ SIDEBAR ══════════════ */
        .sidebar {
            position: fixed; top: 0; left: 0; bottom: 0;
            width: var(--sidebar-w);
            background: linear-gradient(175deg, var(--ocean-deep) 0%, #0b2f58 55%, var(--ocean-mid) 100%);
            z-index: 400; display: flex; flex-direction: column;
            overflow: hidden;
            border-right: 1px solid rgba(255,255,255,0.05);
        }
        .sidebar::after {
            content: ''; position: absolute; bottom: -40px; left: -30px;
            width: 320px; height: 200px;
            background: radial-gradient(ellipse, rgba(23,170,184,0.14) 0%, transparent 70%);
            pointer-events: none;
        }

        .sidebar-brand {
            display: flex; align-items: center; gap: 0.75rem;
            padding: 1.15rem 1.4rem;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            text-decoration: none; flex-shrink: 0;
        }
        .brand-icon {
            width: 40px; height: 40px; border-radius: var(--radius-md);
            background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 14px rgba(23,170,184,0.4); flex-shrink: 0;
        }
        .brand-icon i { color: #fff; font-size: 1.1rem; }
        .brand-text { line-height: 1.2; }
        .brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.05rem; font-weight: 700; color: #fff; display: block;
        }
        .brand-sub {
            font-size: 0.6rem; letter-spacing: 0.13em;
            text-transform: uppercase; color: var(--ocean-foam); opacity: 0.65;
        }

        .sidebar-nav {
            flex: 1; overflow-y: auto; padding: 0.9rem 0 1rem;
            scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.08) transparent;
        }
        .sidebar-nav::-webkit-scrollbar { width: 4px; }
        .sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }

        .nav-label {
            padding: 0.65rem 1.4rem 0.2rem;
            font-size: 0.6rem; letter-spacing: 0.16em;
            text-transform: uppercase; color: rgba(255,255,255,0.28); font-weight: 700;
        }
        .nav-link {
            display: flex; align-items: center; gap: 0.7rem;
            padding: 0.6rem 1.4rem;
            color: rgba(255,255,255,0.65); font-size: 0.845rem; font-weight: 500;
            transition: color var(--tr), background var(--tr);
        }
        .nav-link:hover { color: #fff; background: rgba(255,255,255,0.06); }
        .nav-link.active { color: var(--ocean-aqua); background: rgba(23,170,184,0.1); }

        .nav-link .nav-icon, .nav-group-trigger .nav-icon {
            width: 30px; height: 30px; border-radius: var(--radius-sm);
            background: rgba(255,255,255,0.07);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem; flex-shrink: 0;
            transition: background var(--tr), color var(--tr);
        }
        .nav-link:hover .nav-icon, .nav-link.active .nav-icon,
        .nav-group-trigger:hover .nav-icon, .nav-group-trigger.is-open .nav-icon {
            background: rgba(23,170,184,0.22); color: var(--ocean-aqua);
        }

        .nav-group-trigger {
            display: flex; align-items: center; gap: 0.7rem;
            padding: 0.6rem 1.4rem;
            color: rgba(255,255,255,0.65); font-size: 0.845rem; font-weight: 500;
            cursor: pointer; user-select: none;
            transition: color var(--tr), background var(--tr);
        }
        .nav-group-trigger:hover { color: #fff; background: rgba(255,255,255,0.06); }
        .nav-group-trigger.is-open { color: var(--ocean-aqua); }
        .nav-group-trigger .arrow {
            margin-left: auto; font-size: 0.62rem; opacity: 0.45;
            transition: transform 0.25s ease;
        }
        .nav-group-trigger.is-open .arrow { transform: rotate(180deg); }

        .nav-group-items { max-height: 0; overflow: hidden; transition: max-height 0.28s ease; }
        .nav-group-items.is-open { max-height: 400px; }
        .nav-group-items a {
            display: flex; align-items: center; gap: 0.45rem;
            padding: 0.48rem 1.4rem 0.48rem 3.2rem;
            font-size: 0.81rem; color: rgba(255,255,255,0.52);
            transition: color var(--tr), background var(--tr);
            border-left: 2px solid transparent;
        }
        .nav-group-items a::before {
            content: ''; width: 4px; height: 4px; border-radius: 50%;
            background: currentColor; opacity: 0.5; flex-shrink: 0;
        }
        .nav-group-items a:hover { color: rgba(255,255,255,0.88); background: rgba(255,255,255,0.04); }
        .nav-group-items a.active {
            color: var(--ocean-aqua); border-left-color: var(--ocean-aqua);
            background: rgba(23,170,184,0.07);
        }

        /* Sidebar footer */
        .sidebar-footer {
            padding: 0.85rem 1.1rem;
            border-top: 1px solid rgba(255,255,255,0.07); flex-shrink: 0;
        }
        .admin-card {
            display: flex; align-items: center; gap: 0.65rem;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.09);
            border-radius: var(--radius-lg); padding: 0.75rem 0.9rem;
        }
        .admin-avatar {
            width: 34px; height: 34px; border-radius: 50%;
            background: linear-gradient(135deg, var(--ocean-aqua), var(--accent-gold));
            display: flex; align-items: center; justify-content: center;
            font-size: 0.78rem; font-weight: 700; color: var(--ocean-deep); flex-shrink: 0;
        }
        .admin-info { flex: 1; min-width: 0; }
        .admin-name {
            font-size: 0.8rem; font-weight: 600; color: #fff;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .admin-role { font-size: 0.64rem; color: var(--ocean-aqua); letter-spacing: 0.05em; }

        /* ══════════════ TOPBAR ══════════════ */
        .topbar {
            position: fixed; top: 0; left: 0; right: 0;
            height: var(--header-h); background: #071829;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 1.5rem 0 calc(var(--sidebar-w) + 1.5rem);
            z-index: 300;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            box-shadow: 0 2px 24px rgba(0,0,0,0.35);
        }
        .topbar-left { display: flex; align-items: center; gap: 1rem; }
        .topbar-search {
            display: flex; align-items: center; gap: 0.5rem;
            background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
            border-radius: 24px; padding: 0.33rem 1rem; transition: background var(--tr);
        }
        .topbar-search:focus-within { background: rgba(255,255,255,0.1); }
        .topbar-search i { color: rgba(255,255,255,0.38); font-size: 0.78rem; }
        .topbar-search input {
            background: none; border: none; outline: none;
            color: #fff; font-family: 'DM Sans', sans-serif; font-size: 0.84rem; width: 210px;
        }
        .topbar-search input::placeholder { color: rgba(255,255,255,0.3); }

        .topbar-right { display: flex; align-items: center; gap: 0.75rem; }
        .topbar-btn {
            position: relative; width: 36px; height: 36px; border-radius: 50%;
            background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.09);
            display: flex; align-items: center; justify-content: center;
            color: rgba(255,255,255,0.6); font-size: 0.84rem; text-decoration: none;
            transition: background var(--tr), color var(--tr);
        }
        .topbar-btn:hover { background: var(--ocean-teal); color: #fff; }
        .badge {
            position: absolute; top: -3px; right: -3px;
            min-width: 16px; height: 16px; padding: 0 3px; border-radius: 8px;
            background: var(--accent-coral); font-size: 0.58rem; font-weight: 700;
            color: #fff; display: flex; align-items: center; justify-content: center;
            border: 2px solid #071829;
        }

        .topbar-datetime {
            font-size: 0.78rem; color: rgba(255,255,255,0.38);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 20px; padding: 0.25rem 0.85rem;
            display: flex; align-items: center; gap: 0.4rem;
        }
        .topbar-datetime i { color: var(--ocean-aqua); font-size: 0.7rem; }

        .topbar-user-wrap { position: relative; }
        .topbar-user {
            display: flex; align-items: center; gap: 0.55rem;
            padding: 0.28rem 0.8rem; border-radius: 24px;
            background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1);
            cursor: pointer; transition: background var(--tr);
        }
        .topbar-user:hover { background: rgba(255,255,255,0.12); }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: linear-gradient(135deg, var(--ocean-aqua), var(--accent-gold));
            display: flex; align-items: center; justify-content: center;
            font-size: 0.72rem; font-weight: 700; color: var(--ocean-deep);
        }
        .user-name { font-size: 0.82rem; font-weight: 500; color: rgba(255,255,255,0.82); }
        .user-chevron { font-size: 0.58rem; color: rgba(255,255,255,0.35); }

        .user-dropdown {
            position: absolute; top: calc(100% + 8px); right: 0;
            background: #0b2240; border: 1px solid rgba(255,255,255,0.12);
            border-radius: var(--radius-md); min-width: 190px;
            box-shadow: 0 12px 32px rgba(0,0,0,0.5); overflow: hidden;
            display: none; z-index: 500;
        }
        .user-dropdown.open { display: block; }
        .user-dropdown a, .user-dropdown button {
            display: flex; align-items: center; gap: 0.6rem;
            padding: 0.65rem 1rem; font-size: 0.82rem; color: rgba(255,255,255,0.7);
            width: 100%; background: none; border: none; text-align: left;
            transition: background var(--tr), color var(--tr);
        }
        .user-dropdown a:hover, .user-dropdown button:hover { background: rgba(255,255,255,0.07); color: #fff; }
        .user-dropdown-divider { height: 1px; background: rgba(255,255,255,0.07); margin: 0.25rem 0; }
        .user-dropdown .logout-btn { color: rgba(255,107,107,0.8); }
        .user-dropdown .logout-btn:hover { color: #ff6b6b; background: rgba(255,107,107,0.08); }

        /* ══════════════ MAIN ══════════════ */
        .main-wrapper {
            margin-left: var(--sidebar-w); margin-top: var(--header-h);
            width: calc(100% - var(--sidebar-w));
            min-height: calc(100vh - var(--header-h));
            display: flex; flex-direction: column;
        }
        .main-content { flex: 1; padding: 2rem 2.25rem; }

        /* ══ Shared page utilities (dùng trong mọi view) ══ */
        .page-header {
            display: flex; align-items: flex-start; justify-content: space-between;
            margin-bottom: 1.85rem; flex-wrap: wrap; gap: 1rem;
        }
        .page-greeting {
            font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em;
            text-transform: uppercase; color: var(--ocean-aqua); margin-bottom: 0.2rem;
        }
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.85rem; font-weight: 700; color: #fff; line-height: 1.2;
        }
        .page-title span { color: var(--ocean-aqua); }
        .page-subtitle { font-size: 0.83rem; color: rgba(255,255,255,0.38); margin-top: 0.25rem; }
        .page-actions { display: flex; align-items: center; gap: 0.65rem; }

        .btn-primary {
            display: inline-flex; align-items: center; gap: 0.45rem;
            padding: 0.52rem 1.15rem; border-radius: 22px;
            background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
            border: none; color: #fff; font-size: 0.83rem; font-weight: 600;
            box-shadow: 0 4px 16px rgba(23,170,184,0.35);
            transition: opacity var(--tr), transform var(--tr);
        }
        .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }

        .btn-ghost {
            display: inline-flex; align-items: center; gap: 0.45rem;
            padding: 0.52rem 1.1rem; border-radius: 22px;
            background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.65); font-size: 0.83rem;
            transition: background var(--tr), color var(--tr);
        }
        .btn-ghost:hover { background: rgba(255,255,255,0.11); color: #fff; }

        .btn-danger {
            display: inline-flex; align-items: center; gap: 0.45rem;
            padding: 0.52rem 1.1rem; border-radius: 22px;
            background: rgba(255,107,107,0.12); border: 1px solid rgba(255,107,107,0.25);
            color: var(--accent-coral); font-size: 0.83rem;
            transition: background var(--tr), color var(--tr);
        }
        .btn-danger:hover { background: rgba(255,107,107,0.22); color: #fff; }

        /* Card */
        .card {
            background: var(--card-bg); border: 1px solid var(--card-border);
            border-radius: var(--radius-lg); padding: 1.35rem 1.5rem;
        }
        .card-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 1.1rem;
        }
        .card-title { font-size: 0.88rem; font-weight: 600; color: rgba(255,255,255,0.88); }
        .card-subtitle { font-size: 0.72rem; color: rgba(255,255,255,0.32); margin-top: 0.1rem; }

        /* Table */
        .table-card {
            background: var(--card-bg); border: 1px solid var(--card-border);
            border-radius: var(--radius-lg); overflow: hidden;
        }
        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th {
            font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
            text-transform: uppercase; color: rgba(255,255,255,0.28);
            padding: 0.7rem 1.5rem; text-align: left;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            background: rgba(255,255,255,0.02);
        }
        .data-table td {
            padding: 0.75rem 1.5rem; font-size: 0.82rem;
            color: rgba(255,255,255,0.72);
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }
        .data-table tr:last-child td { border-bottom: none; }
        .data-table tr:hover td { background: rgba(255,255,255,0.025); }
        .td-bold { font-weight: 600; color: rgba(255,255,255,0.9); }
        .td-mono { font-family: monospace; font-size: 0.78rem; color: var(--ocean-foam); }

        /* Status pills */
        .status-pill {
            display: inline-flex; align-items: center; gap: 0.3rem;
            padding: 0.18rem 0.65rem; border-radius: 20px; font-size: 0.7rem; font-weight: 600;
        }
        .status-pill::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
        .pill-green  { background: rgba(93,232,168,0.12);  color: var(--accent-green); }
        .pill-yellow { background: rgba(240,180,41,0.12);  color: var(--accent-gold);  }
        .pill-red    { background: rgba(255,107,107,0.12); color: var(--accent-coral); }
        .pill-blue   { background: rgba(23,170,184,0.12);  color: var(--ocean-aqua);   }

        /* Form elements */
        .form-group { margin-bottom: 1rem; }
        .form-label {
            display: block; font-size: 0.68rem; font-weight: 600;
            color: rgba(255,255,255,0.45); letter-spacing: 0.07em;
            text-transform: uppercase; margin-bottom: 0.32rem;
        }
        .form-control {
            width: 100%; background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;
            padding: 0.6rem 1rem; color: #fff;
            font-family: 'DM Sans', sans-serif; font-size: 0.875rem; outline: none;
            transition: border-color var(--tr), background var(--tr);
        }
        .form-control::placeholder { color: rgba(255,255,255,0.24); }
        .form-control:focus { border-color: var(--ocean-aqua); background: rgba(23,170,184,0.06); }
        select.form-control { appearance: none; -webkit-appearance: none; }

        /* Sidebar overlay */
        .sidebar-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.55); z-index: 350; backdrop-filter: blur(2px);
        }
        .menu-toggle {
            display: none; background: none; border: none;
            color: rgba(255,255,255,0.8); font-size: 1.15rem; padding: 0.2rem 0.4rem;
        }

        /* ══ RESPONSIVE ══ */
        @@media (max-width: 1024px) {
            .menu-toggle { display: block; }
            .topbar { padding-left: 1.25rem; }
            .sidebar { transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.4,0,0.2,1); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main-wrapper { margin-left: 0; width: 100%; }
        }
        @@media (max-width: 640px) {
            .topbar-search, .topbar-datetime { display: none; }
            .main-content { padding: 1.25rem; }
        }
    </style>
</head>
<body>

    <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
    <aside class="sidebar" id="sidebar">
        <a class="sidebar-brand" asp-area="" asp-controller="Admin" asp-action="Dashboard">
            <div class="brand-icon"><i class="fa-solid fa-shield-halved"></i></div>
            <div class="brand-text">
                <span class="brand-name">SkyWave</span>
                <span class="brand-sub">Admin Panel</span>
            </div>
        </a>

        <nav class="sidebar-nav">

            <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Dashboard">
                <span class="nav-icon"><i class="fa-solid fa-gauge-high"></i></span> Dashboard
            </a>

            <div class="nav-label">User Management</div>
            <a class="nav-link" asp-area="" asp-controller="Admin" asp-action="ManageUsers">
                <span class="nav-icon"><i class="fa-solid fa-users-gear"></i></span> Manage User Account
            </a>

            <div class="nav-label">Ticketing</div>
            <div class="nav-group">
                <div class="nav-group-trigger" onclick="toggleGroup(this)">
                    <span class="nav-icon"><i class="fa-solid fa-ticket"></i></span>
                    Tickets <i class="fa-solid fa-chevron-down arrow"></i>
                </div>
                <div class="nav-group-items">
                    <a asp-area="" asp-controller="Admin" asp-action="TicketStatuses">Manage Ticket Statuses</a>
                    <a asp-area="" asp-controller="Admin" asp-action="ConfirmTicket">Confirm Ticket</a>
                    <a asp-area="" asp-controller="Admin" asp-action="TicketClasses">Manage Ticket Classes</a>
                </div>
            </div>

            <div class="nav-label">Flight Operations</div>
            <div class="nav-group">
                <div class="nav-group-trigger" onclick="toggleGroup(this)">
                    <span class="nav-icon"><i class="fa-solid fa-plane"></i></span>
                    Flights <i class="fa-solid fa-chevron-down arrow"></i>
                </div>
                <div class="nav-group-items">
                    <a asp-area="" asp-controller="Admin" asp-action="ManageFlights">Manage Flights</a>
                    <a asp-area="" asp-controller="Admin" asp-action="FlightManagement">Set Flight Management</a>
                    <a asp-area="" asp-controller="Admin" asp-action="FlightSchedules">Manage Flight Schedules</a>
                    <a asp-area="" asp-controller="Admin" asp-action="FlightReschedule">Manage Flight Reschedule</a>
                    <a asp-area="" asp-controller="Admin" asp-action="FlightSeats">Manage Flight Seats</a>
                    <a asp-area="" asp-controller="Admin" asp-action="FlightNotifications">Manage Flight Notifications</a>
                </div>
            </div>

            <div class="nav-group">
                <div class="nav-group-trigger" onclick="toggleGroup(this)">
                    <span class="nav-icon"><i class="fa-solid fa-route"></i></span>
                    Routes & Cities <i class="fa-solid fa-chevron-down arrow"></i>
                </div>
                <div class="nav-group-items">
                    <a asp-area="" asp-controller="Admin" asp-action="ManageRoutes">Manage Routes</a>
                    <a asp-area="" asp-controller="Admin" asp-action="ManageCity">Manage City</a>
                </div>
            </div>

            <div class="nav-label">Commerce</div>
            <div class="nav-group">
                <div class="nav-group-trigger" onclick="toggleGroup(this)">
                    <span class="nav-icon"><i class="fa-solid fa-tags"></i></span>
                    Promotions & Baggage <i class="fa-solid fa-chevron-down arrow"></i>
                </div>
                <div class="nav-group-items">
                    <a asp-area="" asp-controller="Admin" asp-action="ManagePromotions">Manage Promotions</a>
                    <a asp-area="" asp-controller="Admin" asp-action="ManageBaggage">Manage Baggage</a>
                </div>
            </div>

        </nav>

        <div class="sidebar-footer">
            <div class="admin-card">
                <div class="admin-avatar">@initials</div>
                <div class="admin-info">
                    <div class="admin-name">@displayName</div>
                    <div class="admin-role">Super Administrator</div>
                </div>
            </div>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <!-- ═══════════════════ TOPBAR ═══════════════════ -->
    <header class="topbar">
        <div class="topbar-left">
            <button class="menu-toggle" onclick="openSidebar()"><i class="fa-solid fa-bars"></i></button>
            <div class="topbar-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Search users, flights, routes..." />
            </div>
        </div>
        <div class="topbar-right">
            <div class="topbar-datetime">
                <i class="fa-regular fa-clock"></i> <span id="clockVal">--:--</span>
            </div>
            <a class="topbar-btn" href="#" title="Alerts">
                <i class="fa-solid fa-bell"></i>
                <span class="badge">5</span>
            </a>
            <a class="topbar-btn" href="#" title="Messages">
                <i class="fa-solid fa-envelope"></i>
                <span class="badge">2</span>
            </a>
            <div class="topbar-user-wrap">
                <div class="topbar-user" onclick="toggleUserDropdown()">
                    <div class="user-avatar">@initials</div>
                    <span class="user-name">@displayName</span>
                    <i class="fa-solid fa-chevron-down user-chevron"></i>
                </div>
                <div class="user-dropdown" id="userDropdown">
                    <a href="#"><i class="fa-solid fa-user-pen"></i> Edit Profile</a>
                    <a href="#"><i class="fa-solid fa-key"></i> Change Password</a>
                    <a href="#"><i class="fa-solid fa-gear"></i> Settings</a>
                    <div class="user-dropdown-divider"></div>
                    <a asp-controller="Auth" asp-action="Logout" class="logout-btn">
                        <i class="fa-solid fa-right-from-bracket"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
    <div class="main-wrapper">
        <main class="main-content" role="main">
            @RenderBody()
        </main>
    </div>

    <script>
        /* ── Clock ── */
        function updateClock() {
            document.getElementById('clockVal').textContent =
                new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
        }
        updateClock(); setInterval(updateClock, 1000);

        /* ── Sidebar ── */
        function toggleGroup(trigger) {
            const items = trigger.nextElementSibling;
            const isOpen = items.classList.contains('is-open');
            document.querySelectorAll('.nav-group-items.is-open').forEach(el => el.classList.remove('is-open'));
            document.querySelectorAll('.nav-group-trigger.is-open').forEach(el => el.classList.remove('is-open'));
            if (!isOpen) { items.classList.add('is-open'); trigger.classList.add('is-open'); }
        }
        function openSidebar() {
            document.getElementById('sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('open');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('open');
        }

        /* ── User dropdown ── */
        function toggleUserDropdown() {
            document.getElementById('userDropdown').classList.toggle('open');
        }
        document.addEventListener('click', e => {
            const wrap = document.querySelector('.topbar-user-wrap');
            if (wrap && !wrap.contains(e.target)) document.getElementById('userDropdown').classList.remove('open');
        });

        /* ── Auto active nav link ── */
        document.addEventListener('DOMContentLoaded', () => {
            const path = window.location.pathname.toLowerCase();
            document.querySelectorAll('.nav-link, .nav-group-items a').forEach(link => {
                const href = link.getAttribute('href');
                if (href && path.includes(href.toLowerCase()) && href !== '/') {
                    link.classList.add('active');
                    const items = link.closest('.nav-group-items');
                    if (items) {
                        items.classList.add('is-open');
                        items.previousElementSibling?.classList.add('is-open');
                    }
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
