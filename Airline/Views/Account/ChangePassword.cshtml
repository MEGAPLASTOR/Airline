@{
    ViewData["Title"] = "Change Password";
    Layout = "_Layout";
}

@*
@section Styles {
<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .page-header-icon {
        width: 48px; height: 48px;
        border-radius: var(--radius-md);
        background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 1.15rem;
        box-shadow: 0 6px 20px rgba(23,170,184,0.35);
        flex-shrink: 0;
    }
    .page-header-text h1 {
        font-family: 'Playfair Display', serif;
        font-size: 1.55rem; font-weight: 700;
        color: var(--ocean-deep); line-height: 1.2;
    }
    .page-header-text p { font-size: 0.83rem; color: #6b8394; margin-top: 0.2rem; }
    .breadcrumb {
        display: flex; align-items: center; gap: 0.4rem;
        font-size: 0.78rem; color: #8ba5b4; margin-bottom: 1.5rem;
    }
    .breadcrumb a { color: var(--ocean-teal); }
    .breadcrumb a:hover { opacity: 0.75; }
    .breadcrumb i { font-size: 0.6rem; opacity: 0.5; }
    .card {
        background: #fff; border-radius: var(--radius-lg);
        border: 1px solid rgba(10,35,66,0.07);
        box-shadow: 0 2px 20px rgba(10,35,66,0.05); overflow: hidden;
    }
    .card-header {
        padding: 1.25rem 1.75rem; border-bottom: 1px solid rgba(10,35,66,0.06);
        display: flex; align-items: center; gap: 0.6rem;
    }
    .card-header i { color: var(--ocean-teal); font-size: 0.95rem; }
    .card-header-title { font-size: 0.88rem; font-weight: 600; color: var(--ocean-deep); }
    .card-body { padding: 1.75rem; }
    .form-grid { display: grid; gap: 1.1rem; max-width: 480px; }
    .form-field label {
        display: block; font-size: 0.68rem; font-weight: 700;
        letter-spacing: 0.07em; text-transform: uppercase;
        color: #7a96a8; margin-bottom: 0.35rem;
    }
    .inp-wrap { position: relative; display: flex; align-items: center; }
    .inp-wrap > i:first-child {
        position: absolute; left: 0.85rem;
        color: #a8bfcc; font-size: 0.78rem; pointer-events: none;
    }
    .form-inp {
        width: 100%;
        padding: 0.6rem 2.5rem 0.6rem 2.25rem;
        border: 1.5px solid #dce8ef; border-radius: 10px;
        font-family: 'DM Sans', sans-serif; font-size: 0.875rem;
        color: var(--text-dark); background: #f7fbfd; outline: none;
        transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    }
    .form-inp::placeholder { color: #b5cdd8; }
    .form-inp:focus {
        border-color: var(--ocean-aqua); background: #fff;
        box-shadow: 0 0 0 3px rgba(23,170,184,0.12);
    }
    .form-inp.err { border-color: #ff6b6b; box-shadow: 0 0 0 3px rgba(255,107,107,0.1); }
    .eye-btn {
        position: absolute; right: 0.75rem;
        background: none; border: none; color: #a8bfcc; font-size: 0.78rem;
        cursor: pointer; padding: 0.2rem; transition: color 0.2s;
    }
    .eye-btn:hover { color: var(--ocean-teal); }
    .strength-bar { height: 3px; background: #e8f2f6; border-radius: 2px; margin-top: 0.45rem; overflow: hidden; }
    .strength-fill { height: 100%; width: 0; border-radius: 2px; transition: width 0.3s, background 0.3s; }
    .strength-lbl { font-size: 0.67rem; color: #9ab4c0; margin-top: 0.2rem; display: block; }
    .password-rules {
        background: #f0f8fa; border: 1px solid #cde8ef;
        border-radius: var(--radius-sm); padding: 0.85rem 1rem; margin-top: 0.15rem;
    }
    .password-rules p { font-size: 0.72rem; font-weight: 600; color: #5a8295; margin-bottom: 0.45rem; text-transform: uppercase; letter-spacing: 0.07em; }
    .rule { display: flex; align-items: center; gap: 0.45rem; font-size: 0.78rem; color: #7a9aaa; margin-bottom: 0.25rem; transition: color 0.2s; }
    .rule i { font-size: 0.65rem; width: 14px; text-align: center; transition: color 0.2s; }
    .rule.ok { color: #2ecc8e; }
    .rule.ok i { color: #2ecc8e; }
    .rule.fail i { color: #ff6b6b; }
    .form-alert {
        display: none; align-items: center; gap: 0.5rem;
        padding: 0.6rem 0.9rem; border-radius: 9px; font-size: 0.81rem; margin-bottom: 0.5rem;
    }
    .form-alert.show { display: flex; }
    .form-alert-err { background: rgba(255,107,107,0.08); border: 1px solid rgba(255,107,107,0.22); color: #e05555; }
    .form-alert-ok { background: rgba(46,204,142,0.08); border: 1px solid rgba(46,204,142,0.22); color: #1faa6e; }
    .form-actions { display: flex; gap: 0.75rem; align-items: center; margin-top: 0.5rem; }
    .btn-primary {
        display: inline-flex; align-items: center; gap: 0.45rem;
        padding: 0.62rem 1.5rem; border-radius: 10px; border: none;
        background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
        color: #fff; font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 600;
        cursor: pointer; box-shadow: 0 4px 16px rgba(23,170,184,0.32);
        transition: opacity 0.2s, transform 0.2s;
    }
    .btn-primary:hover:not(:disabled) { opacity: 0.88; transform: translateY(-1px); }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-ghost {
        display: inline-flex; align-items: center; gap: 0.45rem;
        padding: 0.62rem 1.2rem; border-radius: 10px;
        border: 1.5px solid #dce8ef; background: #fff; color: #6b8394;
        font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 500;
        cursor: pointer; text-decoration: none; transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
    .btn-ghost:hover { border-color: var(--ocean-aqua); color: var(--ocean-teal); background: #f0f8fa; }
    .tip-item { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.8rem; color: #5a8295; margin-bottom: 0.45rem; }
    .tip-item i { margin-top: 2px; color: var(--ocean-aqua); font-size: 0.72rem; flex-shrink: 0; }
    .two-col { display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; align-items: start; max-width: 880px; }
    @@media (max-width: 768px) { .two-col { grid-template-columns: 1fr; } }
</style>
}
*@

<div class="public-page public-page-account">
<div class="breadcrumb">
    <a href="/">Home</a>
    <i class="fa-solid fa-chevron-right"></i>
    <span>Account</span>
    <i class="fa-solid fa-chevron-right"></i>
    <span>Change Password</span>
</div>

<div class="page-header">
    <div class="page-header-icon"><i class="fa-solid fa-key"></i></div>
    <div class="page-header-text">
        <h1>Change Password</h1>
        <p>Update your account password to keep it secure</p>
    </div>
</div>

<div class="two-col">

    <!-- Main card -->
    <div class="card">
        <div class="card-header">
            <i class="fa-solid fa-shield-halved"></i>
            <span class="card-header-title">Password Settings</span>
        </div>
        <div class="card-body">
            <div class="form-alert form-alert-err" id="cpErr"></div>
            <div class="form-alert form-alert-ok" id="cpOk"></div>
            <div class="form-grid">

                <div class="form-field">
                    <label>Current Password</label>
                    <div class="inp-wrap">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" id="cpCurrent" class="form-inp" placeholder="Enter current password" autocomplete="current-password" />
                        <button type="button" class="eye-btn" onclick="togglePwEye('cpCurrent',this)"><i class="fa-solid fa-eye"></i></button>
                    </div>
                </div>

                <div class="form-field">
                    <label>New Password</label>
                    <div class="inp-wrap">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" id="cpNew" class="form-inp" placeholder="Min 6 characters" autocomplete="new-password" oninput="onNewPw(this.value)" />
                        <button type="button" class="eye-btn" onclick="togglePwEye('cpNew',this)"><i class="fa-solid fa-eye"></i></button>
                    </div>
                    <div class="strength-bar"><div class="strength-fill" id="cpStrengthFill"></div></div>
                    <small class="strength-lbl" id="cpStrengthLbl"></small>
                </div>

                <div class="form-field">
                    <label>Confirm New Password</label>
                    <div class="inp-wrap">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" id="cpConfirm" class="form-inp" placeholder="Repeat new password" autocomplete="new-password" />
                        <button type="button" class="eye-btn" onclick="togglePwEye('cpConfirm',this)"><i class="fa-solid fa-eye"></i></button>
                    </div>
                </div>

                <div class="password-rules">
                    <p><i class="fa-solid fa-shield-check" style="margin-right:5px;"></i>Password requirements</p>
                    <div class="rule" id="rLen"><i class="fa-solid fa-circle-xmark"></i> At least 6 characters</div>
                    <div class="rule" id="rUpper"><i class="fa-solid fa-circle-xmark"></i> One uppercase letter</div>
                    <div class="rule" id="rNum"><i class="fa-solid fa-circle-xmark"></i> One number</div>
                    <div class="rule" id="rSpecial"><i class="fa-solid fa-circle-xmark"></i> One special character</div>
                </div>

                <div class="form-actions">
                    <button class="btn-primary" id="cpBtn" onclick="doChangePassword()">
                        <i class="fa-solid fa-key"></i> Update Password
                    </button>
                    <a href="/" class="btn-ghost"><i class="fa-solid fa-xmark"></i> Cancel</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Side panel -->
    <div class="side-stack">
        <div class="card tips-card">
            <div class="tips-head">
                <div class="tips-icon"><i class="fa-solid fa-lightbulb"></i></div>
                <div class="tips-title">Security Tips</div>
            </div>
            <div class="tip-item"><i class="fa-solid fa-check-circle"></i> Use a mix of letters, numbers &amp; symbols</div>
            <div class="tip-item"><i class="fa-solid fa-check-circle"></i> Avoid using your name or birthday</div>
            <div class="tip-item"><i class="fa-solid fa-check-circle"></i> Don't reuse passwords from other accounts</div>
            <div class="tip-item"><i class="fa-solid fa-check-circle"></i> Change your password every 3–6 months</div>
            <div class="tip-item"><i class="fa-solid fa-check-circle"></i> Never share your password with anyone</div>
        </div>

        <div class="card warning-note">
            <div class="note-head">
                <div class="note-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
                <div class="note-title">Note</div>
            </div>
            <p>After changing your password, all other active sessions will be signed out automatically.</p>
        </div>
    </div>

</div>

</div>

@section Scripts {
<script>
    function togglePwEye(id, btn) {
        const inp = document.getElementById(id);
        const show = inp.type === 'password';
        inp.type = show ? 'text' : 'password';
        btn.querySelector('i').className = show ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye';
    }
    function setRule(id, ok) {
        const el = document.getElementById(id);
        el.className = 'rule ' + (ok ? 'ok' : 'fail');
        el.querySelector('i').className = ok ? 'fa-solid fa-circle-check' : 'fa-solid fa-circle-xmark';
    }
    function onNewPw(v) {
        setRule('rLen', v.length >= 6);
        setRule('rUpper', /[A-Z]/.test(v));
        setRule('rNum', /[0-9]/.test(v));
        setRule('rSpecial', /[^A-Za-z0-9]/.test(v));
        let s = 0;
        if (v.length >= 6) s++; if (v.length >= 10) s++;
        if (/[A-Z]/.test(v)) s++; if (/[0-9]/.test(v)) s++; if (/[^A-Za-z0-9]/.test(v)) s++;
        const lv = [
            { w: '20%', c: '#ff6b6b', t: 'Weak' },
            { w: '40%', c: '#ff9f43', t: 'Fair' },
            { w: '60%', c: '#feca57', t: 'Good' },
            { w: '80%', c: '#48dbfb', t: 'Strong' },
            { w: '100%', c: '#5de8a8', t: 'Very Strong' },
        ];
        const l = lv[Math.min(s - 1, 4)] || { w: '0%', c: '', t: '' };
        document.getElementById('cpStrengthFill').style.width = v ? l.w : '0%';
        document.getElementById('cpStrengthFill').style.background = l.c;
        document.getElementById('cpStrengthLbl').textContent = v ? l.t : '';
    }
    function showCpAlert(id, msg, type) {
        ['cpErr', 'cpOk'].forEach(i => document.getElementById(i).classList.remove('show'));
        const el = document.getElementById(id);
        el.className = 'form-alert ' + (type === 'ok' ? 'form-alert-ok' : 'form-alert-err') + ' show';
        el.innerHTML = `<i class="fa-solid fa-${type === 'ok' ? 'circle-check' : 'circle-exclamation'}"></i> ${msg}`;
    }
    function setCpBtn(loading) {
        const btn = document.getElementById('cpBtn');
        btn.disabled = loading;
        btn.innerHTML = loading
            ? `<i class="fa-solid fa-spinner fa-spin"></i> Updating...`
            : `<i class="fa-solid fa-key"></i> Update Password`;
    }
    async function doChangePassword() {
        const current = document.getElementById('cpCurrent').value;
        const newPw = document.getElementById('cpNew').value;
        const confirm = document.getElementById('cpConfirm').value;
        if (!current || !newPw || !confirm) { showCpAlert('cpErr', 'Please fill in all fields.'); return; }
        if (newPw.length < 6) { showCpAlert('cpErr', 'New password must be at least 6 characters.'); return; }
        if (newPw !== confirm) { showCpAlert('cpErr', 'Passwords do not match.'); return; }
        setCpBtn(true);
        try {
            const res = await fetch('/Account/ChangePassword', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify({ currentPassword: current, newPassword: newPw })
            });
            const json = await res.json().catch(() => null);
            if (json && json.success) {
                showCpAlert('cpOk', 'Password updated successfully! Redirecting...', 'ok');
                setTimeout(() => window.location.href = '/', 1500);
            } else {
                showCpAlert('cpErr', json?.message || 'Failed to update. Please check your current password.');
                setCpBtn(false);
            }
        } catch {
            showCpAlert('cpErr', 'Network error. Please try again.');
            setCpBtn(false);
        }
    }
</script>
}
