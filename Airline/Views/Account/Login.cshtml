@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap');

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'Be Vietnam Pro', sans-serif;
        background: #0d0d0d;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-wrapper {
        position: relative;
        width: 100%;
        max-width: 420px;
        padding: 20px;
    }

    /* Glowing blobs */
    .blob {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.25;
        pointer-events: none;
        z-index: 0;
    }
    .blob-1 { width: 400px; height: 400px; background: #4f46e5; top: -100px; left: -150px; }
    .blob-2 { width: 300px; height: 300px; background: #0ea5e9; bottom: -50px; right: -100px; }

    .login-card {
        position: relative;
        z-index: 1;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 44px 40px;
        backdrop-filter: blur(20px);
        box-shadow: 0 25px 60px rgba(0,0,0,0.5);
        animation: fadeUp 0.5s ease both;
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .login-logo {
        width: 44px; height: 44px;
        background: linear-gradient(135deg, #4f46e5, #0ea5e9);
        border-radius: 12px;
        margin-bottom: 24px;
        display: flex; align-items: center; justify-content: center;
    }
    .login-logo svg { width: 22px; height: 22px; fill: #fff; }

    h1 {
        font-size: 1.6rem;
        font-weight: 700;
        color: #f0f0f0;
        letter-spacing: -0.4px;
        margin-bottom: 6px;
    }
    .subtitle {
        font-size: 0.875rem;
        color: #666;
        margin-bottom: 32px;
    }

    .form-group { margin-bottom: 18px; }

    label {
        display: block;
        font-size: 0.78rem;
        font-weight: 500;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        margin-bottom: 8px;
    }

    input[type="text"],
    input[type="password"] {
        width: 100%;
        padding: 12px 16px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        color: #f0f0f0;
        font-size: 0.95rem;
        font-family: inherit;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
    }
    input[type="text"]:focus,
    input[type="password"]:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79,70,229,0.2);
    }
    input::placeholder { color: #444; }

    .remember-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
    }
    .remember-row input[type="checkbox"] {
        width: 16px; height: 16px;
        accent-color: #4f46e5;
        cursor: pointer;
    }
    .remember-row label {
        font-size: 0.875rem;
        color: #777;
        text-transform: none;
        letter-spacing: 0;
        margin: 0;
        cursor: pointer;
    }

    .btn-login {
        width: 100%;
        padding: 13px;
        background: linear-gradient(135deg, #4f46e5, #0ea5e9);
        color: #fff;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: inherit;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        position: relative;
        overflow: hidden;
    }
    .btn-login:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-login:active { transform: translateY(0); }
    .btn-login:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-login .spinner {
        display: none;
        width: 18px; height: 18px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        margin: 0 auto;
    }
    .btn-login.loading .btn-text { display: none; }
    .btn-login.loading .spinner { display: block; }

    @@keyframes spin { to { transform: rotate(360deg); } }

    .error-msg {
        display: none;
        margin-top: 16px;
        padding: 12px 14px;
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.25);
        border-radius: 8px;
        color: #f87171;
        font-size: 0.875rem;
    }
    .error-msg.show { display: block; animation: fadeUp 0.3s ease; }

    .divider {
        border: none;
        border-top: 1px solid rgba(255,255,255,0.06);
        margin: 28px 0 20px;
    }
    .footer-links {
        text-align: center;
        font-size: 0.82rem;
        color: #555;
    }
    .footer-links a {
        color: #6366f1;
        text-decoration: none;
        font-weight: 500;
    }
    .footer-links a:hover { text-decoration: underline; }
</style>

<div class="blob blob-1"></div>
<div class="blob blob-2"></div>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-logo">
            <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        </div>

        <h1>Đăng nhập</h1>
        <p class="subtitle">Chào mừng trở lại! Vui lòng đăng nhập để tiếp tục.</p>

        <div class="form-group">
            <label for="username">Tên đăng nhập</label>
            <input type="text" id="username" placeholder="Nhập tên đăng nhập..." autocomplete="username" />
        </div>

        <div class="form-group">
            <label for="password">Mật khẩu</label>
            <input type="password" id="password" placeholder="••••••••" autocomplete="current-password" />
        </div>

        <div class="remember-row">
            <input type="checkbox" id="rememberMe" />
            <label for="rememberMe">Ghi nhớ đăng nhập</label>
        </div>

        <button class="btn-login" id="btnLogin" onclick="handleLogin()">
            <span class="btn-text">Đăng nhập</span>
            <span class="spinner"></span>
        </button>

        <div class="error-msg" id="errorMsg"></div>

        <hr class="divider" />
        <div class="footer-links">
            Chưa có tài khoản? <a href="/Account/Register">Đăng ký ngay</a>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Cho phép nhấn Enter để đăng nhập
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') handleLogin();
    });

    function showError(message) {
        const el = document.getElementById('errorMsg');
        el.textContent = message;
        el.classList.add('show');
    }

    function hideError() {
        document.getElementById('errorMsg').classList.remove('show');
    }

    async function handleLogin() {
        const username   = document.getElementById('username').value.trim();
        const password   = document.getElementById('password').value;
        const rememberMe = document.getElementById('rememberMe').checked;
        const btn        = document.getElementById('btnLogin');

        hideError();

        // Validate phía client
        if (!username || !password) {
            showError('Vui lòng nhập đầy đủ tên đăng nhập và mật khẩu.');
            return;
        }

        // Loading state
        btn.disabled = true;
        btn.classList.add('loading');

        try {
            const res = await fetch('/Auth/Login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, password, rememberMe })
            });

            const data = await res.json();

            if (data.success) {
                window.location.href = data.redirectUrl; // ✅ redirect đúng role
            } else {
                showError(data.message || 'Đăng nhập thất bại. Vui lòng thử lại.');
            }
        } catch (err) {
            showError('Không thể kết nối đến máy chủ. Vui lòng thử lại sau.');
        } finally {
            btn.disabled = false;
            btn.classList.remove('loading');
        }
    }
</script>
}
