@model IEnumerable<Airline.Models.Ticket>
@{
    ViewData["Title"] = "Vé Của Tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .ticket-container {
        padding: 2.5rem 2rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.4rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 2.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        animation: fadeInDown 0.8s ease-out;
    }

    .page-title span { color: var(--ocean-aqua); }

    .ticket-card {
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 2rem;
        margin-bottom: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        overflow: hidden;
    }

    .ticket-card:hover {
        transform: translateY(-8px);
        background: rgba(255, 255, 255, 0.07);
        border-color: var(--ocean-aqua);
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .ticket-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .flight-info {
        display: flex;
        align-items: center;
        gap: 2.5rem;
    }

    .city-group {
        text-align: left;
    }

    .city-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.2rem;
    }

    .city-label {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
        letter-spacing: 0.15em;
    }

    .flight-divider {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        width: 140px;
    }

    .flight-line {
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(23,170,184,0.5), transparent);
        width: 100%;
        position: relative;
    }

    .flight-line i {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: var(--ocean-aqua);
        font-size: 1.2rem;
        filter: drop-shadow(0 0 5px rgba(23,170,184,0.5));
    }

    .flight-num-badge {
        font-size: 0.8rem;
        background: rgba(23,170,184,0.1);
        color: var(--ocean-aqua);
        padding: 0.2rem 0.8rem;
        border-radius: 20px;
        font-weight: 700;
    }

    .flight-details {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 2rem;
        background: rgba(0, 0, 0, 0.2);
        padding: 1.8rem;
        border-radius: 20px;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .detail-label {
        font-size: 0.7rem;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 700;
    }

    .detail-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: #fff;
    }

    .status-badge {
        font-size: 0.75rem;
        font-weight: 800;
        padding: 0.5rem 1rem;
        border-radius: 10px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .status-confirmed, .status-booked, .status-paid {
        background: rgba(23, 184, 120, 0.15);
        color: #5de8a8;
        border: 1px solid rgba(23, 184, 120, 0.3);
    }

    .status-cancelled {
        background: rgba(255, 107, 107, 0.15);
        color: #ff8f8f;
        border: 1px solid rgba(255, 107, 107, 0.3);
    }

    .ticket-footer {
        display: flex;
        justify-content: flex-end;
        gap: 1.2rem;
        margin-top: 0.5rem;
    }

    .btn-action {
        padding: 1rem 1.8rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
    }

    .btn-pay {
        background: linear-gradient(135deg, var(--accent-gold), #f39c12);
        color: var(--ocean-deep);
        border: none;
        box-shadow: 0 4px 15px rgba(240, 180, 41, 0.3);
    }

    .btn-secondary {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
    }

    .btn-secondary:hover {
        background: rgba(255,255,255,0.1);
        border-color: var(--ocean-aqua);
    }

    .empty-state {
        text-align: center;
        padding: 6rem 2rem;
        background: rgba(255, 255, 255, 0.02);
        border: 2px dashed rgba(255, 255, 255, 0.05);
        border-radius: 32px;
    }

    .empty-icon {
        font-size: 4rem;
        color: rgba(255, 255, 255, 0.05);
        margin-bottom: 2rem;
    }

    .empty-text {
        font-size: 1.4rem;
        color: rgba(255, 255, 255, 0.3);
        margin-bottom: 2.5rem;
    }
</style>

<div class="ticket-container">
    <h1 class="page-title"><i class="fa-solid fa-ticket"></i> Vé Của <span>Tôi</span></h1>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fa-solid fa-plane-slash"></i></div>
            <div class="empty-text">Bạn chưa có đặt vé nào. Hãy bắt đầu hành trình của mình ngay!</div>
            <a asp-controller="Booking" asp-action="BookFlight" class="btn-action btn-pay" style="padding: 1.2rem 2.5rem;">
                <i class="fa-solid fa-paper-plane"></i> Tìm chuyến bay ngay
            </a>
        </div>
    }
    else
    {
        foreach (var ticket in Model)
        {
            var schedule = ticket.Booking.Schedule;
            var flight = schedule.Flight;
            var route = flight.Route;

            <div class="ticket-card">
                <div class="ticket-header">
                    <div class="flight-info">
                        <div class="city-group">
                            <div class="city-name">@route.DepartureCityNavigation.CityName</div>
                            <div class="city-label">Điểm đi</div>
                        </div>
                        <div class="flight-divider">
                            <div class="flight-line"><i class="fa-solid fa-plane"></i></div>
                            <span class="flight-num-badge">@flight.FlightNumber</span>
                        </div>
                        <div class="city-group">
                            <div class="city-name">@route.ArrivalCityNavigation.CityName</div>
                            <div class="city-label">Điểm đến</div>
                        </div>
                    </div>
                    <div class="status-badge status-@(ticket.Status.ToLower())">
                        @ticket.Status
                    </div>
                </div>

                <div class="flight-details">
                    <div class="detail-item">
                        <span class="detail-label">Hành khách</span>
                        <span class="detail-value">@(ticket.Passenger?.FullName ?? "N/A")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Thời gian khởi hành</span>
                        <span class="detail-value">@schedule.DepartureTime.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Chỗ ngồi</span>
                        <span class="detail-value" style="color: var(--ocean-aqua); font-weight: 800;">@(ticket.Seat?.SeatNumber ?? "Chưa có")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Hạng vé</span>
                        <span class="detail-value">@ticket.Class.ClassName</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Mã đặt chỗ</span>
                        <span class="detail-value">#@ticket.BookingId</span>
                    </div>
                </div>

                <div class="ticket-footer">
                    @if (ticket.Status != "PAID" && ticket.Status != "CANCELLED")
                    {
                        <a asp-controller="Payment" asp-action="CreatePayment" asp-route-id="@ticket.BookingId" class="btn-action btn-pay">
                            <i class="fa-solid fa-credit-card"></i> Thanh toán ngay
                        </a>

                        <a asp-controller="Ticket" asp-action="ChangeSeat" asp-route-id="@ticket.TicketId" class="btn-action btn-secondary">
                            <i class="fa-solid fa-chair"></i> Đổi chỗ ngồi
                        </a>
                    }
                    else if (ticket.Status == "PAID")
                    {
                        <div class="btn-action" style="background: rgba(23, 184, 120, 0.1); color: #5de8a8; border: 1px solid rgba(23, 184, 120, 0.2); cursor: default;">
                            <i class="fa-solid fa-check-double"></i> Đã thanh toán
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>
