@model IEnumerable<Airline.Models.Ticket>
@{
    ViewData["Title"] = "My Tickets";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .ticket-container {
        padding: 2.5rem 2rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.4rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 2.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        animation: fadeInDown 0.8s ease-out;
    }

    .page-title span { color: var(--ocean-aqua); }

    .ticket-card {
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 2rem;
        margin-bottom: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        overflow: hidden;
    }

    .ticket-card:hover {
        transform: translateY(-8px);
        background: rgba(255, 255, 255, 0.07);
        border-color: var(--ocean-aqua);
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .ticket-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .flight-info {
        display: flex;
        align-items: center;
        gap: 2.5rem;
    }

    .city-group {
        text-align: left;
    }

    .city-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.2rem;
    }

    .city-label {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
        letter-spacing: 0.15em;
    }

    .flight-divider {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        width: 140px;
    }

    .flight-line {
        height: 2px;
        background: linear-gradient(90deg, transparent, rgba(23,170,184,0.5), transparent);
        width: 100%;
        position: relative;
    }

    .flight-line i {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: var(--ocean-aqua);
        font-size: 1.2rem;
        filter: drop-shadow(0 0 5px rgba(23,170,184,0.5));
    }

    .flight-num-badge {
        font-size: 0.8rem;
        background: rgba(23,170,184,0.1);
        color: var(--ocean-aqua);
        padding: 0.2rem 0.8rem;
        border-radius: 20px;
        font-weight: 700;
    }

    .flight-details {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 2rem;
        background: rgba(0, 0, 0, 0.2);
        padding: 1.8rem;
        border-radius: 20px;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .detail-label {
        font-size: 0.7rem;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 700;
    }

    .detail-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: #fff;
    }

    .status-badge {
        font-size: 0.75rem;
        font-weight: 800;
        padding: 0.5rem 1rem;
        border-radius: 10px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .status-confirmed, .status-booked, .status-paid {
        background: rgba(23, 184, 120, 0.15);
        color: #5de8a8;
        border: 1px solid rgba(23, 184, 120, 0.3);
    }

    .status-cancelled {
        background: rgba(255, 107, 107, 0.15);
        color: #ff8f8f;
        border: 1px solid rgba(255, 107, 107, 0.3);
    }

    .ticket-footer {
        display: flex;
        justify-content: flex-end;
        gap: 1.2rem;
        margin-top: 0.5rem;
    }

    .btn-action {
        padding: 1rem 1.8rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        border: none;
    }

    .btn-action:disabled {
        opacity: 0.65;
        cursor: not-allowed;
    }

    .btn-pay {
        background: linear-gradient(135deg, var(--accent-gold), #f39c12);
        color: var(--ocean-deep);
        border: none;
        box-shadow: 0 4px 15px rgba(240, 180, 41, 0.3);
    }

    .btn-secondary {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
    }

    .btn-secondary:hover {
        background: rgba(255,255,255,0.1);
        border-color: var(--ocean-aqua);
    }

    .btn-danger {
        background: rgba(255, 107, 107, 0.12);
        border: 1px solid rgba(255, 107, 107, 0.28);
        color: #ffb3b3;
    }

    .btn-danger:hover {
        background: rgba(255, 107, 107, 0.18);
        border-color: rgba(255, 107, 107, 0.45);
    }

    .btn-muted {
        background: rgba(255,255,255,0.05);
        border: 1px dashed rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.55);
        cursor: default;
    }

    .ticket-footer form {
        margin: 0;
        display: inline-flex;
    }

    .empty-state {
        text-align: center;
        padding: 6rem 2rem;
        background: rgba(255, 255, 255, 0.02);
        border: 2px dashed rgba(255, 255, 255, 0.05);
        border-radius: 32px;
    }

    .empty-icon {
        font-size: 4rem;
        color: rgba(255, 255, 255, 0.05);
        margin-bottom: 2rem;
    }

    .empty-text {
        font-size: 1.4rem;
        color: rgba(255, 255, 255, 0.3);
        margin-bottom: 2.5rem;
    }
</style>

<div class="ticket-container">
    <h1 class="page-title"><i class="fa-solid fa-ticket"></i> My <span>Tickets</span></h1>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fa-solid fa-plane-slash"></i></div>
            <div class="empty-text">You do not have any bookings yet. Start your journey now.</div>
            <a asp-controller="Booking" asp-action="BookFlight" class="btn-action btn-pay" style="padding: 1.2rem 2.5rem;">
                <i class="fa-solid fa-paper-plane"></i> Find flights now
            </a>
        </div>
    }
    else
    {
        foreach (var ticket in Model)
        {
            var schedule = ticket.Booking.Schedule;
            var flight = schedule.Flight;
            var route = flight.Route;
            var normalizedStatus = (ticket.Status ?? string.Empty).ToUpperInvariant();
            var isCancelled = normalizedStatus == "CANCELLED";
            var isPaid = normalizedStatus == "PAID";
            var hasDeparted = schedule.DepartureTime <= DateTime.Now;
            var canPay = !isPaid && !isCancelled && !hasDeparted;
            var canChangeSeat = !isPaid && !isCancelled && !hasDeparted;
            var canCancel = !isCancelled && !hasDeparted;

            <div class="ticket-card">
                <div class="ticket-header">
                    <div class="flight-info">
                        <div class="city-group">
                            <div class="city-name">@route.DepartureCityNavigation.CityName</div>
                            <div class="city-label">Origin</div>
                        </div>
                        <div class="flight-divider">
                            <div class="flight-line"><i class="fa-solid fa-plane"></i></div>
                            <span class="flight-num-badge">@flight.FlightNumber</span>
                        </div>
                        <div class="city-group">
                            <div class="city-name">@route.ArrivalCityNavigation.CityName</div>
                            <div class="city-label">Destination</div>
                        </div>
                    </div>
                    <div class="status-badge status-@((ticket.Status ?? "booked").ToLowerInvariant())">
                        @ticket.Status
                    </div>
                </div>

                <div class="flight-details">
                    <div class="detail-item">
                        <span class="detail-label">Passenger</span>
                        <span class="detail-value">@(ticket.Passenger?.FullName ?? "N/A")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Departure Time</span>
                        <span class="detail-value">@schedule.DepartureTime.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Seat</span>
                        <span class="detail-value" style="color: var(--ocean-aqua); font-weight: 800;">@(ticket.Seat?.SeatNumber ?? "Not assigned")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Fare Class</span>
                        <span class="detail-value">@ticket.Class.ClassName</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Booking Reference</span>
                        <span class="detail-value">#@ticket.BookingId</span>
                    </div>
                </div>

                <div class="ticket-footer">
                    @if (canPay)
                    {
                        <a asp-controller="Payment" asp-action="CreatePayment" asp-route-id="@ticket.BookingId" class="btn-action btn-pay">
                            <i class="fa-solid fa-credit-card"></i> Pay now
                        </a>
                    }

                    @if (canChangeSeat)
                    {
                        <a asp-controller="Ticket" asp-action="ChangeSeat" asp-route-id="@ticket.TicketId" class="btn-action btn-secondary">
                            <i class="fa-solid fa-chair"></i> Change seat
                        </a>
                    }

                    @if (isPaid)
                    {
                        <div class="btn-action" style="background: rgba(23, 184, 120, 0.1); color: #5de8a8; border: 1px solid rgba(23, 184, 120, 0.2); cursor: default;">
                            <i class="fa-solid fa-check-double"></i> Paid
                        </div>
                    }

                    @if (canCancel)
                    {
                        <form class="cancel-ticket-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@ticket.TicketId" />
                            <button type="button" class="btn-action btn-danger" onclick="confirmTicketCancellation(this)">
                                <i class="fa-solid fa-ban"></i> Cancel ticket
                            </button>
                        </form>
                    }
                    else if (!isCancelled && hasDeparted)
                    {
                        <div class="btn-action btn-muted">
                            <i class="fa-solid fa-plane-departure"></i> Departure passed
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
    <script>
        async function confirmTicketCancellation(button) {
            const form = button.closest('.cancel-ticket-form');
            if (!form) return;

            const result = await Swal.fire({
                title: 'Cancel this ticket?',
                text: 'The seat will be released immediately. Unpaid baggage registrations for this ticket will also be removed.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff6b6b',
                cancelButtonText: 'Keep ticket',
                confirmButtonText: 'Yes, cancel it'
            });

            if (!result.isConfirmed) return;

            button.disabled = true;

            try {
                const response = await fetch('/Ticket/CancelTicket', {
                    method: 'POST',
                    body: new FormData(form),
                    headers: {
                        'RequestVerificationToken': form.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const data = await response.json();

                if (data.success) {
                    await Swal.fire('Cancelled', data.message, 'success');
                    window.location.reload();
                    return;
                }

                Swal.fire('Unable to cancel', data.message, 'error');
            } catch (error) {
                Swal.fire('Error', 'An error occurred while cancelling the ticket.', 'error');
            } finally {
                button.disabled = false;
            }
        }
    </script>
}
