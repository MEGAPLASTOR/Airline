@model Airline.Models.Ticket
@{
    ViewData["Title"] = "Change Your Seat";
    var schedule = Model.Booking.Schedule;
    var occupiedSeats = ViewBag.OccupiedSeats as List<string> ?? new List<string>();
    var currentSeat = Model.SeatNumber;
}

<style>
    .booking-container {
        padding: 3rem 2rem;
        max-width: 1000px;
        margin: 0 auto;
    }
    .seat-map-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--radius-lg);
        padding: 3.5rem;
        margin-top: 2.5rem;
    }
    .seat-grid {
        display: grid;
        grid-template-columns: repeat(7, 45px); /* 6 seats + 1 aisle */
        gap: 15px;
        margin-top: 2rem;
    }
    .seat {
        width: 45px;
        height: 45px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all var(--transition);
    }
    .seat:hover:not(.occupied):not(.blocked):not(.current) {
        transform: scale(1.1);
        background: rgba(255,255,255,0.2);
        border-color: var(--ocean-aqua);
    }
    .seat.selected {
        background: var(--ocean-aqua);
        border-color: #0fd2e4;
        color: #fff;
        box-shadow: 0 0 15px rgba(23,170,184,0.4);
    }
    .seat.current {
        background: #ffc107;
        border-color: #ff9800;
        color: #000;
        box-shadow: 0 0 10px rgba(255, 193, 7, 0.4);
        cursor: default;
    }
    .seat.occupied {
        background: #ff4d4d33;
        border-color: #ff4d4d;
        color: #ff4d4d;
        cursor: not-allowed;
        opacity: 0.6;
    }
    .seat.blocked {
        background: #444;
        border-color: #555;
        cursor: not-allowed;
        opacity: 0.4;
    }
    .aisle {
        width: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        color: rgba(255,255,255,0.3);
        font-weight: 700;
    }
    .legend {
        display: flex;
        gap: 20px;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        justify-content: center;
    }
    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
    }
    .legend-box {
        width: 18px;
        height: 18px;
        border-radius: 4px;
    }
    .bottom-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(6, 21, 37, 0.9);
        backdrop-filter: blur(20px);
        padding: 20px 40px;
        border-top: 1px solid rgba(255,255,255,0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 1000;
    }
    .btn-save {
        background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
        color: #fff;
        border: none;
        padding: 12px 35px;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-save:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>

<div class="booking-container" style="margin-bottom: 120px;">
    <div style="text-align: center; margin-bottom: 2rem;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #fff;">Change Your <span>Position</span></h2>
        <p style="color: rgba(255,255,255,0.5);">Ticket ID: #@Model.TicketId | Flight: @schedule.Flight.FlightNumber</p>
    </div>

    <div class="seat-map-wrapper">
        <div class="legend">
            <div class="legend-item"><div class="legend-box" style="background:rgba(255,255,255,0.08)"></div> Available</div>
            <div class="legend-item"><div class="legend-box" style="background:#ffc107"></div> Your Current Seat</div>
            <div class="legend-item"><div class="legend-box" style="background:var(--ocean-aqua)"></div> Selected New Seat</div>
            <div class="legend-item"><div class="legend-box" style="background:rgba(255,77,77,0.3)"></div> Occupied</div>
        </div>

        <div class="seat-grid">
            @{
                int rows = ((schedule.TotalSeats ?? 0) / 6) + 1;
                string[] letters = { "A", "B", "C", "D", "E", "F" };
            }
            @for (int i = 0; i < rows; i++)
            {
                int rowNum = i + 1;
                for (int j = 0; j < 7; j++)
                {
                    if (j == 3) // Aisle
                    {
                        <div class="aisle">@rowNum</div>
                    }
                    else
                    {
                        int seatIdxForLetter = (j > 3) ? j - 1 : j;
                        string seatNum = $"{rowNum}{letters[seatIdxForLetter]}";
                        int absoluteIdx = (i * 6) + seatIdxForLetter + 1;

                        if (absoluteIdx <= (schedule.TotalSeats ?? 0))
                        {
                            bool isCurrent = seatNum == currentSeat;
                            bool isOccupied = !isCurrent && occupiedSeats.Contains(seatNum);
                            
                            <div class="seat @(isCurrent ? "current" : "") @(isOccupied ? "occupied" : "")" 
                                 id="seat-@seatNum" 
                                 onclick="selectSeat('@seatNum', @(isCurrent.ToString().ToLower()), @(isOccupied.ToString().ToLower()))">
                                @seatNum
                            </div>
                        }
                    }
                }
            }
        </div>
    </div>
</div>

<div class="bottom-bar">
    <div style="display: flex; gap: 2rem;">
        <div>
            <span style="font-size: 0.7rem; color: rgba(255,255,255,0.4); text-transform: uppercase;">Current Seat</span><br />
            <strong style="font-size: 1.25rem;">@currentSeat</strong>
        </div>
        <div>
            <span style="font-size: 0.7rem; color: rgba(255,255,255,0.4); text-transform: uppercase;">New Seat</span><br />
            <strong id="displayNewSeat" style="font-size: 1.25rem; color: var(--ocean-aqua);">None</strong>
        </div>
    </div>

    <div>
        <a asp-action="ViewConfirmation" style="color: rgba(255,255,255,0.5); text-decoration: none; margin-right: 1.5rem; font-size: 0.9rem;">Cancel</a>
        <button id="btnSave" class="btn-save" disabled onclick="saveSeat()">Update My Seat</button>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
    <script>
        let selectedNewSeat = null;
        const ticketId = @Model.TicketId;

        function selectSeat(seatNum, isCurrent, isOccupied) {
            if (isCurrent || isOccupied) return;

            if (selectedNewSeat) {
                document.getElementById('seat-' + selectedNewSeat).classList.remove('selected');
            }

            if (selectedNewSeat === seatNum) {
                selectedNewSeat = null;
                document.getElementById('displayNewSeat').textContent = 'None';
                document.getElementById('btnSave').disabled = true;
            } else {
                selectedNewSeat = seatNum;
                document.getElementById('seat-' + seatNum).classList.add('selected');
                document.getElementById('displayNewSeat').textContent = seatNum;
                document.getElementById('btnSave').disabled = false;
            }
        }

        function saveSeat() {
            if (!selectedNewSeat) return;

            Swal.fire({
                title: 'Confirm Change',
                text: `Are you sure you want to change your seat to ${selectedNewSeat}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#17aab8',
                confirmButtonText: 'Yes, change it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    const formData = new FormData();
                    formData.append('ticketId', ticketId);
                    formData.append('newSeatNumber', selectedNewSeat);
                    
                    // Lấy antiforgery token
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    fetch('/Ticket/UpdateSeat', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': token
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire('Updated!', data.message, 'success')
                            .then(() => {
                                window.location.href = '/Ticket/ViewConfirmation';
                            });
                        } else {
                            Swal.fire('Error', data.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
