@model Airline.Models.Ticket
@{
    ViewData["Title"] = "Change Seat";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var availableSeats = ViewBag.AvailableSeats as List<Airline.Models.Seat> ?? new List<Airline.Models.Seat>();
}

<div class="change-seat-container">
    <div class="selection-header">
        <a asp-action="ViewConfirmation" class="btn-back"><i class="fas fa-chevron-left"></i> Back to ticket list</a>
        <h1 class="premium-title">Change <span class="highlight">Seat</span></h1>
        <p class="premium-subtitle">Choose a new seat within the same fare class <strong>@(Model?.Class?.ClassName ?? "N/A")</strong></p>
    </div>

    <div class="selection-layout">
        <!-- Seat Map Section (Simplified for this class only) -->
        <div class="seat-map-wrapper">
            <div class="airplane-body">
                <div class="cabin-container">
                    <div class="cabin-divider">
                        <span>@(Model?.Class?.ClassName ?? "N/A") Class</span>
                    </div>
                    
                    <div class="seat-grid-container">
                        @if (!availableSeats.Any())
                        {
                            <div class="empty-seats">
                                <i class="fas fa-info-circle"></i>
                                <p>Sorry, there are no available seats left in this fare class.</p>
                            </div>
                        }
                        else
                        {
                            <div class="seat-list">
                                @foreach (var seat in availableSeats.OrderBy(s => s.SeatNumber))
                                {
                                    <div class="seat-card" data-id="@seat.SeatId" data-number="@seat.SeatNumber" onclick="selectNewSeat(this)">
                                        <i class="fas fa-couch"></i>
                                        <span>@seat.SeatNumber</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="checkout-sidebar">
            <div class="glass-card sticky-card">
                <h3 class="card-title">Change Details</h3>
                
                <div class="current-selection-badge">
                    <div class="badge-icon"><i class="fas fa-chair"></i></div>
                    <div class="badge-text">
                        <p>Current Seat</p>
                        <h4>@ViewBag.CurrentSeatNumber</h4>
                    </div>
                </div>

                <div class="arrow-down"><i class="fas fa-arrow-down"></i></div>

                <div class="current-selection-badge new-selection" id="new-seat-badge">
                    <div class="badge-icon"><i class="fas fa-star"></i></div>
                    <div class="badge-text">
                        <p>Selected New Seat</p>
                        <h4 id="selected-seat-text">Not selected</h4>
                    </div>
                </div>

                <form id="change-seat-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ticketId" value="@Model?.TicketId" />
                    <input type="hidden" name="newSeatId" id="hidden-new-seat-id" />
                    <button type="button" class="btn-confirm-change" id="btn-submit-change" disabled onclick="confirmSeatChange()">
                        Confirm Seat Change <i class="fas fa-check"></i>
                    </button>
                </form>

                <div class="notice-box">
                    <i class="fas fa-lightbulb"></i>
                    <p>Changing seats is completely free within the same fare class.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .change-seat-container { max-width: 1100px; margin: 0 auto; padding-bottom: 5rem; }
        .selection-header { margin-bottom: 3rem; }
        .premium-title { font-family: 'Playfair Display', serif; font-size: 2.8rem; color: #fff; margin-bottom: 0.5rem; }
        .premium-title .highlight { color: var(--ocean-aqua); }
        .premium-subtitle { color: rgba(255,255,255,0.5); }
        
        .selection-layout { display: grid; grid-template-columns: 1fr 350px; gap: 3rem; align-items: start; }
        
        .glass-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 24px;
            padding: 2rem;
        }

        .airplane-body {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 40px;
            padding: 3rem;
            min-height: 400px;
        }

        .cabin-divider {
            border-bottom: 1px dashed rgba(255,255,255,0.2);
            margin-bottom: 2.5rem;
            text-align: center;
        }
        .cabin-divider span { font-weight: 800; color: var(--ocean-aqua); text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.9rem; background: #061525; padding: 0 1rem; position: relative; top: 0.6rem; }

        .seat-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            gap: 1.5rem;
        }

        .seat-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 1.2rem 0.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.6rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .seat-card:hover { background: rgba(255,255,255,0.1); border-color: var(--ocean-aqua); transform: translateY(-5px); }
        .seat-card i { font-size: 1.4rem; color: var(--ocean-aqua); }
        .seat-card span { font-weight: 700; color: #fff; font-size: 1rem; }

        .seat-card.active-selection {
            background: var(--ocean-aqua);
            border-color: #fff;
            box-shadow: 0 0 20px rgba(23,170,184,0.4);
        }
        .seat-card.active-selection i, .seat-card.active-selection span { color: #fff; }

        /* Sidebar info */
        .current-selection-badge {
            background: rgba(255,255,255,0.05);
            border-radius: 16px;
            padding: 1.2rem;
            display: flex;
            align-items: center;
            gap: 1.2rem;
        }
        .badge-icon { width: 45px; height: 45px; background: rgba(255,255,255,0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: #fff; }
        .new-selection { background: rgba(23,170,184,0.1); border: 1px solid var(--ocean-aqua); }
        .new-selection .badge-icon { background: var(--ocean-aqua); }
        
        .badge-text p { margin: 0; font-size: 0.7rem; color: rgba(255,255,255,0.4); text-transform: uppercase; }
        .badge-text h4 { margin: 0; font-size: 1.2rem; color: #fff; }

        .arrow-down { text-align: center; margin: 1rem 0; color: rgba(255,255,255,0.2); font-size: 1.2rem; }

        .btn-confirm-change {
            width: 100%;
            background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
            border: none;
            border-radius: 16px;
            padding: 1.2rem;
            color: #fff;
            font-weight: 800;
            margin-top: 2rem;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-confirm-change:disabled { opacity: 0.3; cursor: not-allowed; }

        .notice-box {
            margin-top: 2rem;
            background: rgba(240,180,41,0.05);
            border: 1px solid rgba(240,180,41,0.2);
            padding: 1rem;
            border-radius: 12px;
            display: flex;
            gap: 1rem;
        }
        .notice-box i { color: var(--accent-gold); }
        .notice-box p { margin: 0; font-size: 0.8rem; color: rgba(255,255,255,0.6); }

        .empty-seats { text-align: center; padding: 4rem 2rem; color: rgba(255,255,255,0.3); }
        .empty-seats i { font-size: 3rem; margin-bottom: 1.5rem; }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
    <script>
        let selectedId = null;

        function selectNewSeat(element) {
            document.querySelectorAll('.seat-card').forEach(c => c.classList.remove('active-selection'));
            element.classList.add('active-selection');
            
            selectedId = element.dataset.id;
            const seatNum = element.dataset.number;

            document.getElementById('selected-seat-text').textContent = seatNum;
            document.getElementById('hidden-new-seat-id').value = selectedId;
            document.getElementById('btn-submit-change').disabled = false;
        }

        async function confirmSeatChange() {
            if (!selectedId) return;

            const result = await Swal.fire({
                title: 'Confirm seat change?',
                text: "Are you sure you want to switch to this new seat?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#17aab8',
                confirmButtonText: 'Yes, change it',
                cancelButtonText: 'Cancel'
            });

            if (result.isConfirmed) {
                const formData = new FormData(document.getElementById('change-seat-form'));
                
                try {
                    const response = await fetch('/Ticket/UpdateSeat', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    });

                    const data = await response.json();

                    if (data.success) {
                        await Swal.fire('Success!', data.message, 'success');
                        window.location.href = '/Ticket/ViewConfirmation';
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (error) {
                    Swal.fire('Error', 'An error occurred while processing your request.', 'error');
                }
            }
        }
    </script>
}
