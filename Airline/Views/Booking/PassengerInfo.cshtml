@model Airline.Models.BookingViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Passenger Information";
}

@section Styles {
    <link rel="stylesheet" href="~/css/booking/passenger-info.css" />
}

<div class="booking-container">
    <div class="section-heading" style="text-align:left; margin-bottom: 30px;">
        <span class="section-kicker">Final Step</span>
        <h2>Passenger <span>Details</span></h2>
    </div>

    <div class="summary-box">
        <div class="summary-row"><span>Flight:</span> <strong>@Model.FlightNumber</strong></div>
        <div class="summary-row"><span>Seat:</span> <strong style="color:var(--ocean-aqua)">@Model.SeatNumber</strong></div>
        <div class="summary-row"><span>Date:</span> <span>@Model.DepartureTime.ToString("dd MMM yyyy HH:mm")</span></div>
        <div class="summary-row" style="margin-top: 10px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 5px;">
            <span>Total:</span> <strong style="color:var(--accent-gold)">1.500.000 VND</strong>
        </div>
    </div>

    <form asp-action="ConfirmBooking" method="post">
        <input type="hidden" asp-for="ScheduleId" />
        <input type="hidden" asp-for="SeatNumber" />
        <input type="hidden" asp-for="FlightNumber" />
        <input type="hidden" asp-for="DepartureTime" />

        <div class="form-group">
            <label class="form-label">Full Name as per Passport/ID</label>
            <input asp-for="FullName" class="form-control" placeholder="E.g. NGUYEN VAN A" />
            <span asp-validation-for="FullName" class="text-danger" style="font-size:0.8rem;"></span>
        </div>

        <div class="form-group">
            <label class="form-label">Passenger Type</label>
            <select asp-for="PassengerType" class="form-control">
                <option value="Adult">Adult (12+ years)</option>
                <option value="Child">Child (2-12 years)</option>
                <option value="Infant">Infant (Under 2 years)</option>
            </select>
        </div>

        <div style="margin-top: 30px;">
            <button type="submit" class="btn-select" style="width: 100%; padding: 15px;">Confirm and Book</button>
        </div>
    </form>
</div>
