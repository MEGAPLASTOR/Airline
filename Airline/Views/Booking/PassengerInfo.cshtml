@model Airline.Models.BookingViewModel
@{
    ViewData["Title"] = "Passenger Information";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedSkyMiles = Model.SkyMilesToRedeem;
}

<div class="passenger-info-container">
    <div class="selection-header">
        <a href="javascript:history.back()" class="btn-back"><i class="fas fa-chevron-left"></i> Back to seat selection</a>
        <h1 class="premium-title">Passenger <span class="highlight">Information</span></h1>
        <p class="premium-subtitle">Please enter the passenger name exactly as it appears on the ID card or passport.</p>
    </div>

    <div class="form-layout">
        <!-- Main Form -->
        <div class="main-form-section">
            <div class="glass-card">
                <form asp-action="ConfirmBooking" method="post" class="passenger-form">
                    <div asp-validation-summary="All" class="text-danger"></div>
                    <input type="hidden" asp-for="ScheduleId" />
                    <input type="hidden" asp-for="SeatId" />
                    <input type="hidden" asp-for="ClassId" />
                    <input type="hidden" asp-for="SeatNumber" />
                    <input type="hidden" asp-for="Origin" />
                    <input type="hidden" asp-for="Destination" />
                    <input type="hidden" asp-for="FlightNumber" />
                    <input type="hidden" asp-for="Price" />
                    <input type="hidden" asp-for="DepartureTime" />
                    <input type="hidden" asp-for="PromoCode" />
                    <input type="hidden" asp-for="AppliedPromotionId" />
                    <input type="hidden" asp-for="DiscountPercent" />
                    <input type="hidden" asp-for="TaxAmount" />
                    <input type="hidden" asp-for="DiscountAmount" />
                    <input type="hidden" asp-for="SkyMilesToRedeem" />
                    <input type="hidden" asp-for="SkyMilesDiscountPercent" />
                    <input type="hidden" asp-for="SkyMilesDiscountAmount" />
                    <input type="hidden" asp-for="FinalPrice" />
                    <input type="hidden" asp-for="CurrentSkyMiles" />

                    <div class="form-header">
                        <i class="fas fa-user-edit"></i>
                        <span>Passenger Information 1</span>
                    </div>

                    <div class="form-group">
                        <label asp-for="FullName">Full Name</label>
                        <div class="input-with-icon">
                            <i class="fas fa-user"></i>
                            <input asp-for="FullName" class="form-control" placeholder="Example: NGUYEN VAN AN" required />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group flex-1">
                            <label asp-for="PassengerType">Passenger Type</label>
                            <div class="input-with-icon">
                                <i class="fas fa-users"></i>
                                <select asp-for="PassengerType" class="form-control">
                                    <option value="Adult">Adult (Over 12 years old)</option>
                                    <option value="Child">Child (2 - 12 years old)</option>
                                    <option value="Infant">Infant (Under 2 years old)</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group flex-1">
                            <label>Nationality</label>
                            <div class="input-with-icon">
                                <i class="fas fa-globe"></i>
                                <select class="form-control">
                                    <option value="VN">Vietnam</option>
                                    <option value="US">United States</option>
                                    <option value="FR">France</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="payment-mode-panel">
                        <div class="payment-mode-header">
                            <div>
                                <h3>SkyMiles Discount</h3>
                                <p>SkyMiles only reduce the ticket price. Every 1,000 miles gives 5% off, up to 10% per booking.</p>
                            </div>
                            <a asp-controller="Miles" asp-action="Index" class="promotion-link">Open SkyMiles Shop</a>
                        </div>

                        <div class="payment-mode-grid">
                            <button type="button"
                                    class="payment-mode-card @(selectedSkyMiles == 0 ? "is-active" : "")"
                                    id="skymiles-option-0"
                                    onclick="selectSkyMilesOption(0)">
                                <i class="fas fa-credit-card"></i>
                                <span>No SkyMiles</span>
                                <small>Keep your current balance and pay the normal online price.</small>
                            </button>
                            <button type="button"
                                    class="payment-mode-card @(selectedSkyMiles == 1000 ? "is-active" : "") @(Model.CurrentSkyMiles < 1000 ? "is-disabled" : "")"
                                    id="skymiles-option-1000"
                                    onclick="selectSkyMilesOption(1000)"
                                    @(Model.CurrentSkyMiles < 1000 ? "disabled" : null)>
                                <i class="fas fa-coins"></i>
                                <span>1,000 SkyMiles</span>
                                <small>Apply 5% off to this booking and still pay the remaining amount online.</small>
                            </button>
                            <button type="button"
                                    class="payment-mode-card @(selectedSkyMiles == 2000 ? "is-active" : "") @(Model.CurrentSkyMiles < 2000 ? "is-disabled" : "")"
                                    id="skymiles-option-2000"
                                    onclick="selectSkyMilesOption(2000)"
                                    @(Model.CurrentSkyMiles < 2000 ? "disabled" : null)>
                                <i class="fas fa-gem"></i>
                                <span>2,000 SkyMiles</span>
                                <small>Apply the maximum 10% SkyMiles discount to this booking.</small>
                            </button>
                        </div>

                        <div class="skymiles-balance-panel" id="skymiles-balance-panel">
                            <div class="balance-stat">
                                <span>Your balance</span>
                                <strong id="skymiles-current">@Model.CurrentSkyMiles.ToString("N0") miles</strong>
                            </div>
                            <div class="balance-stat">
                                <span>Selected for this booking</span>
                                <strong id="skymiles-selected">@Model.SkyMilesToRedeem.ToString("N0") miles</strong>
                            </div>
                            <div class="balance-state @(Model.SkyMilesToRedeem > 0 ? "is-good" : "is-warning")" id="skymiles-affordability">
                                @(Model.SkyMilesToRedeem > 0
                                    ? $"This booking is using {Model.SkyMilesDiscountPercent}% SkyMiles discount."
                                    : "Choose a SkyMiles option above to reduce the ticket price.")
                            </div>
                        </div>
                    </div>

                    <div class="promotion-panel">
                        <div class="promotion-panel-header">
                            <div>
                                <h3>Promotion Code</h3>
                                <p>Enter a public promotion or a reward code you already bought in the SkyMiles Shop. It can be used together with SkyMiles discount.</p>
                            </div>
                            <div class="promotion-actions">
                                <a asp-action="ApplyPromotion" class="promotion-link">View all offers</a>
                                <a asp-controller="Miles" asp-action="Index" class="promotion-link">Go to SkyMiles Shop</a>
                            </div>
                        </div>

                        <div class="promotion-input-row">
                            <div class="input-with-icon promotion-input-wrap">
                                <i class="fas fa-ticket-percent"></i>
                                <input type="text"
                                       id="promoCodeInput"
                                       value="@Model.PromoCode"
                                       class="form-control"
                                       placeholder="Example: NEWUSER10 or MILES12"
                                       autocomplete="off" />
                            </div>
                            <button type="button" class="btn-apply-promo" onclick="applyPromotion()">Apply</button>
                            <button type="button" class="btn-clear-promo" onclick="clearPromotion()">Clear</button>
                        </div>

                        <span asp-validation-for="PromoCode" class="text-danger"></span>
                        <div id="promoFeedback" class="promo-feedback @(Model.AppliedPromotionId.HasValue ? "is-success" : "")">
                            @if (Model.AppliedPromotionId.HasValue)
                            {
                                <span>Applied code <strong>@Model.PromoCode</strong> with @Model.DiscountPercent% discount.</span>
                            }
                        </div>

                        <div class="promo-chip-section">
                            <div class="promo-chip-heading">Public offers</div>
                            <div class="promo-chip-list" id="public-promo-list">
                                @foreach (var promo in Model.AvailablePromotions)
                                {
                                    <button type="button"
                                            class="promo-chip"
                                            data-code="@promo.PromoCode"
                                            onclick="selectPromotion(this.dataset.code)">
                                        <span class="promo-chip-code">@promo.PromoCode</span>
                                        <span class="promo-chip-discount">-@(promo.DiscountPercent ?? 0)%</span>
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="promo-chip-section">
                            <div class="promo-chip-heading">My SkyMiles reward codes</div>
                            <div class="promo-chip-list" id="skymiles-promo-list">
                                @foreach (var promo in Model.OwnedSkyMilesPromotions)
                                {
                                    <button type="button"
                                            class="promo-chip"
                                            data-code="@promo.PromoCode"
                                            onclick="selectPromotion(this.dataset.code)">
                                        <span class="promo-chip-code">@promo.PromoCode</span>
                                        <span class="promo-chip-discount">-@(promo.DiscountPercent ?? 0)%</span>
                                    </button>
                                }
                            </div>

                            @if (!Model.OwnedSkyMilesPromotions.Any())
                            {
                                <div class="promo-empty" id="skymiles-promo-empty">
                                    You have no unused SkyMiles reward codes right now. Open the shop to buy one.
                                </div>
                            }
                        </div>
                    </div>

                    <div class="form-notice">
                        <i class="fas fa-info-circle"></i>
                        <p>The passenger name must match the travel document exactly.</p>
                    </div>

                    <div class="action-buttons">
                        <button type="submit" class="btn-confirm-final" id="confirm-booking-button">
                            Confirm Booking <i class="fas fa-check-circle"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Order Summary Sidebar -->
        <div class="order-summary-sidebar">
            <div class="glass-card sticky-card">
                <h3 class="card-title">Order Summary</h3>
                
                <div class="flight-summary-card">
                    <div class="flight-header">
                        <span class="flight-num">@Model.FlightNumber</span>
                        <span class="date">@(Model.DepartureTime?.ToString("MM/dd/yyyy") ?? "--/--/----")</span>
                    </div>
                    
                    <div class="route-display">
                        <div class="node">
                            <strong>@Model.Origin</strong>
                            <span>Origin</span>
                        </div>
                        <div class="sep"><i class="fas fa-long-arrow-alt-right"></i></div>
                        <div class="node">
                            <strong>@Model.Destination</strong>
                            <span>Destination</span>
                        </div>
                    </div>

                    <div class="seat-badge-mini">
                        <i class="fas fa-couch"></i>
                        <span>Seat <strong>@Model.SeatNumber</strong></span>
                    </div>
                </div>

                <div class="price-breakdown">
                    <div class="breakdown-row">
                        <span>Base Fare</span>
                        <span id="summary-base-price">@(Model.Price?.ToString("N0") ?? "0") VND</span>
                    </div>
                    <div class="breakdown-row">
                        <span>Taxes & Fees</span>
                        <span id="summary-tax-price">@Model.TaxAmount.ToString("N0") VND</span>
                    </div>
                    <div class="breakdown-row discount-row @(Model.AppliedPromotionId.HasValue ? "is-visible" : "")" id="discount-row">
                        <span id="summary-discount-label">Promotion @(Model.DiscountPercent > 0 ? $"(-{Model.DiscountPercent}%)" : "")</span>
                        <span id="summary-discount-price">-@Model.DiscountAmount.ToString("N0") VND</span>
                    </div>
                    <div class="breakdown-row skymiles-row @(Model.SkyMilesToRedeem > 0 ? "is-visible" : "")" id="skymiles-row">
                        <span id="summary-skymiles-label">SkyMiles @(Model.SkyMilesDiscountPercent > 0 ? $"(-{Model.SkyMilesDiscountPercent}%)" : "")</span>
                        <span id="summary-skymiles-discount">-@Model.SkyMilesDiscountAmount.ToString("N0") VND</span>
                    </div>
                    <div class="total-row">
                        <span>Total Payment</span>
                        <span id="summary-final-price">@Model.FinalPrice.ToString("N0") VND</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .passenger-info-container {
            max-width: 1100px;
            margin: 0 auto;
            padding-bottom: 5rem;
        }

        .selection-header {
            margin-bottom: 3rem;
            animation: fadeInDown 0.8s ease-out;
        }

        .premium-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.8rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 0.5rem;
        }

        .premium-title .highlight { color: var(--ocean-aqua); }

        .form-layout {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 2.5rem;
            align-items: start;
        }

        .glass-card {
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 24px;
            padding: 2rem;
        }

        .form-header {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            color: #fff;
            font-weight: 700;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .form-header i { color: var(--ocean-aqua); }

        .form-group {
            margin-bottom: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .form-group label {
            font-size: 0.85rem;
            font-weight: 600;
            color: rgba(255,255,255,0.6);
        }

        .input-with-icon {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-with-icon i {
            position: absolute;
            left: 1rem;
            color: rgba(255,255,255,0.3);
            font-size: 0.95rem;
        }

        .form-control {
            width: 100%;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 12px;
            padding: 0.85rem 1rem 0.85rem 2.8rem;
            color: #fff;
            font-family: inherit;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            background: rgba(255,255,255,0.08);
            border-color: var(--ocean-aqua);
            outline: none;
            box-shadow: 0 0 15px rgba(23,170,184,0.2);
        }

        .form-row { display: flex; gap: 1.5rem; }
        .flex-1 { flex: 1; }

        .payment-mode-panel {
            margin-bottom: 1.6rem;
            padding: 1.2rem;
            border-radius: 18px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
        }

        .payment-mode-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .payment-mode-header h3 {
            color: #fff;
            font-size: 1rem;
            margin-bottom: 0.2rem;
        }

        .payment-mode-header p {
            color: rgba(255,255,255,0.58);
            font-size: 0.82rem;
        }

        .payment-mode-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.9rem;
        }

        .payment-mode-card {
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.04);
            border-radius: 16px;
            padding: 1rem;
            text-align: left;
            color: #fff;
            display: flex;
            flex-direction: column;
            gap: 0.45rem;
            transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
        }

        .payment-mode-card i {
            color: var(--accent-gold);
            font-size: 1.1rem;
        }

        .payment-mode-card span {
            font-weight: 700;
        }

        .payment-mode-card small {
            color: rgba(255,255,255,0.56);
            line-height: 1.45;
        }

        .payment-mode-card.is-active {
            border-color: rgba(23,170,184,0.5);
            background: rgba(23,170,184,0.12);
            transform: translateY(-2px);
        }

        .payment-mode-card.is-disabled,
        .payment-mode-card:disabled {
            opacity: 0.55;
            cursor: not-allowed;
            transform: none;
        }

        .skymiles-balance-panel {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.8rem;
            margin-top: 1rem;
        }

        .balance-stat,
        .balance-state {
            border-radius: 14px;
            padding: 0.9rem 1rem;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
        }

        .balance-stat span,
        .balance-state {
            color: rgba(255,255,255,0.62);
            font-size: 0.8rem;
        }

        .balance-stat strong {
            display: block;
            margin-top: 0.25rem;
            color: #fff;
            font-size: 1rem;
        }

        .balance-state.is-good {
            color: #9df1c8;
            border-color: rgba(93,232,168,0.25);
        }

        .balance-state.is-warning {
            color: #ffd28e;
            border-color: rgba(240,180,41,0.28);
        }

        .promotion-panel {
            margin-bottom: 1.8rem;
            padding: 1.2rem;
            border-radius: 18px;
            background: rgba(23,170,184,0.08);
            border: 1px solid rgba(23,170,184,0.18);
        }

        .promotion-panel-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .promotion-panel-header h3 {
            color: #fff;
            font-size: 1rem;
            margin-bottom: 0.2rem;
        }

        .promotion-panel-header p {
            color: rgba(255,255,255,0.6);
            font-size: 0.82rem;
        }

        .promotion-actions {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .promotion-link {
            color: var(--ocean-foam);
            font-size: 0.82rem;
            font-weight: 700;
        }

        .promotion-link.is-hidden {
            display: none;
        }

        .promotion-input-row {
            display: grid;
            grid-template-columns: 1fr auto auto;
            gap: 0.8rem;
            align-items: center;
        }

        .promotion-input-wrap .form-control {
            padding-right: 1rem;
            text-transform: uppercase;
        }

        .btn-apply-promo,
        .btn-clear-promo {
            border: none;
            border-radius: 12px;
            padding: 0.85rem 1rem;
            font-weight: 700;
            color: #fff;
        }

        .btn-apply-promo {
            background: linear-gradient(135deg, var(--accent-gold), #f39c12);
            color: #071421;
        }

        .btn-clear-promo {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
        }

        .promo-feedback {
            min-height: 1.2rem;
            margin-top: 0.75rem;
            color: rgba(255,255,255,0.55);
            font-size: 0.82rem;
        }

        .promo-feedback.is-success {
            color: #9df1c8;
        }

        .promo-feedback.is-error {
            color: #ff9e9e;
        }

        .promo-chip-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 1rem;
        }

        .promo-chip-section + .promo-chip-section {
            margin-top: 1.2rem;
        }

        .promo-chip-heading {
            color: rgba(255,255,255,0.7);
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .promo-chip-list.is-hidden {
            display: none;
        }

        .promo-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.7rem;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 999px;
            padding: 0.6rem 0.9rem;
            color: #fff;
        }

        .promo-chip-code {
            font-weight: 700;
        }

        .promo-chip-discount {
            color: var(--accent-gold);
            font-size: 0.82rem;
        }

        .promo-empty {
            margin-top: 1rem;
            padding: 0.9rem 1rem;
            border-radius: 14px;
            border: 1px dashed rgba(255,255,255,0.16);
            color: rgba(255,255,255,0.6);
            font-size: 0.82rem;
        }

        .promo-empty.is-hidden {
            display: none;
        }

        .form-notice {
            background: rgba(240,180,41,0.1);
            border-left: 4px solid var(--accent-gold);
            padding: 1rem;
            display: flex;
            gap: 0.8rem;
            margin: 2rem 0;
            border-radius: 8px;
        }

        .form-notice i { color: var(--accent-gold); margin-top: 3px; }
        .form-notice p { color: rgba(255,255,255,0.7); font-size: 0.85rem; line-height: 1.4; }

        .btn-confirm-final {
            width: 100%;
            background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
            border: none;
            border-radius: 16px;
            padding: 1.2rem;
            color: #fff;
            font-weight: 800;
            font-size: 1.1rem;
            box-shadow: 0 10px 25px rgba(23,170,184,0.35);
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex; align-items: center; justify-content: center; gap: 0.8rem;
        }

        .btn-confirm-final:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px rgba(23,170,184,0.45);
        }

        /* Sidebar summary */
        .flight-summary-card {
            background: rgba(0,0,0,0.2);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            padding: 1.2rem;
            margin-bottom: 1.5rem;
        }

        .flight-header {
            display: flex; justify-content: space-between;
            margin-bottom: 1rem; font-size: 0.8rem; font-weight: 700; color: rgba(255,255,255,0.4);
        }

        .route-display {
            display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.2rem;
        }

        .node { display: flex; flex-direction: column; }
        .node strong { font-size: 1.1rem; color: #fff; }
        .node span { font-size: 0.7rem; color: rgba(255,255,255,0.4); text-transform: uppercase; }

        .seat-badge-mini {
            background: var(--ocean-aqua);
            color: #fff;
            padding: 0.4rem 0.8rem;
            border-radius: 8px;
            font-size: 0.85rem;
            display: inline-flex; align-items: center; gap: 0.6rem;
        }

        .price-breakdown {
            display: flex; flex-direction: column; gap: 0.8rem;
            padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.08);
        }

        .breakdown-row { display: flex; justify-content: space-between; font-size: 0.85rem; color: rgba(255,255,255,0.5); }
        .discount-row { display: none; color: #9df1c8; }
        .discount-row.is-visible { display: flex; }
        .skymiles-row { display: none; color: var(--ocean-foam); }
        .skymiles-row.is-visible { display: flex; }
        .total-row { display: flex; justify-content: space-between; margin-top: 0.5rem; font-size: 1.2rem; font-weight: 700; color: var(--accent-gold); }

        @@media (max-width: 920px) {
            .form-layout {
                grid-template-columns: 1fr;
            }

            .payment-mode-grid,
            .skymiles-balance-panel {
                grid-template-columns: 1fr;
            }

            .promotion-panel-header,
            .payment-mode-header,
            .promotion-input-row,
            .form-row {
                display: flex;
                flex-direction: column;
            }

            .promotion-actions {
                justify-content: flex-start;
            }
        }

        .sticky-card { position: sticky; top: 100px; }
    </style>
}

@section Scripts {
    <script>
        const skyMilesStep = @Airline.Services.PromotionService.SkyMilesRedemptionStep;
        const maxSkyMilesRedeemable = @Airline.Services.PromotionService.MaxSkyMilesRedeemable;
        const skyMilesDiscountPercentPerStep = @Airline.Services.PromotionService.SkyMilesDiscountPercentPerStep;
        const maxSkyMilesDiscountPercent = @Airline.Services.PromotionService.MaxSkyMilesDiscountPercent;

        function formatMoney(value) {
            return Number(value || 0).toLocaleString('en-US') + ' VND';
        }

        function formatMiles(value) {
            return Number(value || 0).toLocaleString('en-US') + ' miles';
        }

        function normalizeSkyMiles(value) {
            const parsed = Number(value || 0);
            if (parsed <= 0) {
                return 0;
            }

            return Math.min(maxSkyMilesRedeemable, Math.floor(parsed / skyMilesStep) * skyMilesStep);
        }

        function calculateSkyMilesDiscountPercent(value) {
            const normalizedMiles = normalizeSkyMiles(value);
            return Math.min(
                maxSkyMilesDiscountPercent,
                Math.floor(normalizedMiles / skyMilesStep) * skyMilesDiscountPercentPerStep);
        }

        function getMaxRedeemableSkyMiles() {
            const currentMiles = Number(document.getElementById('CurrentSkyMiles').value || 0);
            return Math.min(maxSkyMilesRedeemable, Math.floor(currentMiles / skyMilesStep) * skyMilesStep);
        }

        function updateSkyMilesState() {
            const currentMiles = Number(document.getElementById('CurrentSkyMiles').value || 0);
            const selectedMiles = normalizeSkyMiles(document.getElementById('SkyMilesToRedeem').value || 0);
            const selectedDiscountPercent = calculateSkyMilesDiscountPercent(selectedMiles);
            const maxEligibleMiles = getMaxRedeemableSkyMiles();

            document.getElementById('SkyMilesToRedeem').value = selectedMiles;
            document.getElementById('SkyMilesDiscountPercent').value = selectedDiscountPercent;
            document.getElementById('skymiles-current').textContent = formatMiles(currentMiles);
            document.getElementById('skymiles-selected').textContent = formatMiles(selectedMiles);

            const affordability = document.getElementById('skymiles-affordability');
            affordability.classList.toggle('is-good', selectedMiles > 0);
            affordability.classList.toggle('is-warning', selectedMiles === 0);

            if (selectedMiles > 0) {
                affordability.textContent = 'This booking is using ' + selectedDiscountPercent + '% SkyMiles discount.';
            } else if (maxEligibleMiles > 0) {
                affordability.textContent = 'You can currently unlock up to ' + calculateSkyMilesDiscountPercent(maxEligibleMiles) + '% off with SkyMiles.';
            } else {
                affordability.textContent = 'You need at least 1,000 SkyMiles to unlock a ticket discount.';
            }

            [0, 1000, 2000].forEach(option => {
                const button = document.getElementById('skymiles-option-' + option);
                if (!button) {
                    return;
                }

                const isDisabled = option > maxEligibleMiles;
                button.classList.toggle('is-active', option === selectedMiles);
                button.classList.toggle('is-disabled', isDisabled);
                button.disabled = isDisabled;
            });
        }

        function refreshPricingSummary() {
            const baseFare = Number(document.getElementById('Price').value || 0);
            const taxAmount = Number(document.getElementById('TaxAmount').value || 0);
            const promotionDiscountAmount = Number(document.getElementById('DiscountAmount').value || 0);
            const selectedMiles = normalizeSkyMiles(document.getElementById('SkyMilesToRedeem').value || 0);
            const skyMilesDiscountPercent = calculateSkyMilesDiscountPercent(selectedMiles);
            const skyMilesDiscountAmount = Math.round(baseFare * skyMilesDiscountPercent / 100);
            const finalAmount = Math.max(0, Math.round(baseFare + taxAmount - promotionDiscountAmount - skyMilesDiscountAmount));

            document.getElementById('SkyMilesDiscountPercent').value = skyMilesDiscountPercent;
            document.getElementById('SkyMilesDiscountAmount').value = skyMilesDiscountAmount;
            document.getElementById('FinalPrice').value = finalAmount;

            document.getElementById('summary-base-price').textContent = formatMoney(baseFare);
            document.getElementById('summary-tax-price').textContent = formatMoney(taxAmount);
            document.getElementById('summary-final-price').textContent = formatMoney(finalAmount);

            const skymilesRow = document.getElementById('skymiles-row');
            const skymilesLabel = document.getElementById('summary-skymiles-label');
            const skymilesPrice = document.getElementById('summary-skymiles-discount');

            if (skyMilesDiscountPercent > 0) {
                skymilesRow.classList.add('is-visible');
                skymilesLabel.textContent = 'SkyMiles (-' + skyMilesDiscountPercent + '%)';
                skymilesPrice.textContent = '-' + formatMoney(skyMilesDiscountAmount);
            } else {
                skymilesRow.classList.remove('is-visible');
                skymilesLabel.textContent = 'SkyMiles';
                skymilesPrice.textContent = '-0 VND';
            }

            updateSkyMilesState();
        }

        function setPromotionSummary(data) {
            document.getElementById('PromoCode').value = data.promoCode || '';
            document.getElementById('AppliedPromotionId').value = data.promoId || '';
            document.getElementById('DiscountPercent').value = data.discountPercent || 0;
            document.getElementById('TaxAmount').value = data.taxAmount || 0;
            document.getElementById('DiscountAmount').value = data.discountAmount || 0;
            if (typeof data.skyMilesRedeemed !== 'undefined') {
                document.getElementById('SkyMilesToRedeem').value = data.skyMilesRedeemed || 0;
            }

            const discountRow = document.getElementById('discount-row');
            const discountLabel = document.getElementById('summary-discount-label');
            const discountPrice = document.getElementById('summary-discount-price');

            if (Number(data.discountPercent || 0) > 0) {
                discountRow.classList.add('is-visible');
                discountLabel.textContent = 'Promotion (-' + data.discountPercent + '%)';
                discountPrice.textContent = '-' + formatMoney(data.discountAmount);
            } else {
                discountRow.classList.remove('is-visible');
                discountLabel.textContent = 'Promotion';
                discountPrice.textContent = '-0 VND';
            }

            refreshPricingSummary();
        }

        function setFeedback(message, isSuccess) {
            const feedback = document.getElementById('promoFeedback');
            feedback.classList.remove('is-success', 'is-error');
            feedback.textContent = message || '';

            if (!message) {
                return;
            }

            feedback.classList.add(isSuccess ? 'is-success' : 'is-error');
        }

        function resetPromotionValues() {
            setPromotionSummary({
                promoCode: '',
                promoId: '',
                discountPercent: 0,
                taxAmount: document.getElementById('TaxAmount').value || 0,
                discountAmount: 0
            });
        }

        function selectSkyMilesOption(miles) {
            const selectedMiles = normalizeSkyMiles(miles);
            if (selectedMiles > getMaxRedeemableSkyMiles()) {
                return;
            }

            document.getElementById('SkyMilesToRedeem').value = selectedMiles;
            refreshPricingSummary();
        }

        async function applyPromotion() {
            const input = document.getElementById('promoCodeInput');
            const code = (input.value || '').trim().toUpperCase();

            if (!code) {
                clearPromotion();
                return;
            }

            const params = new URLSearchParams({
                scheduleId: document.getElementById('ScheduleId').value,
                seatId: document.getElementById('SeatId').value,
                code,
                skyMilesToRedeem: document.getElementById('SkyMilesToRedeem').value || 0
            });

            try {
                const response = await fetch('/Booking/ValidatePromotion?' + params.toString());
                const result = await response.json();

                if (!result.success) {
                    resetPromotionValues();
                    setFeedback(result.message || 'Promotion code is invalid.', false);
                    return;
                }

                input.value = result.promoCode || code;
                setPromotionSummary(result);
                setFeedback('Applied code ' + (result.promoCode || code) + ' successfully.', true);
            } catch {
                setFeedback('Unable to validate promotion right now.', false);
            }
        }

        function clearPromotion() {
            document.getElementById('promoCodeInput').value = '';
            resetPromotionValues();
            setFeedback('', true);
        }

        function selectPromotion(code) {
            document.getElementById('promoCodeInput').value = code;
            applyPromotion();
        }

        document.addEventListener('DOMContentLoaded', function () {
            refreshPricingSummary();
            document.querySelector('.passenger-form')?.addEventListener('submit', function () {
                document.getElementById('PromoCode').value = (document.getElementById('promoCodeInput').value || '').trim().toUpperCase();
            });
        });
    </script>
}
