@model Airline.Models.FlightSchedule
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Select Your Seat";
}

<style>
    .booking-container {
        max-width: 1000px;
        margin: 40px auto;
        padding: 20px;
        color: #fff;
    }
    .seat-map-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 3rem;
        margin-top: 2rem;
    }
    .seat-grid {
        display: grid;
        grid-template-columns: repeat(7, 45px); /* 6 seats + 1 aisle */
        gap: 15px;
        margin-top: 2rem;
    }
    .seat {
        width: 45px;
        height: 45px;
        border-radius: 10px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4,0,0.2,1);
    }
    .seat:hover:not(.occupied):not(.blocked) {
        transform: scale(1.1);
        background: rgba(255,255,255,0.2);
        border-color: var(--ocean-aqua);
    }
    .seat.selected {
        background: var(--ocean-aqua);
        border-color: #0fd2e4;
        color: #fff;
        box-shadow: 0 0 15px rgba(23,170,184,0.4);
    }
    .seat.occupied {
        background: var(--accent-coral);
        border-color: #ff4d4d;
        cursor: not-allowed;
        opacity: 0.6;
    }
    .seat.blocked {
        background: #444;
        border-color: #555;
        cursor: not-allowed;
        opacity: 0.4;
    }
    .aisle {
        width: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        color: rgba(255,255,255,0.3);
        font-weight: 700;
    }
    .legend {
        display: flex;
        gap: 20px;
        margin-bottom: 2rem;
    }
    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
    }
    .legend-box {
        width: 18px;
        height: 18px;
        border-radius: 4px;
    }
    .bottom-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(6, 21, 37, 0.9);
        backdrop-filter: blur(20px);
        padding: 20px 40px;
        border-top: 1px solid rgba(255,255,255,0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 1000;
    }
    .selected-info {
        display: flex;
        flex-direction: column;
    }
</style>

<div class="booking-container" style="margin-bottom: 120px;">
    <div class="section-heading">
        <span class="section-kicker">Seat Selection</span>
        <h2>Choose Your <span>Favorite Position</span></h2>
        <p>Flight @Model.Flight.FlightNumber | @Model.Flight.Route.DepartureCityNavigation.CityName to @Model.Flight.Route.ArrivalCityNavigation.CityName</p>
    </div>

    <div class="seat-map-wrapper">
        <div class="legend">
            <div class="legend-item"><div class="legend-box" style="background:rgba(255,255,255,0.1)"></div> Available</div>
            <div class="legend-item"><div class="legend-box" style="background:var(--ocean-aqua)"></div> Selected</div>
            <div class="legend-item"><div class="legend-box" style="background:var(--accent-coral)"></div> Occupied</div>
            <div class="legend-item"><div class="legend-box" style="background:#444"></div> Unavailable</div>
        </div>

        <div class="seat-grid">
            @for (int i = 0; i < (Model.TotalSeats / 6) + 1; i++)
            {
                int rowNum = i + 1;
                string[] letters = { "A", "B", "C", "D", "E", "F" };
                
                for (int j = 0; j < 7; j++)
                {
                    if (j == 3) // Aisle
                    {
                        <div class="aisle">@rowNum</div>
                    }
                    else
                    {
                        int seatIdx = (j > 3) ? j - 1 : j;
                        string seatNum = $"{rowNum}{letters[seatIdx]}";
                        int seatAbsoluteIndex = (i * 6) + seatIdx + 1;

                        if (seatAbsoluteIndex <= (Model.TotalSeats ?? 0))
                        {
                            var ticket = Model.Bookings.SelectMany(b => b.Tickets).FirstOrDefault(t => t.SeatNumber == seatNum);
                            string statusClass = "";
                            if (ticket != null)
                            {
                                statusClass = (ticket.Status == "BLOCKED") ? "blocked" : "occupied";
                            }
                            
                            <div class="seat @statusClass" id="seat-@seatNum" 
                                 onclick="selectSeat('@seatNum', '@statusClass')">@seatNum</div>
                        }
                    }
                }
            }
        </div>
    </div>
</div>

<div class="bottom-bar">
    <div class="selected-info">
        <span style="font-size: 0.8rem; color: rgba(255,255,255,0.5);">SELECTED SEAT</span>
        <strong id="displaySeat" style="font-size: 1.5rem; color: var(--ocean-aqua);">None</strong>
    </div>
    
    <div class="selected-info">
        <span style="font-size: 0.8rem; color: rgba(255,255,255,0.5);">TOTAL PRICE</span>
        <strong style="font-size: 1.5rem; color: var(--accent-gold);">1.500.000 VND</strong>
    </div>

    <form action="/Booking/PassengerInfo" method="post">
        <input type="hidden" name="scheduleId" value="@Model.ScheduleId" />
        <input type="hidden" name="seatNumber" id="hiddenSeat" />
        <button type="submit" class="btn-select" style="font-size: 1.1rem; padding: 15px 40px;">
            Continue to Passenger Info
        </button>
    </form>
</div>

@section Scripts {
    <script>
        let selectedSeat = null;

        function selectSeat(seatNum, status) {
            if (status === 'occupied' || status === 'blocked') return;

            if (selectedSeat) {
                document.getElementById('seat-' + selectedSeat).classList.remove('selected');
            }

            if (selectedSeat === seatNum) {
                selectedSeat = null;
                document.getElementById('displaySeat').textContent = 'None';
                document.getElementById('hiddenSeat').value = '';
            } else {
                selectedSeat = seatNum;
                document.getElementById('seat-' + seatNum).classList.add('selected');
                document.getElementById('displaySeat').textContent = seatNum;
                document.getElementById('hiddenSeat').value = seatNum;
            }
        }
    </script>
}
