@model Airline.Models.FlightSchedule
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Select Your Seat";
}

@section Styles {
    <link rel="stylesheet" href="~/css/booking/select-seat.css" />
}

<div class="booking-container" style="margin-bottom: 120px;">
    <div class="section-heading">
        <span class="section-kicker">Seat Selection</span>
        <h2>Choose Your <span>Favorite Position</span></h2>
        <p>Flight @Model.Flight.FlightNumber | @Model.Flight.Route.DepartureCityNavigation.CityName to @Model.Flight.Route.ArrivalCityNavigation.CityName</p>
    </div>

    <div class="seat-map-wrapper">
        <div class="legend">
            <div class="legend-item"><div class="legend-box" style="background:rgba(255,255,255,0.1)"></div> Available</div>
            <div class="legend-item"><div class="legend-box" style="background:var(--ocean-aqua)"></div> Selected</div>
            <div class="legend-item"><div class="legend-box" style="background:var(--accent-coral)"></div> Occupied</div>
            <div class="legend-item"><div class="legend-box" style="background:#444"></div> Unavailable</div>
        </div>

        <div class="seat-grid">
            @for (int i = 0; i < (Model.TotalSeats / 6) + 1; i++)
            {
                int rowNum = i + 1;
                string[] letters = { "A", "B", "C", "D", "E", "F" };
                
                for (int j = 0; j < 7; j++)
                {
                    if (j == 3) // Aisle
                    {
                        <div class="aisle">@rowNum</div>
                    }
                    else
                    {
                        int seatIdx = (j > 3) ? j - 1 : j;
                        string seatNum = $"{rowNum}{letters[seatIdx]}";
                        int seatAbsoluteIndex = (i * 6) + seatIdx + 1;

                        if (seatAbsoluteIndex <= (Model.TotalSeats ?? 0))
                        {
                            var ticket = Model.Bookings.SelectMany(b => b.Tickets).FirstOrDefault(t => t.SeatNumber == seatNum);
                            string statusClass = "";
                            if (ticket != null)
                            {
                                statusClass = (ticket.Status == "BLOCKED") ? "blocked" : "occupied";
                            }
                            
                            <div class="seat @statusClass" id="seat-@seatNum" 
                                 onclick="selectSeat('@seatNum', '@statusClass')">@seatNum</div>
                        }
                    }
                }
            }
        </div>
    </div>
</div>

<div class="bottom-bar">
    <div class="selected-info">
        <span style="font-size: 0.8rem; color: rgba(255,255,255,0.5);">SELECTED SEAT</span>
        <strong id="displaySeat" style="font-size: 1.5rem; color: var(--ocean-aqua);">None</strong>
    </div>
    
    <div class="selected-info">
        <span style="font-size: 0.8rem; color: rgba(255,255,255,0.5);">TOTAL PRICE</span>
        <strong style="font-size: 1.5rem; color: var(--accent-gold);">1.500.000 VND</strong>
    </div>

    <form action="/Booking/PassengerInfo" method="post">
        <input type="hidden" name="scheduleId" value="@Model.ScheduleId" />
        <input type="hidden" name="seatNumber" id="hiddenSeat" />
        <button type="submit" class="btn-select" style="font-size: 1.1rem; padding: 15px 40px;">
            Continue to Passenger Info
        </button>
    </form>
</div>

@section Scripts {
    <script src="~/js/booking/select-seat.js"></script>
}
