@model int
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Booking Successful";
}

@section Styles {
    <link rel="stylesheet" href="~/css/booking/booking-success.css" />
}

<div class="success-container">
    <div class="success-icon">
        <i class="fa-solid fa-check"></i>
    </div>
    
    <div class="section-heading">
        <span class="section-kicker">Confirmed</span>
        <h2>Booking <span>Successful</span></h2>
    </div>

    <p style="margin-top: 20px; color: rgba(255,255,255,0.7);">
        Thank you for choosing SkyWave Airlines. Your reservation has been confirmed.
    </p>

    <div class="booking-id">
        RESERVATION ID: #@Model.ToString("D6")
    </div>

    <div style="margin-top: 40px; display: flex; gap: 15px; justify-content: center;">
        <a asp-controller="Home" asp-action="Index" class="home-btn secondary">Back to Home</a>
        <a asp-controller="Profile" asp-action="MyTickets" class="home-btn primary">View My Tickets</a>
    </div>
</div>
