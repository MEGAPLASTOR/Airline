@model Airline.Models.Ticket
@{
    ViewData["Title"] = "Register Extra Baggage";
    var schedule = Model.Booking.Schedule;
    var flight = schedule.Flight;
    var route = flight.Route;
}

<style>
    .baggage-container {
        padding: 3rem 2rem;
        max-width: 800px;
        margin: 0 auto;
    }
    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.25rem;
        font-weight: 700;
        margin-bottom: 2rem;
        text-align: center;
    }
    .ticket-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-lg);
        padding: 1.5rem 1.75rem;
        margin-bottom: 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .weight-options {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
        gap: 1.25rem;
        margin-bottom: 2.5rem;
    }
    .weight-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-md);
        padding: 1.5rem 1rem;
        text-align: center;
        cursor: pointer;
        transition: all var(--transition);
    }
    .weight-card:hover {
        transform: translateY(-5px);
        border-color: rgba(23, 170, 184, 0.5);
        background: rgba(255, 255, 255, 0.06);
    }
    .weight-card.selected {
        background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
        border-color: transparent;
        box-shadow: 0 8px 25px rgba(23, 170, 184, 0.3);
    }
    .weight-val {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
    }
    .weight-unit {
        font-size: 0.8rem;
        opacity: 0.6;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
    .price-box {
        background: rgba(0, 0, 0, 0.2);
        border-radius: 15px;
        padding: 1.5rem 2rem;
        text-align: center;
        margin-bottom: 2rem;
    }
    .price-val {
        font-size: 2.25rem;
        font-weight: 700;
        color: var(--accent-gold);
        margin-top: 0.5rem;
    }
    .btn-submit {
        width: 100%;
        background: linear-gradient(135deg, var(--ocean-aqua), var(--ocean-teal));
        padding: 1.15rem;
        border-radius: 12px;
        border: none;
        color: #fff;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 18px rgba(23, 170, 184, 0.38);
    }
    .btn-submit:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }
</style>

<div class="baggage-container">
    <h1 class="page-title">Register <span>Extra Baggage</span></h1>

    <div class="ticket-card">
        <div>
            <div style="font-size: 0.75rem; color: var(--ocean-aqua); font-weight: 700; text-transform: uppercase; margin-bottom: 0.35rem;">Ticket Detail</div>
            <div style="font-size: 1.25rem; font-weight: 600;">#@Model.TicketId | @flight.FlightNumber</div>
            <div style="font-size: 0.9rem; opacity: 0.6;">Seat: @(Model.SeatNumber ?? "N/A") | @Model.Passenger.FullName</div>
        </div>
        <div style="text-align: right;">
            <div style="font-size: 1.25rem; font-weight: 700; color: #fff;">@route.DepartureCityNavigation.CityName</div>
            <div style="font-size: 0.8rem; opacity: 0.4;">TO</div>
            <div style="font-size: 1.25rem; font-weight: 700; color: #fff;">@route.ArrivalCityNavigation.CityName</div>
        </div>
    </div>

    <div style="margin-bottom: 1rem; font-weight: 600; opacity: 0.8;">CHỌN KHỐI LƯỢNG HÀNH LÝ:</div>
    <div class="weight-options">
        <div class="weight-card" onclick="selectWeight(20)">
            <div class="weight-val">20</div>
            <div class="weight-unit">Kilograms</div>
        </div>
        <div class="weight-card" onclick="selectWeight(25)">
            <div class="weight-val">25</div>
            <div class="weight-unit">Kilograms</div>
        </div>
        <div class="weight-card" onclick="selectWeight(30)">
            <div class="weight-val">30</div>
            <div class="weight-unit">Kilograms</div>
        </div>
        <div class="weight-card" onclick="selectWeight(40)">
            <div class="weight-val">40</div>
            <div class="weight-unit">Kilograms</div>
        </div>
    </div>

    <div class="price-box">
        <div style="font-size: 0.75rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.08em;">Total Baggage Fee</div>
        <div class="price-val" id="displayPrice">0 VND</div>
    </div>

    <button id="btnSubmit" class="btn-submit" disabled onclick="submitBaggage()">Review & Confirm Baggage</button>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
    <script>
        let selectedWeight = 0;
        const ticketId = @Model.TicketId;
        const unitPrice = 20000;

        function selectWeight(val) {
            selectedWeight = val;
            
            // UI Update
            document.querySelectorAll('.weight-card').forEach(el => el.classList.remove('selected'));
            event.currentTarget.classList.add('selected');

            // Price Update
            const totalPrice = selectedWeight * unitPrice;
            document.getElementById('displayPrice').textContent = totalPrice.toLocaleString('vi-VN') + ' VND';
            document.getElementById('btnSubmit').disabled = false;
        }

        function submitBaggage() {
            if (selectedWeight === 0) return;

            Swal.fire({
                title: 'Confirm Baggage',
                text: `Bạn đăng ký thêm ${selectedWeight}kg hành lý ký gửi. Tổng phí: ${(selectedWeight * unitPrice).toLocaleString('vi-VN')} VND. Bạn có muốn tiếp tục?`,
                icon: 'info',
                showCancelButton: true,
                confirmButtonColor: '#17aab8',
                confirmButtonText: 'Xác nhận đăng ký'
            }).then((result) => {
                if (result.isConfirmed) {
                    const formData = new FormData();
                    formData.append('ticketId', ticketId);
                    formData.append('weight', selectedWeight);
                    
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    fetch('/Baggage/ProcessRegister', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': token
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire('Thành công!', data.message, 'success')
                            .then(() => {
                                window.location.href = '/Ticket/ViewConfirmation';
                            });
                        } else {
                            Swal.fire('Error', data.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
